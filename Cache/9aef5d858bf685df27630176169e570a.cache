e";s:6:"status";s:9:"published";s:14:"params_general";s:637:"{"1":{"name":"pow. u\u017cytkowa","value":152.7,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":156.55,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":25.9,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":21.67,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":5,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":40,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":8.34,"unit":"m"},"17":{"name":"pow. netto poddasza","value":100.45,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"474401","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-02-27 14:49:58";s:10:"technology";s:209:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas, blacha tytanowo-cynkowa (lukarny). Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:215:"{"features":["10","47"],"thumbnail":"1180\/aston-ii-wizualizacja-200-5954f2c647d61.jpg","templateId":"3","isbn":"978-83-7937-138-9","isbn_mirror":"978-83-7937-139-6","price_other_type":null,"skeleton_disabled":null}";}i:857;a:22:{s:2:"id";i:63;s:6:"id_old";i:63;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:51;s:4:"name";s:8:"Telimena";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:100:"Parterowy dom z poddaszem użytkowym i garażem, z 4 sypialniami i tarasem - częściowo w podcieniu";s:11:"description";s:600:"Elegancki budynek dla zwolenników tradycji. W centrum parteru zaprojektowano pokój dzienny, komfortowe i przestronne miejsce dla całej rodziny, doświetlone oknami ryzalitu. W ciepłe dni do wyjścia na zewnątrz zachęca dostępny z jadalni niewielki taras, który stanowi łącznik wnętrza z otaczającym dom ogrodem. Prywatną strefę nocną przewidziano tradycyjnie na poddaszu, które poza czterema sypialniami mieści również dużą, ponad 10-metrową łazienkę. W bryłę budynku wkomponowano dwustanowiskowy garaż. Dom będzie komfortowym lokum dla cztero lub pięcioosobowej rodziny.";s:21:"alternate_description";N;s:5:"price";s:7:"5299.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:614:"{"1":{"name":"pow. u\u017cytkowa","value":"157,8","unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":"144,9","unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":"20,5","unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":"22,52","unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":"5","unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":"41","unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":"9,03","unit":"m"},"17":{"name":"pow. netto poddasza","value":"111,2","unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"477016","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-13 14:43:04";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:190:"{"thumbnail":"63\/telimena-wizualizacja-200-5954d4be9aeb2.jpg","templateId":"3","price_other_type":null,"skeleton_disabled":null,"isbn":"978-83-87603-50-2","isbn_mirror":"978-83-7356-036-9"}";}i:858;a:22:{s:2:"id";i:71;s:6:"id_old";i:71;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:59;s:4:"name";s:11:"Dom W Parku";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:105:"Dom parterowy z kopertowym dachem, wejściem z kolumnami i narożnym, niezadaszonym tarasem wypoczynkowym";s:11:"description";s:353:"Ten mały, kompaktowy dom parterowy mieści trzy niezależne sypialnie, łazienkę oraz dodatkowe w.c ., a także przestrzeń dzienną z dużym pokojem, kuchnią i aneksem jadalnym. Wspólną przestrzeń uzupełnia zaciszny taras z tyłu domu. Ozdobny, wsparty na kolumnach daszek osłaniający wejście, nadaje projektowi uroku i zaprasza do odwiedzin.";s:21:"alternate_description";N;s:5:"price";s:7:"4599.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:631:"{"1":{"name":"pow. u\u017cytkowa","value":97.85,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":128,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":22.2,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":20.5,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":4,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":31,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":5.28,"unit":"m"},"17":{"name":"pow. netto poddasza","value":null,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"247463","self":null}";s:10:"meta_title";s:82:"Dom w Parku. Mały uroczy dom parterowy bez garażu dla rodziny 2+2. Studio Atrium";s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-10 09:00:26";s:10:"technology";s:156:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:288:"{"garages":["37","155","322","323","511","512","652","654","655","656","701"],"thumbnail":"71\/dom-w-parku-wizualizacja-200-5954d4cb1abef.jpg","templateId":"1","isbn":"978-83-89103-29-1","isbn_mirror":"978-83-7356-081-9","features":["21"],"price_other_type":null,"skeleton_disabled":null}";}i:859;a:22:{s:2:"id";i:1186;s:6:"id_old";i:1186;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:1154;s:4:"name";s:13:"New House III";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:126:"Nowoczesny piętrowy dom z dwuspadowym dachem, 4 sypialnie, przeszklony taras i przestronny balkon, z garażem 2-stanowiskowym";s:11:"description";s:782:"Nowoczesny, oryginalny i kompaktowy dom piętrowy o bardzo ciekawej architekturze. Oddzielenie przestrzeni kuchenno-jadalnej od pokoju dziennego to dobre rozwiązanie dla osób, które lubią przygotowywać posiłki w spokoju lub obawiają się przenikania zapachów gotowanych potraw do pozostałych pomieszczeń w domu. Dzięki dużym przeszkleniom strefa dzienna pozostaje przestronna i dobrze nasłoneczniona. Możliwość spędzania czasu na świeżym powietrzu oferuje nie tylko obszerny taras z tyłu domu, ale także przylegający do dwóch ścian narożny balkon dostępny z sypialni znajdujących się na piętrze. Funkcja pietra mieści cztery przestronne sypialnie oraz dwie łazienki. Dodatkowym atutem domu jest dwustanowiskowy garaż mieszczący się w bryle budynku.";s:21:"alternate_description";N;s:5:"price";s:7:"6999.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:639:"{"1":{"name":"pow. u\u017cytkowa","value":205.25,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":167.3,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":20.65,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":22.66,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":5,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":30,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":10.19,"unit":"m"},"17":{"name":"pow. netto poddasza","value":null,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":114.35,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"601910","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-02-26 11:46:40";s:10:"technology";s:283:"Technologia murowana: pustak ceramiczny gr. 25 cm +  ocieplenie w systemie Termo Organika, wykończenie ścian: dachówka, tynk. Pokrycie dachu: dachówka Braas, nad sypialnią główną - papa termozgrzewalna ew. membrana dachowa. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:215:"{"thumbnail":"1186\/new-house-iii-wizualizacja-200-5954fcd4a76e0.jpg","templateId":"2","isbn":"978-83-7937-404-5","isbn_mirror":"978-83-7937-405-2","price_other_type":null,"skeleton_disabled":null,"features":["37"]}";}i:860;a:22:{s:2:"id";i:1072;s:6:"id_old";i:1072;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:1034;s:4:"name";s:9:"Oxford IV";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:115:"Parterowy dom z poddaszem użytkowym i garażem 2-stanowiskowym, z 6 sypialniami i narożnym, niezadaszonym tarasem";s:11:"description";s:619:"Komfortowy dom dla dużej rodziny. Rozbudowany program użytkowy parteru umożliwia realizację  w dwóch etapach. Poza strefą wypoczynkową, obejmującą salon z aneksem kuchennym, na parterze mamy trzy sypialnie, pomieszczenie gospodarcze i kotłownię. Poddasze mieści trzy duże pokoje, garderobę i łazienkę. Dom został wyposażony w dwustanowiskowy garaż zaprojektowany od frontu, co umożliwia jego realizację na wąskich działkach. Jasny kolor elewacji świetnie komponuje się z drewnianymi deskami oraz ciemną dachówką. Projekt dobrze wkomponuje się zarówno w miejskie jak i podmiejskie działki.";s:21:"alternate_description";N;s:5:"price";s:7:"5599.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:637:"{"1":{"name":"pow. u\u017cytkowa","value":232.6,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":197.8,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":19.73,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":27.23,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":7,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":40,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":8.24,"unit":"m"},"17":{"name":"pow. netto poddasza","value":159.55,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"627049","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-02-26 11:38:10";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:211:"{"thumbnail":"1072\/oxford-iv-wizualizacja-200-5954f2d7771a5.jpg","templateId":"3","isbn":"978-83-7937-130-3","isbn_mirror":"978-83-7937-131-0","features":["48"],"price_other_type":null,"skeleton_disabled":null}";}i:861;a:22:{s:2:"id";i:1045;s:6:"id_old";i:1045;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:1032;s:4:"name";s:4:"Olek";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:131:"Dom parterowy z dwuspadowym dachem w nowoczesnej stylistyce, z poddaszem użytkowym i garażem, z lukarną i balkonem nad wejściem";s:11:"description";s:883:"Rozbielone beże, szarości i drewno – takie połączenie to strzał w dziesiątkę. Drewniane, interesująco zaaranżowane elementy elewacji przykuwają uwagę i nadają charakteru całości. Ukryty na tyłach domu taras z widokiem na ogród jest miejscem, w którym można spędzić długie godziny z kawą i książką. Dodatkowe miejsce na wypoczynek to taras nad garażem przynależny do sypialni rodziców.  Na parterze, w pokoju dziennym i kuchni połączonej z jadalnią, będzie toczyć się ożywione życie rodzinne. Cechą szczególną jest bardzo przestronny jak na niewielką powierzchnię domu przedsionek, z którego zaprojektowano przejście do garażu, jak również wejście do schowka pod schodami na poddasze. Druga kondygnacja to „strefa nocna”, z trzema sypialniami i dwoma łazienkami. Dom spełni potrzeby zarówno cztero jak i pięcioosobowej rodziny.";s:21:"alternate_description";N;s:5:"price";s:7:"4899.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:635:"{"1":{"name":"pow. u\u017cytkowa","value":121.1,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":124.7,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":20.54,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":18.28,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":5,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":40,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":8.67,"unit":"m"},"17":{"name":"pow. netto poddasza","value":65.7,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"379515","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-11 15:54:26";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:188:"{"thumbnail":"1045\/olek-wizualizacja-200-5954f2dedb3ea.jpg","templateId":"3","isbn":"978-83-7937-122-8","isbn_mirror":"978-83-7937-123-5","price_other_type":null,"skeleton_disabled":null}";}i:862;a:22:{s:2:"id";i:1223;s:6:"id_old";i:1223;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:1190;s:4:"name";s:9:"Saturn VI";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:84:"Dom parterowy z 5 sypialniami, z podcieniem wejściowym, z garażem dwustanowiskowym";s:11:"description";s:451:"Elegancka parterówka z dwustanowiskowym garażem. Na uwagę zasługuje ilość pokoi w tym średniej wielkości domu. Poza salonem do dyspozycji mieszkańców jest 5 dodatkowych pokoi, w tym jeden z własną łazienką. Ciekawym elementem architektonicznym jest podcienie tworzące funkcjonalne zadaszenie nad wejściem do budynku. Stonowana, zwarta bryła przykryta wielospadowym dachem wkomponuje się zarówno w miejski jak i podmiejski krajobraz.";s:21:"alternate_description";N;s:5:"price";s:7:"5199.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:636:"{"1":{"name":"pow. u\u017cytkowa","value":135.3,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":235.05,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":26.35,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":23.55,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":6,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":30,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":7.17,"unit":"m"},"17":{"name":"pow. netto poddasza","value":null,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"448296","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-13 13:14:36";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:214:"{"price_other_type":null,"thumbnail":"1223\/saturn-vi-wizualizacja-200-5954fce681d64.jpg","templateId":"1","isbn":"978-83-7937-548-6","isbn_mirror":"978-83-7937-549-3","sun_ratio":"0.0182","skeleton_disabled":null}";}i:863;a:22:{s:2:"id";i:944;s:6:"id_old";i:944;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:925;s:4:"name";s:8:"Astra II";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:116:"Dom parterowy z poddaszem użytkowym i garażem, z lukarną i balkonem nad wejściem, z kotłownią na paliwo stałe";s:11:"description";s:400:"W klasycznej konstrukcji z jednostanowiskowym garażem zaskakuje ilość pomieszczeń. Na poddaszu znajdziemy nie tylko trzy sypialnie i dużą garderobę, ale także dołączone do łazienki zaplecze mogące z powodzeniem pełnić rolę pralni i suszarni. Na parterze tuż obok otwartej kuchni umieszczono niewielką spiżarkę. Kotłownia została zaprojektowana pod montaż pieca na paliwo stałe.";s:21:"alternate_description";N;s:5:"price";s:7:"5299.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:634:"{"1":{"name":"pow. u\u017cytkowa","value":142.55,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":133.65,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":22,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":18.15,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":5,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":40,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":8.34,"unit":"m"},"17":{"name":"pow. netto poddasza","value":97.5,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"420176","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-02-27 14:51:11";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:213:"{"features":["1","36"],"thumbnail":"944\/astra-ii-wizualizacja-200-5954f2e6346d0.jpg","templateId":"3","price_other_type":null,"skeleton_disabled":null,"isbn":"978-83-7559-993-0","isbn_mirror":"978-83-7559-997-8"}";}i:864;a:22:{s:2:"id";i:1063;s:6:"id_old";i:1063;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:912;s:4:"name";s:15:"Orle Gniazdo II";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:98:"Dom parterowy z poddaszem użytkowym i 2-stanowiskowym garażem, z lukarną i balkonem nad tarasem";s:11:"description";s:617:"Utrzymany w nieco jaśniejszej niż jego poprzednik kolorystyce, dom zyskał inne zdobienia. Drewniane kolumny zostały zastąpione przez bardziej masywne, wydobywające podobieństwa do szlacheckiego dworku. Umieszczono nad nimi balkon. Dwustanowiskowy garaż wkomponowany w bryłę budynku od frontu sprawia, że szerokość elewacji frontowej nie jest duża i umożliwia realizację tego domu nawet na niezbyt szerokich działkach. Przestronny parter stanowi miejsce relaksu domowników i ich gości natomiast poddasze to typowa strefa sypialna z łazienką i pomieszczeniem przeznaczonym na pralnię i suszarnię.";s:21:"alternate_description";N;s:5:"price";s:7:"5399.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:638:"{"1":{"name":"pow. u\u017cytkowa","value":147.85,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":154.05,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":21.15,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":23.33,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":5,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":40,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":8.26,"unit":"m"},"17":{"name":"pow. netto poddasza","value":111.5,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"454886","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-11 16:08:18";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:199:"{"thumbnail":"1063\/orle-gniazdo-ii-wizualizacja-200-5954f2ed55e83.jpg","templateId":"3","isbn":"978-83-7559-988-6","isbn_mirror":"978-83-7559-992-3","price_other_type":null,"skeleton_disabled":null}";}i:865;a:22:{s:2:"id";i:1027;s:6:"id_old";i:1027;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:899;s:4:"name";s:8:"Omega II";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:117:"Parterowy dom z poddaszem użytkowym i 2-stanowiskowym garażem, z częściowo zadaszonym tarasem, bez podpiwniczenia";s:11:"description";s:538:"Średniej wielkości dom dla cztero lub pięcioosobowej rodziny. Pod rozłożystym, dwuspadowym dachem w kolorze grafitu ukrywa się dwustanowiskowy garaż, dzięki czemu konstrukcja uzyskuje wydłużony, lecz nadal proporcjonalny kształt. Chłodny kolor dachu został ocieplony przez beżowy odcień elewacji i drewniane elementy okien, drzwi i tarasu. Duże, ponad 17-metrowe pomieszczenie na poddaszu może służyć jako pralnia, ale również, ze względu na swoje rozmiary, pełnić funkcję pracowni lub miejsca do majsterkowania.";s:21:"alternate_description";N;s:5:"price";s:7:"4899.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:637:"{"1":{"name":"pow. u\u017cytkowa","value":121.75,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":142.65,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":23.8,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":18.05,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":5,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":42,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":8.41,"unit":"m"},"17":{"name":"pow. netto poddasza","value":87.55,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"416543","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-11 15:56:27";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:210:"{"thumbnail":"1027\/omega-ii-wizualizacja-200-5954e8b00bc18.jpg","templateId":"3","isbn":"978-83-7559-887-2","isbn_mirror":"978-83-7559-891-9","features":["23"],"price_other_type":null,"skeleton_disabled":null}";}i:866;a:22:{s:2:"id";i:687;s:6:"id_old";i:687;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:608;s:4:"name";s:10:"Fortuna II";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:112:"Dom parterowy z poddaszem użytkowym i garażem, z 4 sypialniami i częściowo zadaszonym tarasem, podpiwniczony";s:11:"description";s:476:"Doskonały wybór dla pięcioosobowej rodziny poszukującej komfortowego i przyjaznego lokum z dużymi możliwościami. Podpiwniczenie całej powierzchni domu generuje sporą powierzchnię gospodarczą, pozwalając przechować wszystkie niezbędne sprzęty i przedmioty. Poddasze mieści cztery sypialnie i łazienkę, dodatkowa znajduje się także na parterze. Duży i jasny pokój dzienny z kominkiem to komfortowa przestrzeń, zachęcająca do wspólnego spędzania czasu.";s:21:"alternate_description";N;s:5:"price";s:7:"5399.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:613:"{"1":{"name":"pow. u\u017cytkowa","value":"131,9","unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":"123,4","unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":"19,19","unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":"19,3","unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":"5","unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":"42","unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":"8,45","unit":"m"},"17":{"name":"pow. netto poddasza","value":"89,1","unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"533018","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-10 12:06:29";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:211:"{"features":["10"],"thumbnail":"687\/fortuna-ii-wizualizacja-200-5954e8bf5afec.jpg","templateId":"3","isbn":"978-83-7559-270-2","isbn_mirror":"978-83-7559-274-0","price_other_type":null,"skeleton_disabled":null}";}i:867;a:22:{s:2:"id";i:470;s:6:"id_old";i:470;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:428;s:4:"name";s:10:"Kwiatuszek";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:108:"Dom parterowy z poddaszem użytkowym, 4 sypialniami i garażem, lukarną z balkonem nad przeszklonym gankiem";s:11:"description";s:754:"Dom jednorodzinny o harmonijnej bryle i funkcjonalnym wnętrzu. Przeszklony ganek zaprojektowany od frontu nawiązuje do tradycyjnego budownictwa, podobnie jak prosty, dwuspadowy dach. Wnętrze projektu tworzy pięć niezależnych pokojów, dwie łazienki oraz przestronna strefa dzienna. Otwartą powierzchnię salonu ogrzewaną kominkiem połączono z jadalnią a dalej z kuchnią, tworząc komfortową przestrzeń dla wspólnie spędzanego czasu. Atutem jest duża kotłownia, która może pełnić również funkcję pralni. Do bryły budynku dołączono jednostanowiskowy garaż, przykryty pulpitowym dachem oraz taras, który będzie doskonałym miejscem wypoczynku w ciepłe dni. Kwiatuszek to ciekawa propozycja małego domu dla rodziny 2 plus 3.";s:21:"alternate_description";N;s:5:"price";s:7:"4899.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:616:"{"1":{"name":"pow. u\u017cytkowa","value":"122,65","unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":"116,35","unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":"20,62","unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":"18,22","unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":"6","unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":"45","unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":"8,75","unit":"m"},"17":{"name":"pow. netto poddasza","value":"68,5","unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"377493","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-10 15:39:00";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:211:"{"features":["10"],"thumbnail":"470\/kwiatuszek-wizualizacja-200-5954dd6fcef2d.jpg","templateId":"3","isbn":"978-83-7356-730-6","isbn_mirror":"978-83-7356-735-1","price_other_type":null,"skeleton_disabled":null}";}i:868;a:22:{s:2:"id";i:1181;s:6:"id_old";i:1181;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:1153;s:4:"name";s:16:"Marek i Wacek II";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:149:"Dom bliźniaczy, 4-lokalowy, parterowy, z poddaszem użytkowym i lukarnami, z 2-stanowiskowym garażem w segmencie - w podpiwniczeniu, dom na skarpę";s:11:"description";s:746:"Ciekawa propozycja dla deweloperów – dom w zabudowie bliźniaczej w ramach którego zaprojektowano cztery niezależne lokale mieszkalne. Budynek posiada trzy kondygnacje – piwnicę, parter i poddasze. W piwnicy ulokowano kotłownie i garaże, na parterze mieszkanie o powierzchni 77m2, natomiast na poddaszu ze względu na skosy nieco mniejsze o powierzchni 69m2. Każdy lokal mieszkalny posiada kuchnię, jadalnię i salon z kominkiem, dwa dodatkowe pokoje oraz łazienkę. Mieszkania na parterze mają wyjścia na taras natomiast na poddaszu – na balkon. W prosty dwuspadowy dach wkomponowano lukarny, przykryte płaskim dachem, dzięki czemu bryła nabrała nowoczesnego charakteru. Budynek można realizować na działkach ze spadkiem.";s:21:"alternate_description";N;s:5:"price";s:8:"10999.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:612:"{"1":{"name":"pow. u\u017cytkowa","value":"150,8","unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":"128,85","unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":"28,75","unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":"20,3","unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":"6","unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":"42","unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":"9,04","unit":"m"},"17":{"name":"pow. netto poddasza","value":"84","unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"622011","self":null}";s:10:"meta_title";s:82:"Marek i Wacek II. Bliźniaczy dom czterolokalowy z poddaszem użytk. Studio Atrium";s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-11 12:46:53";s:10:"technology";s:209:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas, blacha tytanowo-cynkowa (lukarny). Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:252:"{"features":["10","6","7","54"],"thumbnail":"1181\/marek-i-wacek-ii-wizualizacja-200-5954fbb80e019.jpg","templateId":"3","price_other_type":null,"skeleton_disabled":null,"isbn":"978-83-7937-400-7","isbn_mirror":"978-83-7937-401-4","sun_ratio":"0.0173"}";}i:869;a:22:{s:2:"id";i:1060;s:6:"id_old";i:1060;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:825;s:4:"name";s:7:"Viva II";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:118:"Nowoczesny dom parterowy z płaskim dachem,odkrytym tarasem wypoczynkowym i garażem 2-stanowiskowym, energooszczędny";s:11:"description";s:681:"Nowoczesna forma utrzymana w duchu szlachetnego minimalizmu. Zaprojektowaną na planie prostokąta bryłę urozmaica ganek zaakcentowany żywym kolorem elewacji. Wnętrze kryje trzy niezależne sypialnie, w tym jedną wyposażoną w garderobę, łazienkę oraz przestronną strefę dzienną dogrzewaną sezonowo kominkiem. Panoramiczne okna nie tylko zapewniają dobre nasłonecznienie pomieszczenia, ale także doskonały widok na okolicę. Bezpośredni łącznik wnętrza z otaczającą dom przestrzenią stanowi komfortowy taras, z którego po kilku schodkach możemy zejść wprost do ogrodu. W bryłę budynku wkomponowano dwustanowiskowy garaż z pomieszczeniem gospodarczym.";s:21:"alternate_description";N;s:5:"price";s:7:"4699.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:635:"{"1":{"name":"pow. u\u017cytkowa","value":101,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":180.65,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":18.34,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":27.5,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":4,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":null,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":4.02,"unit":"m"},"17":{"name":"pow. netto poddasza","value":null,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"327067","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-13 15:49:56";s:10:"technology";s:201:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: papa termozgrzewalna, ew. membrana dachowa. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:209:"{"thumbnail":"1060\/viva-ii-wizualizacja-200-5954e8c6f3a05.jpg","templateId":"1","price_other_type":null,"skeleton_disabled":null,"isbn":"978-83-7559-793-6","isbn_mirror":"978-83-7559-797-4","features":["23"]}";}i:870;a:22:{s:2:"id";i:792;s:6:"id_old";i:792;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:730;s:4:"name";s:10:"Milano III";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:110:"Nowoczesny dom piętrowy w stylu włoskim z 4 sypialniami, liczne przeszklenia, przestronny taras wypoczynkowy";s:11:"description";s:649:"Siła prostoty. Te dwa słowa świetnie oddają charakter tego projektu. Prosta bryła przykryta kopertowym dachem urzeka detalami, takimi jak wykusz czy ażurowa ścianka, okalająca narożny taras z jednej strony. Również program użytkowy został starannie przemyślany przez projektanta. Na parterze uwagę zwraca otwarta, dobrze doświetlona strefa dzienna, obejmująca kuchnię, jadalnię i pokój dzienny. Poza tym do dyspozycji mieszkańców jest gabinet, kotłownia i łazienka. Piętro mieści aż cztery pokoje, w tym sypialnię rodziców z garderobą oraz łazienkę. Milano III to ciekawa propozycja nawet dla pięcioosobowej rodziny.";s:21:"alternate_description";N;s:5:"price";s:7:"5099.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:633:"{"1":{