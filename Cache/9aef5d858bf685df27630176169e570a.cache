"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"365573","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-09 13:54:43";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:214:"{"features":["10"],"thumbnail":"395\/bajkowa-chata-wizualizacja-200-5954ddce80c1d.jpg","templateId":"3","isbn":"978-83-7356-850-1","isbn_mirror":"978-83-7356-855-6","price_other_type":null,"skeleton_disabled":null}";}i:953;a:22:{s:2:"id";i:1151;s:6:"id_old";i:1151;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:1135;s:4:"name";s:6:"Aladyn";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:153:"Dom piętrowy symetryczny z wielospadowym dachem i 4 sypialniami, przestronne balkony i tarasy, w części drewniana elewacja, dwa 1-stanowiskowe garaże";s:11:"description";s:417:"Symetryczna z zewnątrz konstrukcja kryje nietypowe rozwiązanie we wnętrzu. Powierzchnia parteru przeznaczona głównie na garaże i pomieszczenie rekreacyjne, przenosi mieszkalną strefę na piętro domu, które  mieści trzy przestronne sypialnie z osobnymi łazienkami, kuchnię oraz połączony z jadalnią pokój dzienny w centralnej części. Idealny projekt dla inwestorów ceniących nieszablonowe pomysły.";s:21:"alternate_description";N;s:5:"price";s:8:"19999.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:638:"{"1":{"name":"pow. u\u017cytkowa","value":252.25,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":233.4,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":25.44,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":23.19,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":5,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":25,"unit":"\u00b0"},"26":{"