ynku","value":7.48,"unit":"m"},"17":{"name":"pow. netto poddasza","value":null,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":47.6,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"222435","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-09 15:16:51";s:10:"technology";s:156:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:253:"{"garages":["37","155","322","323","511","539","544","652","829"],"thumbnail":"133\/busik-wizualizacja-200-5954d5f66e8dd.jpg","templateId":"2","price_other_type":null,"skeleton_disabled":null,"isbn":"978-83-89103-21-5","isbn_mirror":"978-83-7356-093-2"}";}i:1095;a:22:{s:2:"id";i:91;s:6:"id_old";i:91;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:79;s:4:"name";s:6:"Krokus";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:134:"Dom parterowy z poddaszem użytkowym i garażem, z lukarnami, przeszklonym ryzalitem i narożnym tarasem w podcieniu, niepodpiwniczony";s:11:"description";s:614:"Parterowy dom z poddaszem użytkowym, na którym zaprojektowano trzy przestronne sypialnie oraz łazienkę z zapleczem, które może pełnić funkcję pralni i suszarni. Na parterze zaproponowano funkcjonalny podział pomieszczeń, w którym kuchnię połączono z przestrzenią jadalni w ryzalicie z wyjściem do podcienia, a pokój dzienny z kominkiem to odrębna część z dostępem do niezadaszonej części tarasu. Kotłownia jest przechodnim pomieszczeniem pomiędzy jednostanowiskowym garażem a kuchnią, dzięki czemu może pełnić funkcję praktycznej spiżarki. Dom wygodny dla czteroosobowej rodziny.";s:21:"alternate_description";N;s:5:"price";s:7:"4899.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:635:"{"1":{"name":"pow. u\u017cytkowa","value":133.35,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":122,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":20.45,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":19.06,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":4,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":40,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":8.03,"unit":"m"},"17":{"name":"pow. netto poddasza","value":81.55,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"383213","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-10 15:35:08";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:206:"{"features":["10"],"thumbnail":"91\/krokus-wizualizacja-200-5954d6053aa64.jpg","templateId":"3","isbn":"978-83-87603-79-3","isbn_mirror":"978-83-7356-032-1","price_other_type":null,"skeleton_disabled":null}";}i:1096;a:22:{s:2:"id";i:11;s:6:"id_old";i:11;s:12:"symbol_alpha";s:3:"GLZ";s:10:"symbol_num";i:11;s:4:"name";s:10:"Kruszek II";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:109:"Mały dom parterowy z dwuspadowym dachem i poddaszem użytkowym, idealny na wąską działkę, tani w budowie";s:11:"description";s:814:"Ten mały dom jednorodzinny z poddaszem użytkowym będzie wygodnym lokum dla trzyosobowej rodziny. Wnętrze zostało zaprojektowane w niezwykle ekonomiczny sposób, na parterze znajdziemy funkcjonalny pokój dzienny połączony z hallem z komunikacją oraz wspólne pomieszczenie łączące kuchnię i jadalnię. Parter mieści również przedsionek i dodatkową łazienkę, a także zlokalizowaną przy kuchni kotłownię, która może dodatkowo pełnić funkcję spiżarni. Na poddaszu zaprojektowano dwie przytulne sypialnie, w tym jedną z dostępem do balkonu oraz łazienkę. Atutem jest jeden komin, w którym udało się zmieścić wszystkie niezbędne kanały spalinowe i wentylacyjne. Nieduże gabaryty domu pozwolą na realizację projektu na wąskiej działce, z całą pewnością niewielkim kosztem.";s:21:"alternate_description";N;s:5:"price";s:7:"3899.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:610:"{"1":{"name":"pow. u\u017cytkowa","value":"55,4","unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":"56,2","unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":"15,7","unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":"16,4","unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":"3","unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":"45","unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":"7,39","unit":"m"},"17":{"name":"pow. netto poddasza","value":"34,3","unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"159201","self":null}";s:10:"meta_title";s:75:"Kruszek II. Mały tani w budowie dom z poddaszem użytkowym - Studio Atrium";s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-10 15:36:17";s:10:"technology";s:156:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:274:"{"garages":["34","35","509","510","540","545","546","593","606"],"thumbnail":"11\/kruszek-ii-wizualizacja-200-5c93aa340837e.jpg","templateId":"3","isbn":"978-83-87603-58-8","isbn_mirror":"978-83-7356-035-2","features":["23"],"price_other_type":null,"skeleton_disabled":null}";}i:1097;a:22:{s:2:"id";i:1144;s:6:"id_old";i:1144;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:1020;s:4:"name";s:11:"Winston XII";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:105:"Dom parterowy z odkrytym, narożnym tarasem wypoczynkowym oraz 2-stanowiskowym garażem, energooszczędny";s:11:"description";s:1377:"Przed Państwem mały, bo mający niespełna 120m<sup>2</sup> powierzchni użytkowej dom o zgrabnej bryle z doklejonym, wysuniętym dwustanowiskowym garażem gwarantującym dodatkowy komfort mieszkańcom, nakryty dwuspadowym dachem o przenikających się połaciach, to znak rozpoznawczy domów z linii Winston. Uwagę w tej wersji zwraca kolorystyka – ciemne drewno w połączeniu z białą elewacją, jest bardzo stylowym rozwiązaniem. Centrum domowego życia będzie przestronny, bo mający prawie 35m2 powierzchni salon z jadalnią, z którego przewidziano wyjście na taras wypoczynkowy. To sporych rozmiarów serce domu wzbogacono o element, który w jesienno-zimowe wieczory będzie rozgrzewał i rozświetlał swym blaskiem - umiejscowiony w rogu pokoju kominek. Pozostałe zalety domu to z całą pewnością duża kuchnia umiejscowiona od frontu domu, przedsionek z wkomponowanym obok praktycznym w.c. i spora kotłownia umiejscowiona za garażem. Z całą pewnością posłuży ona domownikom za praktyczny schowek na sprzęt wszelkiego rodzaju. Część nocną składającą się z trzech dużych, ustawnych pokoi oraz łazienki z wanną i prysznicem, oddziela od strefy dziennej wąski korytarz. Widać zatem, że w rozkładzie pomieszczeń uwzględniono wszystko to, co jest niezbędne do życia czteroosobowej rodzinie i zapewni jej komfort użytkowania domu.";s:21:"alternate_description";N;s:5:"price";s:7:"4799.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:576:"{"1":{"name":"pow. u\u017cytkowa","value":"118,10","unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":"197,8","unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":"19,73","unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":"27,23","unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":"4","unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":"35","unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":"7,56","unit":"m"},"17":{"name":"pow. netto poddasza"},"18":{"name":"pow. netto pi\u0119tra"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"361644","self":null}";s:10:"meta_title";s:79:"Winston XII. Parterowy dom z dwustanowiskowym garażem i tarasem. Studio Atrium";s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-02-26 10:41:59";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:213:"{"features":["10"],"thumbnail":"1144\/winston-xii-wizualizacja-200-5954f4fa494e9.jpg","templateId":"1","isbn":"978-83-7937-074-0","isbn_mirror":"978-83-7937-075-7","price_other_type":null,"skeleton_disabled":null}";}i:1098;a:22:{s:2:"id";i:525;s:6:"id_old";i:525;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:474;s:4:"name";s:13:"Marek I Wacek";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:149:"Dom bliźniaczy, 4-lokalowy, parterowy, z poddaszem użytkowym i lukarnami, z 2-stanowiskowym garażem w segmencie - w podpiwniczeniu, dom na skarpę";s:11:"description";s:635:"Bliźniak w ramach którego zaprojektowano cztery niezależne lokale to ciekawa propozycja dla deweloperów. Bryła budynku obejmuje trzy kondygnacje, zwieńczone dwuspadowym dachem z lukarnami, które powiększają przestrzeń poddasza. W piwnicy zaprojektowano kotłownie oraz garaże. Mieszkania na parterze to trzypokojowe lokale z kuchnią, jadalnią i łazienką. Z pokoju dziennego i jednej sypialni można wyjść na taras. Nieco mniejszą powierzchnię ale identyczny program użytkowy mają mieszkania na poddaszu, które z kolei posiadają wyjścia na balkon. Budynek jest odpowiedni do realizacji na działkach ze spadkiem.";s:21:"alternate_description";N;s:5:"price";s:8:"10999.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:613:"{"1":{"name":"pow. u\u017cytkowa","value":"144,4","unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":"128,85","unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":"28,75","unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":"22,05","unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":"6","unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":"42","unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":"9,04","unit":"m"},"17":{"name":"pow. netto poddasza","value":"84","unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"579701","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-11 12:46:26";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:227:"{"features":["10","6","7","54"],"thumbnail":"525\/marek-i-wacek-wizualizacja-200-5954df03d44bc.jpg","templateId":"3","price_other_type":null,"skeleton_disabled":null,"isbn":"978-83-7356-704-7","isbn_mirror":"978-83-7356-709-2"}";}i:1099;a:22:{s:2:"id";i:447;s:6:"id_old";i:447;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:407;s:4:"name";s:13:"Doborowy Duet";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:95:"Dom bliźniaczy, parterowy z poddaszem użytkowym i garażem, z lukarną i balkonem nad tarasem";s:11:"description";s:404:"Dom jednorodzinny w bliźniaczej zabudowie z garażem zaprojektowanym z przodu budynku. Kuchnia umieszczona we frontowej części domu jest częściowo otwarta na jadalnię oraz umieszczony na tyłach pokój dzienny, jednak dzięki zabudowie poszczególne strefy są funkcjonalnie podzielone. Na poddaszu mieści się duża sypialnia rodziców z wyjściem na balkon, a także mniejszy pokój i łazienka.";s:21:"alternate_description";N;s:5:"price";s:7:"6999.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:612:"{"1":{"name":"pow. u\u017cytkowa","value":"104,35","unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":"102,7","unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":"23,25","unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":"24,95","unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":"3","unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":"40","unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":"8,3","unit":"m"},"17":{"name":"pow. netto poddasza","value":"62","unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"322646","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-10 08:53:55";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:183:"{"features":["6","7"],"thumbnail":"447\/doborowy-duet-wizualizacja-200-5954df1c04a89.jpg","templateId":"3","isbn":"978-83-7356-610-1","price_other_type":null,"skeleton_disabled":null}";}i:1100;a:22:{s:2:"id";i:379;s:6:"id_old";i:379;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:339;s:4:"name";s:7:"Zbyszko";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:122:"Parterowy dom z wejściem w stylu dworkowym, zadaszonym, narożnym tarasem wypoczynkowym oraz z garażem, energooszczędny";s:11:"description";s:392:"Szeroko otwarte okiennice i dyskretne kolumny od razu przywodzą na myśl skojarzenia z tradycyjną gościnnością szlacheckiego dworku. Uwagę przyciąga symetryczna kompozycja frontu i kopertowy dach. W pogodne dni można korzystać z częściowo zadaszonego tarasu, ukrytego z boku domu. Dodatkową powierzchnię zapewni poddasze, które można łatwo zaadaptować do celów mieszkalnych.";s:21:"alternate_description";N;s:5:"price";s:7:"4499.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:633:"{"1":{"name":"pow. u\u017cytkowa","value":80.5,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":136.9,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":24.85,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":17.2,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":3,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":35,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":6.95,"unit":"m"},"17":{"name":"pow. netto poddasza","value":null,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"243654","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-13 16:39:55";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:190:"{"thumbnail":"379\/zbyszko-wizualizacja-200-5954df2632968.jpg","templateId":"1","isbn":"978-83-7356-474-9","isbn_mirror":"978-83-7356-479-4","price_other_type":null,"skeleton_disabled":null}";}i:1101;a:22:{s:2:"id";i:372;s:6:"id_old";i:372;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:332;s:4:"name";s:8:"Jagienka";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:98:"Parterowy dom z wejściem w stylu dworkowym, tarasem umiejscowionym z boku budynku oraz z garażem";s:11:"description";s:500:"Harmonijna bryła w klasycznym stylu z jednostanowiskowym garażem. Chłodną kolorystykę dachu i elewacji równoważą drewniane elementy wykończenia domu oraz okiennice nawiązujące do tradycyjnego budownictwa. Przedsionek i hall dzielą wnętrze na strefę sypialną i część dzienną obejmującą duży pokój prowadzący na taras oraz kuchnię i jadalnię, która pomieści duży, rodzinny stół. Dzięki nieskomplikowanemu projektowi oraz niedużej powierzchni dom będzie tani w budowie.";s:21:"alternate_description";N;s:5:"price";s:7:"4599.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:632:"{"1":{"name":"pow. u\u017cytkowa","value":98.05,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":151,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":24.85,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":17.9,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":4,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":37,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":7.42,"unit":"m"},"17":{"name":"pow. netto poddasza","value":null,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"287663","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-10 13:32:44";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:209:"{"thumbnail":"372\/jagienka-wizualizacja-200-5954df308d0c3.jpg","templateId":"1","isbn":"978-83-7356-553-1","isbn_mirror":"978-83-7356-558-6","features":["22"],"price_other_type":null,"skeleton_disabled":null}";}i:1102;a:22:{s:2:"id";i:631;s:6:"id_old";i:631;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:575;s:4:"name";s:7:"Alabama";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:94:"Przestronny dom parterowy z 4 sypialniami, rozległym tarasem oraz jednostanowiskowym garażem";s:11:"description";s:409:"Taras umieszczony od frontu zachęca do wejścia, otwierając wnętrze zaaranżowane w przemyślany i komfortowy sposób. Parterowy projekt na jednym poziomie mieści aż cztery niezależne sypialnie, przestronną strefę dzienną oraz dużą łazienkę. Konstrukcja na planie prostokąta oraz zaprojektowanie garażu od strony frontowej doskonale sprawdzą się na wąskich działkach z wjazdem od południa.";s:21:"alternate_description";N;s:5:"price";s:7:"4799.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:633:"{"1":{"name":"pow. u\u017cytkowa","value":132.6,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":194.5,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":20.3,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":26.05,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":5,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":30,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":7.4,"unit":"m"},"17":{"name":"pow. netto poddasza","value":null,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"399617","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-02-27 13:53:56";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:191:"{"thumbnail":"631\/alabama-wizualizacja-200-5954df3fdb845.jpg","templateId":"1","price_other_type":null,"skeleton_disabled":null,"isbn":"978-83-7559-212-2 ","isbn_mirror":"978-83-7559-216-0"}";}i:1103;a:22:{s:2:"id";i:874;s:6:"id_old";i:874;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:822;s:4:"name";s:11:"Ricardo VII";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:89:"Parterowy dom z dwuspadowym dachem i poddaszem użytkowym, częściowo zadaszonym tarasem";s:11:"description";s:480:"Prosta, nakryta  dwuspadowym dachem bryła nabiera oryginalnego charakteru dzięki elewacji w dwóch kontrastowych kolorach. Dzięki dwóm dodatkowym pokojom na parterze w domu może wygodnie zamieszkać pięcioosobowa rodzina, a komfort użytkowania przy takiej liczbie mieszkańców zapewnią także dwie łazienki oraz garderoba. Miejscem spędzanego w rodzinnym gronie czasu wolnego będzie przestronna strefa dzienna w otwartej kompozycji, połączona z jadalnią i kuchnią.";s:21:"alternate_description";N;s:5:"price";s:7:"4699.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:634:"{"1":{"name":"pow. u\u017cytkowa","value":118.15,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":112.95,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":19.8,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":18.03,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":5,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":35,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":7.33,"unit":"m"},"17":{"name":"pow. netto poddasza","value":83,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"329993","self":null}";s:10:"meta_title";s:75:"Ricardo VII. Parterowy dom z poddaszem użytkowym i tarasem - Studio Atrium";s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-02-20 12:56:11";s:10:"technology";s:156:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:276:"{"garages":["37","155","322","323","511","512","652","701"],"thumbnail":"874\/ricardo-vii-wizualizacja-200-5954ed7d07bfd.jpg","templateId":"3","price_other_type":null,"skeleton_disabled":null,"features":["46","21"],"isbn":"978-83-7559-769-1","isbn_mirror":"978-83-7559-773-8"}";}i:1104;a:22:{s:2:"id";i:1012;s:6:"id_old";i:1012;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:961;s:4:"name";s:12:"Ronaldo VIII";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:93:"Parterowy dom z klasycznym dwuspadowym dachem, odkrytym tarasem wypoczynkowym oraz z garażem";s:11:"description";s:439:"Parterowy dom jednorodzinny nakryty dwuspadowym dachem utrzymany w nowoczesnej stylistyce. Projekt zawiera dwie sypialnie oddzielone od siebie powierzchnią łazienki. W drugiej części domu znajduje się przestronna dzięki otwartej kompozycji przestrzeń dzienna. Lekko cofnięta względem budynku bryła garażu osłania znajdujący się z tyłu domu taras, tworząc zaciszne i sprzyjające wypoczynkowi na świeżym powietrzu miejsce.";s:21:"alternate_description";N;s:5:"price";s:7:"4299.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:574:"{"1":{"name":"pow. u\u017cytkowa","value":"78,7","unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":"141,05","unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":"24,45","unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":"20,34","unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":"3","unit":""},"27":{"name":"k\u0105t nachylenia dachu","valu