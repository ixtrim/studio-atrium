e":"wysoko\u015b\u0107 budynku","value":9.16,"unit":"m"},"17":{"name":"pow. netto poddasza","value":72.5,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"356387","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-10 12:12:24";s:10:"technology";s:156:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:287:"{"garages":["34","35","509","510","540","545","546","593","606"],"features":["10","21","27"],"thumbnail":"424\/gajowa-chata-wizualizacja-200-5954ddb28198a.jpg","templateId":"3","price_other_type":null,"skeleton_disabled":null,"isbn":"978-83-7356-828-0","isbn_mirror":"978-83-7356-833-4"}";}i:935;a:22:{s:2:"id";i:116;s:6:"id_old";i:116;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:104;s:4:"name";s:8:"Kamyczek";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:134:"Dom piętrowy z dwuspadowym dachem i garażem, oryginalne szklane zadaszenie nad wejściem, w części otwarty taras, energooszczędny";s:11:"description";s:601:"Kompaktowy dom jednorodzinny, który dzięki niewielkim gabarytom może zostać wybudowany także na wąskiej działce. Na parterze tuż przy wejściu znajduje się kotłownia i w.c., a hall z komunikacją prowadzi do części dziennej z salonem, jadalnią oraz kuchnią optycznie oddzieloną zabudową blatu. Dzięki zaprojektowaniu pełnego piętra, żadne z pomieszczeń nie zostało pomniejszone o charakterystyczne dla poddaszy skosy. W części sypialnej projekt przewiduje trzy niezależne pokoje oraz łazienkę. Do projektu dobudowano także garaż z bezpośrednim wejściem do wnętrza domu.";s:21:"alternate_description";N;s:5:"price";s:7:"4399.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:635:"{"1":{"name":"pow. u\u017cytkowa","value":96.75,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":89.5,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":16.85,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":18.45,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":4,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":30,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":7.99,"unit":"m"},"17":{"name":"pow. netto poddasza","value":null,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":49.85,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"268086","self":null}";s:10:"meta_title";s:82:"Kamyczek. Energooszczędny dom piętrowy z garażem 1-stanowiskowym. Studio Atrium";s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-10 13:59:31";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:214:"{"thumbnail":"116\/kamyczek-wizualizacja-200-5954d507e2851.jpg","templateId":"2","isbn":"978-83-89103-04-8","isbn_mirror":"978-83-7356-008-6","features":["10","22"],"price_other_type":null,"skeleton_disabled":null}";}i:936;a:22:{s:2:"id";i:82;s:6:"id_old";i:82;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:70;s:4:"name";s:5:"Blues";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:70:"Dom parterowy z oryginalną wiatą i zadaszonym tarasem w formie ganku";s:11:"description";s:1631:"Mały, parterowy dom jednorodzinny z dobudowaną z boku wiatą wspartą na kolumnach, która idealnie sprawdzi się do parkowania pod nią samochodu. Mimo niewielkiej powierzchni użytkowej, wnętrze jest komfortowe, funkcjonalne i bez problemu pomieści czteroosobową rodzinę. Do domu wprowadza przedsionek z wnęką na szafy, które pomieszczą odzienie wierzchni i obuwie domowników oraz gości. Na wprost znajduje się kotłownia z kotłem gazowym, który ogrzeje dom oraz wodę użytkową. Ze względu na jego niewielkie rozmiary, pomieszczenie to sprawdzi się również jako praktyczny schowek lub mini pralnię. Idąc dalej mijamy małe w.c. by znaleźć się w sercu domu - pokoju dziennym z kominkiem i wyjściem na zadaszony taras, który świetnie sprawdzi się zarówno latem chroniąc domowników przed nadmiarem słońca, ale również w deszczowe dni, umożliwiając wypicie kawy na świeżym powietrzu. Salon połączono z otwartą, ustawną kuchnią. Do dyspozycji mieszkańców będą jeszcze trzy pokoje, w tym jeden większy z przeznaczeniem na sypialnię rodziców. Obok hallu łączącego pokoje z centralną częścią domu, architekt przewidział miejsce na małą garderobę oraz sporą łazienkę z wanną i kabiną prysznicową. Ta przemyślana wyjątkowa funkcjonalność połączona z urokliwą propozycją wykończenia elewacji budynku w postaci jasnego tynku i dominujących jasnych drewnianych okiennic, daje w rezultacie dom, który swym charakterem będzie przypominać nieco mały wiejski dworek, a zatem świetnie sprawdzi się na działkach ulokowanych raczej z dala od miejskiego zgiełku.";s:21:"alternate_description";N;s:5:"price";s:7:"4499.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:502:"{"1":{"name":"pow. u\u017cytkowa","value":"79,3","unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":"22,6","unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":"20,7","unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":"4","unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":"31","unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":"5,28","unit":"m"},"17":{"name":"pow. netto poddasza"},"18":{"name":"pow. netto pi\u0119tra"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"200550","self":null}";s:10:"meta_title";s:82:"Blues. Mały dom parterowy z wiatą garażową i zadaszonym tarasem. Studio Atrium";s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-09 15:01:12";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:240:"{"garages":["37","155","322","323","511","512","652"],"thumbnail":"82\/blues-wizualizacja-200-60d1c11b2bf3f.jpg","templateId":"1","isbn":"978-83-87603-70-0","isbn_mirror":"978-83-7356-136-6","price_other_type":null,"skeleton_disabled":null}";}i:937;a:22:{s:2:"id";i:1138;s:6:"id_old";i:1138;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:1035;s:4:"name";s:16:"Mały Michał II";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:82:"Parterowy dom z poddaszem użytkowym, z 4 sypialniami, garażem i odkrytym tarasem";s:11:"description";s:726:"Funkcjonalny dom dla pięcioosobowej rodziny. Atutem jest stonowana, ponadczasowa architektura budynku oraz przemyślany program użytkowy. Centralnym punktem parteru jest  kominek, wokół którego zaprojektowano strefę dzienną, tworzoną przez przestronny salon z wyjściem na taras, kuchnię z jadalnią oraz łazienkę. Znalazło się również miejsce na dodatkowy pokój oraz sporej wielkości przestrzeń gospodarczą, w której skład wchodzą spiżarnia, schowek i kotłownia za garażem. W programie poddasza są cztery pokoje, w tym jeden z własną garderobą i łazienka. Z trzech sypialni i łazienki zaprojektowano wyjście na balkony. Dom świetnie wpisze się zarówno w miejskie jak i podmiejskie działki.";s:21:"alternate_description";N;s:5:"price";s:7:"4899.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:635:"{"1":{"name":"pow. u\u017cytkowa","value":132.95,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":114.75,"u