tatus";s:9:"published";s:14:"params_general";s:635:"{"1":{"name":"pow. u\u017cytkowa","value":148.45,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":147.3,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":23,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":19.4,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":6,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":null,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":7.34,"unit":"m"},"17":{"name":"pow. netto poddasza","value":null,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":78.35,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"421190","self":null}";s:10:"meta_title";s:78:"Qubus II. Piętrowy nowoczesny dom z płaskim dachem i garażem. Studio Atrium";s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-12 15:26:49";s:10:"technology";s:201:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: papa termozgrzewalna, ew. membrana dachowa. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:215:"{"features":["10","22"],"thumbnail":"733\/qubus-ii-wizualizacja-200-5b2a2120156b8.jpg","templateId":"2","price_other_type":null,"skeleton_disabled":null,"isbn":"978-83-7559-335-8","isbn_mirror":"978-83-7559-339-6 "}";}i:785;a:22:{s:2:"id";i:202;s:6:"id_old";i:202;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:184;s:4:"name";s:5:"Zorba";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:85:"Niewielki, energooszczędny dom parterowy z odkrytym tarasem wypoczynkowym i garażem";s:11:"description";s:443:"Przytulny dom parterowy z garażem dla niedużej rodziny. Ten urokliwy budynek posiada nie tylko niepowtarzalny klimat, ale i praktyczne wnętrze. Część dzienna obejmuje kuchnię oraz jadalnię umieszczoną w ryzalicie połączoną z salonem, z którego można wyjść bezpośrednio na taras. Z kolei zimą o wyjątkową atmosferę zadba stojący w centrum kominek. Dzięki swojej konstrukcji projekt jest energooszczędny i tani w budowie.";s:21:"alternate_description";N;s:5:"price";s:7:"4299.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:504:"{"1":{"name":"pow. u\u017cytkowa","value":"62,3","unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":"21,65","unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":"17,22","unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":"3","unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":"30","unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":"6,08","unit":"m"},"17":{"name":"pow. netto poddasza"},"18":{"name":"pow. netto pi\u0119tra"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"191024","self":null}";s:10:"meta_title";s:79:"Zorba. Mały energooszczędny dom parterowy z tarasem i garażem. Studio Atrium";s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-02-23 15:06:32";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:211:"{"thumbnail":"202\/zorba-wizualizacja-200-5954d432b6a8c.jpg","templateId":"1","isbn":"978-83-7356-252-3","isbn_mirror":"978-83-7356-257-8","features":["22","29"],"price_other_type":null,"skeleton_disabled":null}";}i:786;a:22:{s:2:"id";i:953;s:6:"id_old";i:953;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:836;s:4:"name";s:9:"Ostoja VI";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:102:"Dom parterowy z kotłownią na paliwo stałe, odkrytym narożnym tarasem oraz 2-stanowiskowym garażem";s:11:"description";s:606:"Utrzymany w całości w naturalnych barwach ziemi dom idealnie wkomponuje się w każdą okolicę. Wyposażony został w dwustanowiskowy garaż, do którego wjazd znajduje się tuż obok wejścia do domu. Na wygodnym tarasie zmieszczą się wszyscy członkowie rodziny, a także ich goście. Nowoczesna kuchnia z wyspą oraz przestronny, pięknie doświetlony salon to niewątpliwe atuty tego domu. Trzy sypialnie oraz duża łazienka zapewnią komfort użytkowania czteroosobowej rodzinie. W programie budynku jest również w.c. z pralnią oraz kotłownia przeznaczona pod montaż pieca na paliwo stałe.";s:21:"alternate_description";N;s:5:"price";s:7:"4899.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:635:"{"1":{"name":"pow. u\u017cytkowa","value":125.25,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":214.5,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":21.05,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":27.8,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":4,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":22,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":5.48,"unit":"m"},"17":{"name":"pow. netto poddasza","value":null,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"385966","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-02-23 15:48:28";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:214:"{"features":["1","36"],"thumbnail":"953\/ostoja-vi-wizualizacja-200-5954e7cf7a446.jpg","templateId":"1","price_other_type":null,"skeleton_disabled":null,"isbn":"978-83-7559-782-0","isbn_mirror":"978-83-7559-786-8"}";}i:787;a:22:{s:2:"id";i:820;s:6:"id_old";i:820;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:765;s:4:"name";s:5:"Amber";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:56:"Niewielki parterowy dom z przestronnym, odkrytym tarasem";s:11:"description";s:392:"Projekt wpisuje się w skandynawski styl nie tylko poprzez prostą bryłę i wykończoną drewnem elewację, ale i energooszczędne rozwiązania. Parterową konstrukcję wyraźnie podzielono na otwartą strefę dzienną z kuchnią, jadalnią i pokojem dziennym oraz nocną z trzema przytulnymi sypialniami i łazienką, zawierając w niespełna 100 m2 wszystko, czego wymaga komfortowe lokum.";s:21:"alternate_description";N;s:5:"price";s:7:"4599.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:575:"{"1":{"name":"pow. u\u017cytkowa","value":"98,25","unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":"124,4","unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":"19,55","unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":"19,55","unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":"4","unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":"22","unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":"5,35","unit":"m"},"17":{"name":"pow. netto poddasza"},"18":{"name":"pow. netto pi\u0119tra"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"248474","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-02-26 11:54:39";s:10:"technology";s:164:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: blacha tytanowo-cynkowa. Drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:270:"{"garages":["37","155","322","323","511","652","701","829"],"thumbnail":"820\/amber-wizualizacja-200-5954e7d70e799.jpg","templateId":"1","features":["10","21"],"price_other_type":null,"skeleton_disabled":null,"isbn":"978-83-7559-624-3","isbn_mirror":"978-83-7559-628-1"}";}i:788;a:22:{s:2:"id";i:691;s:6:"id_old";i:691;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:634;s:4:"name";s:5:"Astra";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:118:"Dom parterowy z poddaszem użytkowym i garażem, z lukarną i balkonem nad wejściem, z częściowo zadaszonym tarasem";s:11:"description";s:316:"Tradycyjne budownictwo w nowoczesnym wydaniu. Klasyczna bryła przykryta dwuspadowym dachem zyskuje nową jakość dzięki surowym, minimalistycznym balustradom zestawionym z drewnianą stolarką okienną i wykończeniom elewacji. Poddasze użytkowe kryje trzy pokoje, w tym jeden z własną łazienką i garderobą.";s:21:"alternate_description";N;s:5:"price";s:7:"5299.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:634:"{"1":{"name":"pow. u\u017cytkowa","value":142.5,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":133.65,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":22,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":18.15,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":5,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":40,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":8.34,"unit":"m"},"17":{"name":"pow. netto poddasza","value":97.25,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"420045","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-02-27 14:50:46";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:210:"{"features":["10","9"],"thumbnail":"691\/astra-wizualizacja-200-5954e7e15d136.jpg","templateId":"3","price_other_type":null,"skeleton_disabled":null,"isbn":"978-83-7559-368-6","isbn_mirror":"978-83-7559-372-3"}";}i:789;a:22:{s:2:"id";i:385;s:6:"id_old";i:385;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:345;s:4:"name";s:5:"Gawra";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:103:"Parterowy dom z możliwością adaptacji poddasza, tarasem wypoczynkowym oraz garażem dwustanowiskowym";s:11:"description";s:528:"Parterowy budynek jednorodzinny z wysuniętym przed bryłę dwustanowiskowym garażem. Dzięki przemyślanemu projektowi jednopoziomowa przestrzeń jest funkcjonalna, a jednocześnie komfortowa. Sypialnie nie znajdują się w swoim bezpośrednim sąsiedztwie, ale zostały od siebie oddzielone łazienką i garderobą, zapewniając tym samym prywatność i spokój. Znajdująca się w drugiej części domu przestrzeń dzienna z obszernym pokojem, jadalnią i otwartą kuchnią to miejsce wspólnych spotkań w rodzinnym gronie.";s:21:"alternate_description";N;s:5:"price";s:7:"4999.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:575:"{"1":{"name":"pow. u\u017cytkowa","value":"133,85","unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":"205,95","unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":"20,2","unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":"27,7","unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":"5","unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":"35","unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":"8,43","unit":"m"},"17":{"name":"pow. netto poddasza"},"18":{"name":"pow. netto pi\u0119tra"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"432182","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-10 12:20:54";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:188:"{"thumbnail":"385\/gawra-wizualizacja-200-5954dcd681878.jpg","templateId":"1","isbn":"978-83-7356-544-9","isbn_mirror":"978-83-7356-549-4","price_other_type":null,"skeleton_disabled":null}";}i:790;a:22:{s:2:"id";i:396;s:6:"id_old";i:396;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:356;s:4:"name";s:8:"Hacjenda";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:107:"Parterowy dom z możliwością adaptacji poddasza, narożnym odkrytym tarasem oraz 2-stanowiskowym garażem";s:11:"description";s:508:"Parterowy budynek jednorodzinny z jasnym i przestronnym wnętrzem dla czteroosobowej rodziny. Przedsionek prowadzi bezpośrednio do obszernego pokoju dziennego z kominkiem optycznie oddzielonego od przestrzeni kuchni dużym, rodzinnym stołem. W dalszej części domu zaprojektowano strefę sypialną ze znajdującą się w jej centrum łazienką. Tuż za dwustanowiskowym garażem znajduje się dodatkowa toaleta oraz przechodnia kotłownia – rozwiązanie doceniane zwłaszcza w mroźne lub deszczowe dni.";s:21:"alternate_description";N;s:5:"price";s:7:"4999.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:634:"{"1":{"name":"pow. u\u017cytkowa","value":134.55,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":206.5,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":21.45,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":27.2,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":4,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":35,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":7.6,"unit":"m"},"17":{"name":"pow. netto poddasza","value":null,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"432324","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-10 12:57:51";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:209:"{"features":["10"],"thumbnail":"396\/hacjenda-wizualizacja-200-5954dce09281c.jpg","templateId":"1","isbn":"978-83-7356-876-1","isbn_mirror":"978-83-7356-881-5","price_other_type":null,"skeleton_disabled":null}";}i:791;a:22:{s:2:"id";i:122;s:6:"id_old";i:122;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:110;s:4:"name";s:5:"Remek";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:90:"Przestronny dom parterowy z niezadaszonym tarasem wypoczynkowym i 2-stanowiskowym garażem";s:11:"description";s:366:"Rozłożysty, parterowy dom z grupy budynków typu bungalow. Z boku dołączony garaż
 2-stanowiskowy. Jedyna kondygnacja oprócz pokoju dziennego z kuchnia i jadalnią zawiera trzy dodatkowe,  niemałe pokoje, łazienkę i wc oraz kotłownię. Na uwagę zasługuje taras osłonięty z dwóch stron ścianami pomieszczeń o lokalizacji w kształcie litery „L”.";s:21:"alternate_description";N;s:5:"price";s:7:"4899.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:634:"{"1":{"name":"pow. u\u017cytkowa","value":108.5,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":173.7,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":27.3,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":21.45,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":4,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":30,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":5.86,"unit":"m"},"17":{"name":"pow. netto poddasza","value":null,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"332492","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-12 15:36:19";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:188:"{"thumbnail":"122\/remek-wizualizacja-200-5954d43a6d98c.jpg","templateId":"1","isbn":"978-83-89103-10-9","isbn_mirror":"978-83-7356-038-3","price_other_type":null,"skeleton_disabled":null}";}i:792;a:22:{s:2:"id";i:314;s:6:"id_old";i:314;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:290;s:4:"name";s:9:"Ondraszek";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:91:"Dom regionalny w stylu beskidzkim, parterowy z poddaszem użytkowym, z przestronnym tarasem";s:11:"description";s:1173:"Średniej wielkości dom który zachwyci wielbicieli architektury regionalnej, w tym wypadku czerpiącej z najlepszych wzorców budownictwa beskidzkiego. Poza piękną bryłą, atutem budynku jest również przemyślany program użytkowy gwarantujący komfort użytkowania. Wygodny przedsionek to w tym wypadku również piękny element architektoniczny zaakcentowany kamiennymi przyporami. Obszerny hol mieści szafy wnękowe oraz drzwi do kotłowni której wielkość pozwala na swobodny dobór technologii ogrzewania. Strefa typowo dzienna to duża kuchnia, jadalnia z widokiem na schody na poddasze oraz salon z kominkiem i wyjściem na częściowo zadaszony taras. Poza tym w programie parteru mamy łazienkę z kabiną prysznicową oraz gabinet do pracy lub pokój gościnny. Poddasze mieści 3 sporej wielkości pokoje z szafami wnękowymi oraz łazienkę. Z jednej z sypialni dostępny jest balkon zadaszony przez nachodzącą na niego płaszczyznę dachu. Zastosowanie drewnianych  okiennic, kamiennych przypór czy przyczółków dachowych daje efekt w postaci niepowtarzalnego w klimacie, magicznego domu, idealnego dla 4-osobowej rodziny żyjącej w stylu slow.";s:21:"alternate_description";N;s:5:"price";s:7:"4899.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:616:"{"1":{"name":"pow. u\u017cytkowa","value":"135,65","unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":"130,15","unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":"18,9","unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":"23,85","unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":"5","unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":"45","unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":"7,85","unit":"m"},"17":{"name":"pow. netto poddasza","value":"77,25","unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"357709","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-11 15:57:32";s:10:"technology";s:156:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:279:"{"garages":["34","35","509","510","540","545","546","593","606"],"thumbnail":"314\/ondraszek-wizualizacja-200-5954d4445ea60.jpg","templateId":"3","isbn":"978-83-7356-510-4","isbn_mirror":"978-83-7356-515-9","features":["46","47"],"price_other_type":null,"skeleton_disabled":null}";}i:793;a:22:{s:2:"id";i:1026;s:6:"id_old";i:1026;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:966;s:4:"name";s:6:"Reflex";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:101:"Mały dom parterowy w klasycznej bryle z rozległym, odkrytym tarasem wypoczynkowym, energooszczędny";s:11:"description";s:470:"Projekt zainspirowany oszczędnym i stonowanym stylem skandynawskim. Chłodną kolorystykę elewacji ogrzewają wykończone czerwoną cegłą fragmenty. Panoramiczne okna naturalnie otwierają wnętrze na otaczającą dom przestrzeń, tworząc w strefie dziennej sprzyjającą wypoczynkowi atmosferę. Część nocną z dwoma sypialniami i łazienką oddzielono niewielkim hallem od pozostałych pomieszczeń, gwarantując domownikom spokojny, niczym niezakłócony sen.";s:21:"alternate_description";N;s:5:"price";s:7:"4299.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:575:"{"1":{"name":"pow. u\u017cytkowa","value":"80,8","unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":"113,05","unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":"20,38","unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":"17,92","unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":"3","unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":"25","unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":"5,72","unit":"m"},"17":{"name":"pow. netto poddasza"},"18":{"name":"pow. netto pi\u0119tra"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"204343","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-12 15:34:18";s:10:"technology";s:156:"Technologia murowana: pustak ceramiczny gr. 25 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:255:"{"garages":["37","155","322","323","511","652","701","829"],"thumbnail":"1026\/reflex-wizualizacja-200-5c8b90721991a.jpg","templateId":"1","isbn":"978-83-7937-060-3   ","isbn_mirror":"978-83-7937-061-0   ","price_other_type":null,"skeleton_disabled":null}";}i:794;a:22:{s:2:"id";i:693;s:6:"id_old";i:693;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:619;s:4:"name";s:6:"Karmel";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:94:"Dom parterowy z poddaszem użytkowym i garażem, przestronnym tarasem i przeszklonym ryzalitem";s:11:"description";s:1669:"Tradycyjna bryła z dwuspadowym dachem dzięki chłodnej kolorystyce i elementom z kamienia ozdobnego zyskuje elegancki i stylowy wygląd. Przeszklenia ryzalitu i tarasu oraz duże okna nie tylko zapewniają odpowiednie nasłonecznienie pomieszczeń, ale także optycznie je powiększają. Podobną funkcję pełni otwarta przestrzeń wydzielona nad pokojem dziennym, dodatkowo urozmaicająca kompozycję wnętrza. Poddasze mieści trzy sypialnie, w tym jedną z wyjściem na balkon oraz łazienkę doświetloną oknem połaciowym. Jako, że jest to właśnie projekt domu z poddaszem użytkowym, dostrzegalny jest wyraźny podział na strefę dzienną i nocną. Ta pierwsza zwraca uwagę przede wszystkim otwartą przestrzenią nad przestronnym salonem wzbogaconym wyjściem na sporych rozmiarów taras oraz kominkiem, który nada niepowtarzalny przytulny charakter temu pomieszczeniu. Dodatkowy pokój na parterze mogący pełnić rolę gabinetu lub pokoju gościnnego, spora spiżarka na kuchenne przetwory lub zimowe zapasy,  pomieszczenie gospodarcze usytuowane w przejściu z jednostanowiskowego garażu do strefy dziennej, czy wreszcie umiejscowiona za garażem dużych rozmiarów kotłownia, która może stać się także pralnią, zadowolą zwolenników praktycznych rozwiązań. Duża w pełni funkcjonalna łazienka i otwarta kuchnia z jadalnią umiejscowioną w przeszklonym ryzalicie dopełniają listę niezbędnych pomieszczeń na parterze domu. Poddasze to strefa nocna z trzema sporymi pokojami (jeden z balkonem umiejscowionym nad ryzalitem) i łazienką, które zagwarantują domownikom nawet pięcioosobowej rodziny na chwilę odpoczynku i relaksu.";s:21:"alternate_description";N;s:5:"price";s:7:"4999.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:634:"{"1":{"name":"pow. u\u017cytkowa","value":138.2,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":145.2,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":22.2,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":19.6,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":5,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":40,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":8.57,"unit":"m"},"17":{"name":"pow. netto poddasza","value":87.55,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"397931","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-10 14:08:19";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:207:"{"features":["10"],"thumbnail":"693\/karmel-wizualizacja-200-5954e7f1005d2.jpg","templateId":"3","price_other_type":null,"skeleton_disabled":null,"isbn":"978-83-7559-251-1","isbn_mirror":"978-83-7559-255-9"}";}i:795;a:22:{s:2:"id";i:1154;s:6:"id_old";i:1154;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:1132;s:4:"name";s:8:"Ultra 3G";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:103:"Nowoczesny dom parterowy z płaskim dachem, przestronnym odkrytym tarasem oraz 3-stanowiskowym garażem";s:11:"description";s:670:"Na wskroś nowoczesny, oryginalny projekt o przejrzystej funkcji i luksusowym wnętrzu. W centrum bryły zaplanowano obszerny salon, który stanowi łącznik pomiędzy użytkową częścią dzienną a strefą sypialną. Od frontu budynku zaprojektowano trzystanowiskowy garaż, skomunikowany z kuchnią poprzez kotłownię i spiżarnię. Znajdujący się blisko wejścia niewielki pokój będzie idealnym miejscem na gabinet. W tylnej części domu znajdziemy trzy pokoje z wyjściem na taras oraz dwie łazienki.  Niewątpliwie jest to propozycja dla nowoczesnych Inwestorów, którzy nie boją się odważnych rozwiązań architektonicznych, optymalna dla rodziny 2+2.";s:21:"alternate_description";N;s:5:"price";s:7:"7799.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:637:"{"1":{"name":"pow. u\u017cytkowa","value":164.5,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":296.05,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":19.4,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":32.85,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":5,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":null,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":4.02,"unit":"m"},"17":{"name":"pow. netto poddasza","value":null,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"546114","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-13 15:12:07";s:10:"technology";s:201:"Technologia murowana: pustak ceramiczny gr. 25 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: papa termozgrzewalna, ew. membrana dachowa. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:192:"{"thumbnail":"1154\/ultra-3g-wizualizacja-200-5954fc7907b43.jpg","templateId":"1","price_other_type":null,"skeleton_disabled":null,"isbn":"978-83-7937-322-2","isbn_mirror":"978-83-7937-323-9"}";}i:796;a:22:{s:2:"id";i:1080;s:6:"id_old";i:1080;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:1082;s:4:"name";s:6:"Nevada";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:97:"Przestronny parterowy dom z 4 sypialniami, odkrytym tarasem wypoczynkowym, z wjazdem od południa";s:11:"description";s:663:"Klasyczny dom parterowy z dwuspadowym dachem nabiera całkowicie nowego charakteru dzięki ozdobnym fragmentom elewacji wykonanym z drewna i kamienia, a całość – uzupełniona nowoczesną stolarką okienną z dużymi przeszkleniami – prezentuje się bardzo subtelnie i elegancko. Funkcjonalne wnętrze tradycyjnie podzielono na część dzienną z kuchnią, jadalnią i salonem oraz strefę nocną, w której znajdziemy cztery przytulne sypialnie. Główna sypialnia została wyposażona we własną łazienkę oraz wnęki pod zabudowę, w których staną praktyczne szafy. Nevada stanowi ciekawą propozycję na działki z wjazdem od południa lub zachodu.";s:21:"alternate_description";N;s:5:"price";s:7:"4799.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:636:"{"1":{"name":"pow. u\u017cytkowa","value":125.55,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":161.5,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u01