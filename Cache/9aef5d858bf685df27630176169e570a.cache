ilo\u015b\u0107 pokoi","value":6,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":42,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":8.7,"unit":"m"},"17":{"name":"pow. netto poddasza","value":123.65,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"674909","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-02-27 13:13:12";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:217:"{"features":["1","36"],"thumbnail":"1021\/agawa-iv-sp-wizualizacja-200-5954f39cd64ed.jpg","templateId":"3","isbn":"978-83-7937-102-0","isbn_mirror":"978-83-7937-103-7","price_other_type":null,"skeleton_disabled":null}";}i:955;a:22:{s:2:"id";i:748;s:6:"id_old";i:748;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:671;s:4:"name";s:5:"Widok";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:67:"Dom regionalny w stylu beskidzkim, parterowy z poddaszem użytkowym";s:11:"description";s:697:"Widok gwarantuje niezrównane... widoki – pod warunkiem, że dom zostanie wybudowany w malowniczej, górskiej okolicy. Ale jeśli nawet tak się nie stanie, sam dom będzie przywoływał górskie krajobrazy, ponieważ stanowi czytelne nawiązanie do górskiej zabudowy z rejonów Beskidu. Uwagę zwracają charakterystyczne belki wspierające dach i kamienne zdobienia w dole elewacji. Drewniane elementy – wspomniane już belki oraz stolarka okienno-drzwiowa i okiennice – nadają domowi niepowtarzalnego uroku. Do środka wchodzimy przez przeszkloną mini-werandę. Na parterze zaprojektowano typową część dzienną, poddasze natomiast to strefa nocna z trzema sypialniami i łazienką.";s:21:"alternate_description";N;s:5:"price";s:7:"4799.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:635:"{"1":{"name":"pow. u\u017cytkowa","value":130.9,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":111.15,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":19.8,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":19.7,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":5,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":40,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":7.55,"unit":"m"},"17":{"name":"pow. netto poddasza","value":73.95,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"345183","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-13 16:20:54";s:10:"technology";s:156:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:190:"{"thumbnail":"748\/widok-wizualizacja-200-5954eadfce10c.jpg","templateId":"3","isbn":"978-83-7559-367-9 ","isbn_mirror":"978-83-7559-375-4 ","price_other_type":null,"skeleton_disabled":null}";}i:956;a:22:{s:2:"id";i:706;s:6:"id_old";i:706;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:657;s:4:"name";s:7:"Cynamon";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:146:"Nowoczesny piętrowy dom z płaskim dachem i 4 sypialniami, przeszklony ryzalit z tyłu budynku, przestronny taras narożny, 2-stanowiskowy garaż";s:11:"description";s:448:"Prosta, przykryta płaskim dachem bryła kryje wiele pomysłowych rozwiązań. Duży taras na dachu dwustanowiskowego garażu oraz przeszklona część elewacji  oświetlająca jadalnię to tylko niektóre z nich. Wnętrze domu podzielono na przestrzeń dzienną na parterze oraz część nocną z czterema sypialniami na piętrze. Nowoczesny wygląd zewnętrzny z drewnianymi i kamiennymi  wykończeniami doskonale wpisze się w miejski krajobraz.";s:21:"alternate_description";N;s:5:"price";s:7:"5599.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:582:"{"1":{"name":"pow. u\u017cytkowa","value":"153,5","unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":"154,65","unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":"24,2","unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":"18,4","unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":"6","unit":""},"27":{"name":"k\u0105t nachylenia dachu"},"26":{"name":"wysoko\u015b\u0107 budynku","value":"7,37","unit":"m"},"17":{"name":"pow. netto poddasza"},"18":{"name":"pow. netto pi\u0119tra","value":"87","unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"479670","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-09 15:32:12";s:10:"technology";s:201:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: papa termozgrzewalna, ew. membrana dachowa. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:209:"{"features":["10"],"thumbnail":"706\/cynamon-wizualizacja-200-5954eae50cfc7.jpg","templateId":"2","price_other_type":null,"skeleton_disabled":null,"isbn":"978-83-7559-354-9 ","isbn_mirror":"978-83-7559-358-7"}";}i:957;a:22:{s:2:"id";i:723;s:6:"id_old";i:723;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:650;s:4:"name";s:5:"Swing";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:104:"Parterowy dom z poddaszem użytkowym i garażem 2-stanowiskowym, z 4 sypialniami i niezadaszonym tarasem";s:11:"description";s:367:"Oryginalny projekt dla hołdujących nowoczesnym a zarazem praktycznym rozwiązaniom. Narożne okna oraz duże przeszklenia na parterze tworzą przyjazną, nasłonecznioną przestrzeń, w której cała rodzina z przyjemnością spędzi wspólnie czas. Zwolennikom spożywania posiłków na świeżym powietrzu przypadnie do gustu usytuowanie tarasu w pobliżu kuchni.";s:21:"alternate_description";N;s:5:"price";s:7:"5399.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:616:"{"1":{"name":"pow. u\u017cytkowa","value":"149,85","unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":"152,5","unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":"24,5","unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":"19,55","unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":"6","unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":"40","unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":"8,32","unit":"m"},"17":{"name":"pow. netto poddasza","value":"104,95","unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"473862","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-13 14:15:09";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:190:"{"thumbnail":"723\/swing-wizualizacja-200-5954eaea2a1e9.jpg","templateId":"3","isbn":"978-83-7559-397-6 ","isbn_mirror":"978-83-7559-302-0 ","price_other_type":null,"skeleton_disabled":null}";}i:958;a:22:{s:2:"id";i:704;s:6:"id_old";i:704;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:648;s:4:"name";s:4:"Beta";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:156:"Piętrowy dom z płaskim dachem w modernistycznej odsłonie, oryginalny ryzalit z boku budynku i wykusz nad wejściem, narożny taras, 2-stanowiskowy garaż";s:11:"description";s:434:"Prostota i funkcjonalność. W tym nowoczesnym projekcie przykrytym płaskim dachem znajduje się wszystko, czego potrzebuje czteroosobowa rodzina. Piętro domu zajmuje część sypialna z trzema pokojami i łazienką, parter stanowi część dzienną zawierającą kuchnię, jadalnię oraz duży pokój z kominkiem i drzwiami prowadzącymi wprost na częściowo zadaszony taras. W bryłę budynku wkomponowano dwustanowiskowy garaż.";s:21:"alternate_description";N;s:5:"price";s:7:"5499.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:637:"{"1":{"name":"pow. u\u017cytkowa","value":134.35,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":144.8,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":23.6,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":18.55,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":4,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":null,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":7.19,"unit":"m"},"17":{"name":"pow. netto poddasza","value":null,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":73.6,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"426100","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-09 14:22:06";s:10:"technology";s:201:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: papa termozgrzewalna, ew. membrana dachowa. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:189:"{"thumbnail":"704\/beta-wizualizacja-200-5954eaf1ad4b3.jpg","templateId":"2","price_other_type":null,"skeleton_disabled":null,"isbn":"978-83-7559-381-5 ","isbn_mirror":"978-83-7559-385-3 "}";}i:959;a:22:{s:2:"id";i:725;s:6:"id_old";i:725;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:626;s:4:"name";s:7:"Ramabox";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:111:"Nowoczesny dom piętrowy z płaskim dachem, oryginalny ryzalit z balkonem nad wejściem i tarasem wypoczynkowym";s:11:"description";s:493:"Nowoczesny i komfortowy projekt piętrowego domu jednorodzinnego na wąską działkę. Urozmaiceniem geometrycznej bryły z płaskim dachem są szerokie balkony osłonięte solidnymi filarami. Otwarta zabudowa oraz panoramiczne okna tworzą z przestrzeni dziennej radosne i przyjazne miejsce, w którym domownicy będą wypoczywać z prawdziwą przyjemnością. Pracę i naukę w komfortowych warunkach gwarantuje gabinet na parterze, pokój można także zaaranżować na czwartą sypialnię.";s:21:"alternate_description";N;s:5:"price";s:7:"6599.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:638:"{"1":{"name":"pow. u\u017cytkowa","value":189.15,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":123.5,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":17.5,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":23.8,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":5,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":null,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":7.24,"unit":"m"},"17":{"name":"pow. netto poddasza","value":null,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":119.45,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"488764","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2022-05-26 15:33:46";s:10:"technology";s:183:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: papa termozgrzewalna, ew. membrana dachowa. Drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:226:"{"garages":["539"],"thumbnail":"725\/ramabox-wizualizacja-200-5954eaf942b9a.jpg","templateId":"2","price_other_type":null,"skeleton_disabled":null,"isbn":"978-83-7559-304-4","isbn_mirror":"978-83-7559-308-2","features":["21"]}";}i:960;a:22:{s:2:"id";i:339;s:6:"id_old";i:339;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:310;s:4:"name";s:7:"Pelikan";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:81:"Dom parterowy z poddaszem użytkowym, z garażem i częściowo zadaszonym tarasem";s:11:"description";s:578:"Ciepły, łososiowy odcień elewacji świetnie współgra z grafitowym dachem o kopertowym kształcie. Dach jest zwieńczeniem prostej a jednocześnie niezwykle funkcjonalnej bryły budynku. Parter poza strefą typowo dzienną, obejmującą kuchnię i salon, mieści również część sypialną, w której umieszczono dwa pokoje. Na przytulny, zadaszony taras możemy wyjść zarówno z salonu jak i z sypialni rodziców. Niewielkie poddasze mieści pokój z łazienką, idealną przestrzeń dla dorastającego nastolatka. Dom będzie wygodnym lokum dla czteroosobowej rodziny.";s:21:"alternate_description";N;s:5:"price";s:7:"4699.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:613:"{"1":{"name":"pow. u\u017cytkowa","value":"105,5","unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":"148,2","unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":"19,05","unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":"22,8","unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":"4","unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":"30","unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":"7,07","unit":"m"},"17":{"name":"pow. netto poddasza","value":"56,6","unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"328660","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-03 09:57:34";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:208:"{"thumbnail":"339\/pelikan-wizualizacja-200-69cba4b03251d.jpg","templateId":"3","isbn":"978-83-7356-472-5","isbn_mirror":"978-83-7356-477-0","features":["27"],"price_other_type":null,"skeleton_disabled":null}";}i:961;a:22:{s:2:"id";i:1056;s:6:"id_old";i:1056;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:1029;s:4:"name";s:8:"Orbis II";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:94:"Okrągły dom piętrowy z 4 sypialniami i przestronnym tarasem wypoczynkowym, energooszczędny";s:11:"description";s:998:"Coś dla fanek i fanów nietypowych rozwiązań! Charakterystyczny, okrągły dom, a właściwie bryła geometrycznie przypominająca stożek, na pewno będzie się odznaczała wśród innych, bardziej tradycyjnych budynków. Z ulokowanego na parterze w centralnym miejscu hallu można dostać się do wszystkich pomieszczeń a centralnym punktem jest kominek, tworzący przyjemną atmosferę w długie zimowe wieczory. Z otwartej części dziennej, na którą składają się kuchnia, jadalnia i salon zaprojektowano dwa wyjścia na taras, na którym przy sprzyjającej pogodzie, domownicy i ich goście mogą przyjemnie spędzać czas. Na piętro prowadzą wygodne dwubiegowe schody ze spocznikiem, pod którymi wygospodarowano wnękę na pralkę w łazience. Druga kondygnacja obejmuje cztery sypialnie, w tym jedną z własną łazienką i garderobą, oraz ogólnodostępną łazienkę. Orbis II będzie wygodnym lokum dla pięcioosobowej rodziny, ceniącej odważne koncepcje architektoniczne.";s:21:"alternate_description";N;s:5:"price";s:8:"11299.00";s:8:"discount";s:6:"555.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:614:"{"1":{"name":"pow. u\u017cytkowa","value":"158,1","unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":"117,65","unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":"19,8","unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":"19,8","unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":"6","unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":"30","unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":"9,65","unit":"m"},"17":{"name":"pow. netto poddasza"},"18":{"name":"pow. netto pi\u0119tra","value":"80,85","unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"421972","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-11 16:01:06";s:10:"technology";s:156:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:227:"{"garages":["1075"],"thumbnail":"1056\/orbis-ii-wizualizacja-200-5954f3ab181df.jpg","templateId":"2","isbn":"978-83-7937-110-5","isbn_mirror":"978-83-7937-111-2","cost":"656000","price_other_type":null,"skeleton_disabled":null}";}i:962;a:22:{s:2:"id";i:924;s:6:"id_old";i:924;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:841;s:4:"name";s:7:"Amber V";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:121:"Niewielki dom parterowy z dwuspadowym dachem, odkrytym, narożnym tarasem i oryginalnym wejściem z kamiennymi przyporami";s:11:"description";s:546:"Solidne filary podtrzymujące zadaszenie nad wejściem doskonale komponują się z wyłożonym kamiennymi płytami tarasem, którego stopnie prowadzą wprost do ogrodu. Chłodną kolorystykę elewacji równoważą drewniane elementy wykończenia. Przemyślany podział wnętrza na strefę dzienną i nocną zapewnia komfort mieszkania dla czteroosobowej rodziny. Atutem budynku jest duża kotłownia dająca swobodę w wyborze sposobu ogrzewania oraz stanowiące dodatkową przestrzeń do przechowywania sprzętów tak potrzebnych w każdym domu.";s:21:"alternate_description";N;s:5:"price";s:7:"4599.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:635:"{"1":{"name":"pow. u\u017cytkowa","value":98.25,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":131.05,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":19.55,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":20.8,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":4,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":35,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":6.91,"unit":"m"},"17":{"name":"pow. netto poddasza","value":null,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"248474","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-02-26 11:57:28";s:10:"technology";s:156:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:272:"{"garages":["37","155","322","323","511","512","652","701"],"features":["10","47"],"thumbnail":"924\/amber-v-wizualizacja-200-5954eb00dd817.jpg","templateId":"1","isbn":"978-83-7559-723-3","isbn_mirror":"978-83-7559-727-1","price_other_type":null,"skeleton_disabled":null}";}i:963;a:22:{s:2:"id";i:849;s:6:"id_old";i:849;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:788;s:4:"name";s:17:"Mały Dworek Plus";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:109:"Niewielki dom parterowy z wejściem w stylu dworkowym, tarasem ulokowanym na zapleczu budynku oraz z garażem";s:11:"description";s:1098:"Urokliwy dom  z kolumnami przy wejściu, nawiązującymi do architektury dworkowej. Wnętrze cechuje przemyślany i klarowny układ funkcjonalny, gwarantujący komfort użytkowania trzyosobowej rodzinie. Blisko wejścia mieści się kotłownia, która pełni równocześnie funkcję pralni. W przestronnym holu zmieszczą się funkcjonalne szafy wnękowe, dzięki czemu utrzymanie porządku stanie się łatwiejsze. Kuchnia, jadalnia i salon stanowią jedno duże pomieszczenie, z którego zaprojektowano wyjście na boczny taras. Taka lokalizacja tarasu oraz układ stolarki okiennej i drzwiowej w części dziennej czynią ten projekt ciekawą propozycją na działkę z wjazdem od południa lub zachodu. Vis a vis tej strefy mieszczą się dwa pokoje. W programie znalazła się również jasna łazienka, zaprojektowana w ryzalicie. Do budynku doprojektowano jednostanowiskowy garaż, który podobnie jak bryłę główną przykryto dwuspadowym dachem. Mały Dworek Plus to dom o tradycyjnej architekturze, który będzie idealnym miejscem do życia dla osób ceniących tradycyjne budownictwo.";s:21:"alternate_description";N;s:5:"price";s:7:"4299.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:634:"{"1":{"name":"pow. u\u017cytkowa","value":73.8,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":125.9,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":24.25,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":18.65,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":3,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":30,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":5.88,"unit":"m"},"17":{"name":"pow. netto poddasza","value":null,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"219984","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-11 12:55:34";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:199:"{"thumbnail":"849\/maly-dworek-plus-wizualizacja-200-5954eb08a6ea1.jpg","templateId":"1","isbn":"978-83-7559-629-8","isbn_mirror":"978-83-7559-633-5","price_other_type":null,"skeleton_disabled":null}";}i:964;a:22:{s:2:"id";i:866;s:6:"id_old";i:866;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:749;s:4:"name";s:13:"Hacjenda Plus";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:108:"Średniej wielkości dom parterowy z narożnym, odkrytym tarasem wypoczynkowym oraz garażem 2-stanowiskowym";s:11:"description";s:497:"Elegancki projekt z elewacją w stonowanej kolorystyce kryje ciepłe i przytulne wnętrze. Na uwagę zasługuje przestronna kuchnia doświetlona rzędem okien, która sprawi, że przygotowywanie codziennych posiłków będzie prawdziwą przyjemnością. Sporą przestrzeń zajmuje strefa wypoczynku łącząca obszerny pokój dzienny oraz taras w części ogrodowej, na którym można miło spędzić czas w ciepłe dni. Dobre parametry energetyczne budynku zapewniają niskie koszty eksploatacji.";s:21:"alternate_description";N;s:5:"price";s:7:"4999.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:635:"{"1":{"name":"pow. u\u017cytkowa","value":140.45,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":212.75,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":21.45,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":27.2,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":4,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":35,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":7.6,"unit":"m"},"17":{"name":"pow. netto poddasza","value":null,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"448485","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-10 12:58:53";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:214:"{"features":["10"],"thumbnail":"866\/hacjenda-plus-wizualizacja-200-5954eb1063c2a.jpg","templateId":"1","price_other_type":null,"skeleton_disabled":null,"isbn":"978-83-7559-598-7","isbn_mirror":"978-83-7559-503-1"}";}i:965;a:22:{s:2:"id";i:793;s:6:"id_old";i:793;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:733;s:4:"name";s:9:"Milano II";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:129:"Dom piętrowy z kopertowym dachem w stylu włoskim, przeszklenia w części tarasowej, fragmentaryczna drewniana elewacja, garaż";s:11:"description";s:843:"Milano II to dom o prostej bryle i konstrukcji, nawiązujący do architektury włoskich willi, który idealnie wkomponuje się w miejskie działki. Na niewielkiej powierzchni użytkowej  zaprojektowano wygodną przestrzeń do życia dla czteroosobowej rodziny. Parter mieści salon z kominkiem i aneksem jadalnym a w kuchni przewidziano modną wyspę. Dodatkowy pokój to idealne miejsce na gabinet lub pokój dla gościa. Na piętrze do dyspozycji mieszkańców są sypialnia rodziców z garderobą, dwa pokoje dla dzieci i łazienka. Prosta bryła zyskuje nietuzinkowy charakter poprzez zastosowanie odpowiednich detali wykończeniowych, takich jak deskowanie oraz wielkość i rodzaj stolarki okiennej. Do bryły domu doprojektowano garaż z płaskim dachem i drewnianą ażurową ścianą, co podkreśla nowoczesny charakter tego projektu.";s:21:"alternate_description";N;s:5:"price";s:7:"5099.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:614:"{"1":{"name":"pow. u\u017cytkowa","value":"117,15","unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":"119,8","unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":"20,1","unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":"22,7","unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":"5","unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":"22","unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":"8,54","unit":"m"},"17":{"name":"pow. netto poddasza"},"18":{"name":"pow. netto pi\u0119tra","value":"56,20","unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"325903","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-11 14:24:52";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:210:"{"thumbnail":"793\/milano-ii-wizualizacja-200-5954eb181460c.jpg","templateId":"2","features":["22"],"price_other_type":null,"skeleton_disabled":null,"isbn":"978-83-7559-569-7","isbn_mirror":"978-83-7559-573-4"}";}i:966;a:22:{s:2:"id";i:802;s:6:"id_old";i:802;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:698;s:4:"name";s:8:"Domus IV";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:97:"Piętrowy dom z płaskim dachem w minimalistycznej formie, przestronny odkryty taras wypoczynkowy";s:11:"description";s:464:"Doskonała propozycja dla właścicieli wąskiej działki poszukujących projektu komfortowego domu z dwustanowiskowym garażem. Parter to strefa dzienna z jadalnią w centralnej części oraz niedużym gabinetem z tyłu domu, na poddaszu natomiast zaprojektowano trzy sypialnie i łazienkę. Poza garażem podpiwniczenie kryje dużą kotłownię oraz pomieszczenie gospodarcze. Minimalistyczna forma i biała elewacja nadają projektowi ultranowoczesny charakter.";s:21:"alternate_description";N;s:5:"price";s:7:"5899.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:637:"{"1":{"name":"pow. u\u017cytkowa","value":134.4,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":103.6,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":16.8,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":26.05,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":5,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":null,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":7.34,"unit":"m"},"17":{"name":"pow. netto poddasza","value":null,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":64.65,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"480151","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-10 09:15:39";s:10:"technology";s:201:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: papa termozgrzewalna, ew. membrana dachowa. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:211:"{"features":["10"],"thumbnail":"802\/domus-iv-wizualizacja-200-5954eb275f742.jpg","templateId":"2","price_other_type":null,"skeleton_disabled":null,"isbn":"978-83-7559-485-0 ","isbn_mirror":"978-83-7559-489-8 "}";}i:967;a:22:{s:2:"id";i:709;s:6:"id_old";i:709;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:652;s:4:"name";s:6:"Stella";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:102:"Parterowy dom z poddaszem użytkowym i garażem, z 4 sypialniami i przestronnym, niezadaszonym tarasem";s:11:"description";s:414:"Projekt złożony z dwóch przenikających się brył nakrytych dwuspadowym dachem. Rozległy taras w części ogrodowej to doskonałe miejsce na chwilę samotności i poranny kubek kawy przed intensywnym dniem lub na wspólne grillowanie w rodzinnym gronie. Wnętrze to obszerna przestrzeń dzienna w otwartej kompozycji usytuowana na parterze oraz część nocna z czterema komfortowymi  sypialniami na poddaszu.";s:21:"alternate_description";N;s:5:"price";s:7:"5499.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:635:"{"1":{"name":"pow. u\u017cytkowa","value":161.05,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":131.9,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":21.25,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":19,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":5,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":40,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":8.61,"unit":"m"},"17":{"name":"pow. netto poddasza","value":104.25,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"466532","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-13 14:00:10";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:190:"{"thumbnail":"709\/stella-wizualizacja-200-5954eb2ef3aab.jpg","templateId":"3","isbn":"978-83-7559-314-3","isbn_mirror":"978-83-7559-318-1 ","price_other_type":null,"skeleton_disabled":null}";}i:968;a:22:{s:2:"id";i:744;s:6:"id_old";i:744;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:649;s:4:"name";s:8:"Bacówka";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:67:"Regionalny dom w stylu beskidzkim, parterowy z poddaszem użytkowym";s:11:"description";s:366:"Ten urokliwy dom jednorodzinny zawiera strefę sypialną na poddaszu oraz część dzienną zaprojektowaną na parterze. Powierzchnię użytkową domu powiększa przeszklona weranda, w której umieszczono jadalnię dostępną od strony kuchni oraz przedsionka. Półszczytowy dach z lukarnami i przyczółkami stanowi doskonały przykład architektury regionalnej. .";s:21:"alternate_description";N;s:5:"price";s:7:"4899.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:613:"{"1":{"name":"pow. u\u017cytkowa","value":"122,4","unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":"106,3","unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":"19,8","unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":"18,2","unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":"5","unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":"40","unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":"7,55","unit":"m"},"17":{"name":"pow. netto poddasza","value":"66,45","unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"341863","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-09 13:49:13";s:10:"technology";s:156:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:209:"{"features":["10"],"thumbnail":"744\/bacowka-wizualizacja-200-5954eb3685c94.jpg","templateId":"3","isbn":"978-83-7559-389-1","isbn_mirror":"978-83-7559-393-8 ","price_other_type":null,"skeleton_disabled":null}";}i:969;a:22:{s:2:"id";i:222;s:6:"id_old";i:222;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:203;s:4:"name";s:8:"Komandor";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:113:"Rozległy dom parterowy z poddaszem użytkowym, 4 sypialnie i 2-stanowiskowy garaż, przestronny, zadaszony taras";s:11:"description";s:850:"Okazały dom o urozmaiconej bryle i wyważonych proporcjach to komfortowe lokum dla dużej rodziny. Wnętrze domu liczy prawie 300 m2 powierzchni. Otwarta przestrzeń parteru robi ogromne wrażenie. Z dużego przedsionka z garderoba wchodzimy do reprezentacyjnego holu a następnie do pokoju dziennego, w którym zaprojektowano kominek. Stąd już tylko krok dzieli nas od zadaszonego tarasu, z którego można rozkoszować się pięknem ogrodu. Ponadto w programie parteru otwarte kuchnia z jadalnią oraz dwa pokoje, łazienka i kotłownia. Program poddasza obejmuje cztery sypialnie, dwie łazienki, garderobę oraz strych do adaptacji według własnych potrzeb właścicieli. Bryłę budynku uzupełnia dwustanowiskowy garaż. Komandor to najlepszy wybór dla osób poszukujących przestrzeni do życia, mieszkania i realizowania własnych pasji.";s:21:"alternate_description";N;s:5:"price";s:8:"12999.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:636:"{"1":{"name":"pow. u\u017cytkowa","value":292.25,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":296.05,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":29.45,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":29.95,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":7,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":45,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":10,"unit":"m"},"17":{"name":"pow. netto poddasza","value":220.2,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"802260","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-02 07:45:12";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:191:"{"thumbnail":"222\/komandor-wizualizacja-200-5954d50f60ad4.jpg","templateId":"3","isbn":"978-83-7356-239-4","isbn_mirror":"978-83-7356-244-8","price_other_type":null,"skeleton_disabled":null}";}i:970;a:22:{s:2:"id";i:129;s:6:"id_old";i:129;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:118;s:4:"name";s:4:"Arka";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:92:"Dom parterowy z kopertowym dachem, wejściem z kolumnami, z oryginalną pergolą i  garażem";s:11:"description";s:430:"Parterowy dom jednorodzinny z uroczym gankiem od frontu, który zaprasza do wejścia. Otwarta i jasna strefa dzienna z centralnie umieszczonym kominkiem stanowi serce domu i miejsce wspólnych spotkań, a wyraźnie oddzielona we wnętrzu strefa sypialna gwarantuje spokojny sen wszystkim domownikom. Drewniana pergola na elewacji ogrodowej stanowi zadaszenie nad tarasem i jednocześnie piękny detal ocieplający bryłę budynku.";s:21:"alternate_description";N;s:5:"price";s:7:"4599.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:633:"{"1":{"name":"pow. u\u017cytkowa","value":111.1,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":161.2,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":25.1,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":19.5,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":4,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":30,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":6.61,"unit":"m"},"17":{"name":"pow. netto poddasza","value":null,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"316277","self":null}";s:10:"meta_title";s:79:"Arka. Parterowy dom jednorodzinny z garażem i kopertowym dachem. Studio Atrium";s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-02-27 14:41:29";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:225:"{"thumbnail":"129\/arka-wizualizacja-200-5954d404b5bcf.jpg","templateId":"1","isbn":"978-83-89103-17-8","isbn_mirror":"978-83-7356-073-4","features":["9"],"price_other_type":null,"skeleton_disabled":null,"sun_ratio":"0.0148"}";}i:971;a:22:{s:2:"id";i:1020;s:6:"id_old";i:1020;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:962;s:4:"name";s:9:"Milano IV";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:139:"Dom piętrowy z kopertowym dachem, nawiązujący klimatem do włoskiej zabudowy, bez garażu i podpiwniczenia, idealny na wąską działkę";s:11:"description";s:651:"Elegancki dom piętrowy przykryty czterospadowym dachem. Jasna elewacja, grafitowa dachówka i dyskretne drewniane detale tworzą harmonijną całość o odpowiednich proporcjach. Duże przeszklenia są naturalnym źródłem światła dla pomieszczeń, w szczególności dla zaprojektowanej w otwartej przestrzeni strefy dziennej. Dodatkowy pokój na parterze sprawdzi się zarówno w roli gabinetu jak i sypialni. Piętro mieści cztery pokoje, w tym jeden z garderobą oraz dużą łazienkę. Niewielka powierzchnia zabudowy czyni Milano IV ciekawą propozycją nawet na małe działki.  Dom będzie wygodnym lokum nawet dla pięcioosobowej rodziny.";s:21:"alternate_description";N;s:5:"price";s:7:"5099.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:635:"{"1":{"name":"pow. u\u017cytkowa","value":127.45,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":88.8,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":16.38,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":18.78,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":6,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":22,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":8.54,"unit":"m"},"17":{"name":"pow. netto poddasza","value":null,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":65.5,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"306645","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-11 14:25:57";s:10:"technology";s:156:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:253:"{"garages":["539","654","655","656"],"thumbnail":"1020\/milano-iv-wizualizacja-200-5954f3be2189a.jpg","templateId":"2","price_other_type":null,"skeleton_disabled":null,"isbn":"978-83-7937-044-3   ","isbn_mirror":"978-83-7937-045-0   ","features":["37"]}";}i:972;a:22:{s:2:"id";i:1025;s:6:"id_old";i:1025;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:952;s:4:"name";s:10:"Wektor VII";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:129:"Dom parterowy z przestronnym tarasem wypoczynkowym z boku budynku oraz 2-stanowiskową wiatą, na działki z wjazdem od południa";s:11:"description";s:550:"Prostokątna, typowa dla tej wersji domu bryła, została jeszcze przedłużona o zadaszoną powierzchnię, wspartą na czterech reprezentacyjnych, symetrycznie rozmieszczonych kolumnach z wzorem, który jest powtórzeniem zdobień na elewacji budynku. Zadaszoną powierzchnię można wykorzystać na wiele sposobów – urządzić tam miejsce do majsterkowania, przechowywać rowery lub drewno do kominka. W programie domu uwzględniono dwa pokoje, pokój dzienny, łazienkę, kuchnię oraz bardzo praktyczny wynalazek – garderobę z prasowalnią.";s:21:"alternate_description";N;s:5:"price";s:7:"4399.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:635:"{"1":{"name":"pow. u\u017cytkowa","value":83.45,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":164.65,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":25.15,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":17.6,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":3,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":30,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":6.41,"unit":"m"},"17":{"name":"pow. netto poddasza","value":null,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"208516","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-13 16:03:11";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:200:"{"thumbnail":"1025\/wektor-vii-wizualizacja-200-6a030b5d21445.jpg","templateId":"1","isbn":"978-83-7937-004-7   ","isbn_mirror":"978-83-7937-005-4   ","price_other_type":null,"skeleton_disabled":null}";}i:973;a:22:{s:2:"id";i:921;s:6:"id_old";i:921;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:896;s:4:"name";s:9:"Samba VII";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:112:"Parterowy dom z poddaszem użytkowym i garażem 2-stanowiskowym, 4 sypialnie i niezadaszony taras, podpiwniczony";s:11:"description";s:448:"Średniej wielkości dom z dwustanowiskowym garażem, w którym wygodnie zamieszka pięcioosobowa rodzina. Dzięki podpiwniczeniu dom zyskał nie tylko dodatkową przestrzeń gospodarczą, ale i rekreacyjną – sauna to doskonałe miejsce na relaks po ciężkim dniu lub intensywnym wysiłku fizycznym.  Wypoczynkowi sprzyja także rozległy taras w części ogrodowej, na którym mieszkańcy z przyjemnością będą spędzać letnie popołudnia.";s:21:"alternate_description";N;s:5:"price";s:7:"5499.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:636:"{"1":{"name":"pow. u\u017cytkowa","value":132.5,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":166.4,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":25.69,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":19.38,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":6,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":35,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":8.44,"unit":"m"},"17":{"name":"pow. netto poddasza","value":69.25,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"565881","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-10 15:19:37";s:10:"technology";s:227:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: część mieszkalna - dachówka Braas, garaż - papa termozgrzewalna. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:215:"{"features":["10","28"],"thumbnail":"921\/samba-vii-wizualizacja-200-5954eb3ba8467.jpg","templateId":"3","price_other_type":null,"skeleton_disabled":null,"isbn":"978-83-7559-863-6","isbn_mirror":"978-83-7559-867-4"}";}i:974;a:22:{s:2:"id";i:855;s:6:"id_old";i:855;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:784;s:4:"name";s:12:"Ondraszek II";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:114:"Dom regionalny w stylu beskidzkim, parterowy z poddaszem użytkowym, 4 sypialnie, przestronny taras, podpiwniczony";s:11:"description";s:877:"Patrząc na ten dom, instynktownie szukamy w zasięgu wzroku gór  bo wizualnie Ondraszek II przywodzi na myśl bryłę górskiego schroniska z jego kamiennymi wykończeniami elewacji w dolnej części. Do tego stylu nawiązuje również drewniane zwieńczenie przedsionka. Wprost z pokoju dziennego wychodzi się na zadaszony taras, ozdobiony kamiennymi przyporami. Wspólna, otwarta przestrzeń na parterze obejmuje m. in. kuchnię, jadalnię i pokój dzienny. Na poddaszu znajdują się trzy sypialnie, garderoba i łazienka. Pomieszczenia części piwnicznej można wykorzystać na kotłownię, suszarnię, pralnię oraz jako miejsce do przechowywania zimowych smakołyków. Słyną z nich przecież beskidzkie chaty, do których stylem wyraźnie nawiązuje projekt. Praktyczny rozkład pomieszczeń i ich przeznaczenie będą idealne dla cztero lub pięciosobowej rodziny.";s:21:"alternate_description";N;s:5:"price";s:7:"5399.00";s:8:"discount";s:6:"555.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:636:"{"1":{"name":"pow. u\u017cytkowa","value":134.35,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":133.1,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":18.9,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":23.85,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":5,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":40,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":7.85,"unit":"m"},"17":{"name":"pow. netto poddasza","value":76.95,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"504922","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-11 15:58:00";s:10:"technology";s:156:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:195:"{"thumbnail":"855\/ondraszek-ii-wizualizacja-200-5954eb45ea1f6.jpg","templateId":"3","isbn":"978-83-7559-696-0","isbn_mirror":"978-83-7559-601-4","price_other_type":null,"skeleton_disabled":null}";}i:975;a:22:{s:2:"id";i:742;s:6:"id_old";i:742;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:684;s:4:"name";s:7:"Wena II";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:101:"Dom parterowy z poddaszem użytkowym i garażem, z wykuszami, z 4 sypialniami i niezadaszonym tarasem";s:11:"description";s:536:"Ta wersja została wzbogacona o „doklejony” z boku garaż jednostanowiskowy. Biała elewacja świetnie komponuje się z żółtymi zdobieniami i stolarką okienno-drzwiową w tym samym kolorze. Wprost z pokoju dziennego wychodzimy na rozległy taras, na którym w ciepłe dni będzie przenosić się życie rodzinne i towarzyskie. Praktyczny i funkcjonalny układ pomieszczeń jest niewątpliwym atutem tego projektu. Dzięki niemu w domu może zamieszkać pięcioosobowa rodzina, dla której będzie to z pewnością wygodne lokum.";s:21:"alternate_description";N;s:5:"price";s:7:"4999.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:635:"{"1":{"name":"pow. u\u017cytkowa","value":136.8,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":134.95,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":21.9,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":22.2,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":6,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":40,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":8.46,"unit":"m"},"17":{"name":"pow. netto poddasza","value":79.15,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"399970","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-13 16:18:09";s:10:"technology";s:283:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: część mieszkalna  - dachówka Braas, blacha tytanowo-cynkowa (wykusz), garaż - papa termozgrzewalna ew. membrana dachowa. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:218:"{"thumbnail":"742\/wena-ii-wizualizacja-200-5954eb54b729d.jpg","templateId":"3","isbn":"978-83-7559-464-5","isbn_mirror":"978-83-7559-468-3 ","features":["9","22","27"],"price_other_type":null,"skeleton_disabled":null}";}i:976;a:22:{s:2:"id";i:745;s:6:"id_old";i:745;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:661;s:4:"name";s:7:"U Gazdy";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:59:"Dom regionalny, beskidzki, parterowy z poddaszem użytkowym";s:11:"description";s:604:"Solidny dom z góralskim charakterem. Oryginalnym akcentem podkreślającym regionalne inspiracje projektu jest wysunięty przed bryłę przeszklony wiatrołap, wsparty dodatkowo kamiennymi przyporami współgrającymi z cokołem budynku. Charakterystycznym elementem jest powiększająca strefę dzienną jadalnia, która ze względu na duże przeszklenie przywodzi na myśl dawne werandy. Będzie to z pewnością miejsce radosnych spotkań w gronie rodziny i przyjaciół. Dzięki czterem sypialniom oraz przestronnej strefie dziennej, budynek będzie wygodnym lokum nawet dla pięcioosobowej rodziny.";s:21:"alternate_description";N;s:5:"price";s:7:"4899.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:633:"{"1":{"name":"pow. u\u017cytkowa","value":124.75,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":118.55,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":20,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":20.2,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":5,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":40,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":7.55,"unit":"m"},"17":{"name":"pow. netto poddasza","value":66.3,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"348427","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-13 15:08:22";s:10:"technology";s:156:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:210:"{"features":["10"],"thumbnail":"745\/u-gazdy-wizualizacja-200-5954eb5be5cf0.jpg","templateId":"3","isbn":"978-83-7559-386-0 ","isbn_mirror":"978-83-7559-390-7 ","price_other_type":null,"skeleton_disabled":null}";}i:977;a:22:{s:2:"id";i:671;s:6:"id_old";i:671;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:576;s:4:"name";s:6:"Narcyz";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:107:"Dom parterowy z poddaszem użytkowym, z 4 sypialniami i niezadaszonym tarasem, bez garażu i podpiwniczenia";s:11:"description";s:495:"Średniej wielkości dom zbudowany na planie zbliżonym do kwadratu, co sprawia, że jego wnętrze jest ekonomiczne i dobrze skomunikowane. Parter poza standardowymi pomieszczeniami codziennego użytku mieści dodatkowy pokój, który może pełnić funkcję gabinetu oraz dużą garderobę i sporą kotłownie z możliwością zastosowania pieca na paliwo stałe. Na poddaszu znajdziemy komfortową łazienkę oraz cztery jasne i przestronne sypialnie, z których dwie mają dostęp do balkonu.";s:21:"alternate_description";N;s:5:"price";s:7:"4899.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:615:"{"1":{"name":"pow. u\u017cytkowa","value":"147,65","unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":"111,25","unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":"18,3","unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":"20,8","unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":"6","unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":"40","unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":"8,89","unit":"m"},"17":{"name":"pow. netto poddasza","value":"86,45","unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"389353","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-11 15:38:09";s:10:"technology";s:156:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:253:"{"garages":["34","35","509","510","540","545","546","593","606"],"thumbnail":"671\/narcyz-wizualizacja-200-5954dded12287.jpg","templateId":"3","isbn":"978-83-7559-220-7","isbn_mirror":"978-83-7559-224-5","price_other_type":null,"skeleton_disabled":null}";}i:978;a:22:{s:2:"id";i:587;s:6:"id_old";i:587;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:535;s:4:"name";s:12:"Bursztyn Bis";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:107:"Dom parterowy z zadaszonym, narożnym tarasem wypoczynkowym oraz 1-stanowiskowym garażem, energooszczędny";s:11:"description";s:447:"Centrum domu i miejsce wspólnych spotkań stanowi duży pokój dzienny z kominkiem i wyjściem prowadzącym na zadaszony taras. Znajdujące się w części nocnej trzy sypialnie i łazienka zapewnią komfort użytkowania czteroosobowej rodzinie. W projekcie znalazło się także miejsce na jednostanowiskowy garaż oraz przedsionek z wejściem do kotłowni. Chłodna kolorystyka elewacji nadaje klasycznej bryle bardziej nowoczesnego charakteru.";s:21:"alternate_description";N;s:5:"price";s:7:"4699.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:574:"{"1":{"name":"pow. u\u017cytkowa","value":"87,4","unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":"151,4","unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":"19,45","unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":"22,45","unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":"4","unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":"30","unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":"7,22","unit":"m"},"17":{"name":"pow. netto poddasza"},"18":{"name":"pow. netto pi\u0119tra"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"257274","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-02-19 14:28:34";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:222:"{"thumbnail":"587\/bursztyn-bis-wizualizacja-200-5954ddf71700a.jpg","templateId":"1","isbn":"978-83-7559-192-7","isbn_mirror":"978-83-7559-196-5","features":["9","27","29"],"price_other_type":null,"skeleton_disabled":null}";}i:979;a:22:{s:2:"id";i:1287;s:6:"id_old";i:1287;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:9990964;s:4:"name";s:8:"Punto SZ";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:61:"Rekreacyjny, parterowy dom szkieletowy z poddaszem użytkowym";s:11:"description";s:435:"Przed Państwem typowy dom rekreacyjny idealny na weekendowe i wakacyjne pobyty. Zwarta bryła została przykryta dwuspadowym dachem z lukarnami. Forma budynku gwarantuje niewysokie koszty realizacji i znakomicie wpisuje się w technologię szkieletową. W programie funkcjonalnym mamy dwa poziomy - parter z pokojem dziennym, łazienką i odrębną kuchnią z jadalnią oraz poddasze z dwoma sypialniami przewidziane dla trzech osób.";s:21:"alternate_description";N;s:5:"price";s:7:"3899.00";s:8:"discount";s:4:"0.00";s:4:"type";s:8:"skeleton";s:6:"status";s:9:"published";s:14:"params_general";s:609:"{"1":{"name":"pow. u\u017cytkowa","value":"40,3","unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":"36,1","unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":"15,85","unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":"12,6","unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":"1","unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":"45","unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":"5,76","unit":"m"},"17":{"name":"pow. netto poddasza","value":"26","unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"112558","self":null}";s:10:"meta_title";s:80:"Punto SZ. Rekreacyjny dom z poddaszem w technologii szkieletowej - Studio Atrium";s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-11 16:46:04";s:10:"technology";s:177:"Ściany w szkielecie drewnianym + ocieplenie z wełny mineralnej + płyty OSB + elewacja: styropian z tynkiem. Pokrycie dachu: dachówka Braas. Drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:217:"{"thumbnail":"1287\/punto-sz-wizualizacja-200-5954fd2ea66f4.jpg","templateId":"3","linkedProjects":["996"],"price_other_type":null,"skeleton_disabled":null,"isbn":"978-83-7937-876-0","isbn_mirror":"978-83-7937-877-7"}";}i:980;a:22:{s:2:"id";i:614;s:6:"id_old";i:614;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:534;s:4:"name";s:7:"Kruczek";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:58:"Dom parterowy z poddaszem użytkowym, z zadaszonym tarasem";s:11:"description";s:871:"Tradycyjny projekt na planie prostokąta wzbogacony o dostawiony z boku obszerny przedsionek oraz znajdujący się po przeciwnej stronie zadaszony taras. Stonowana kolorystyka elewacji oraz elementy wykończeniowe z drewna i ozdobnego kamienia sprawiają że budynek prezentuje się bardzo klimatycznie. Parter to otwarta część dzienna z kuchnią i salonem oraz niezależny pokój mogący pełnić funkcję gabinetu. W programie parteru jest również łazienka oraz dużą kotłownia, która ze względu na sąsiedztwo kuchni może pełnić dodatkowo rolę spiżarni. Na poddaszu znajdziemy strefę sypialną z trzema pokojami i komfortową łazienką. W jednym z pokoi zaprojektowano obszerną garderobę. Prosta bryła o ponadczasowej formie świetnie sprawdzi się na podmiejskich działkach. Dom będzie wygodnym lokum dla cztero- a nawet pięcioosobowej rodziny.";s:21:"alternate_description";N;s:5:"price";s:7:"4899.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:614:"{"1":{"name":"pow. u\u017cytkowa","value":"143,65","unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":"146,4","unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":"22,13","unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":"18,8","unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":"5","unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":"42","unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":"8,78","unit":"m"},"17":{"name":"pow. netto poddasza","value":"72,7","unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"378805","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-10 15:35:41";s:10:"technology";s:156:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:254:"{"garages":["34","35","509","510","540","545","546","593","606"],"thumbnail":"614\/kruczek-wizualizacja-200-5954ddfc2168b.jpg","templateId":"3","isbn":"978-83-7559-184-2","isbn_mirror":"978-83-7559-188-0","price_other_type":null,"skeleton_disabled":null}";}i:981;a:22:{s:2:"id";i:607;s:6:"id_old";i:607;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:529;s:4:"name";s:6:"Nefryt";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:80:"Parterowy dom z poddaszem użytkowym i garażem, z narożnym tarasem w podcieniu";s:11:"description";s:687:"Główna bryła budynku została nakryta dwuspadowym dachem, nadając całości cechę szlachetnej prostoty, a tym, co wyróżnia projekt jest oryginalny, przeszklony przedsionek, który jednocześnie może pełnić rolę miniaturowego ogrodu zimowego. Wnętrze mieści przestrzeń dzienną w otwartej zabudowie oraz strefę sypialną obejmującą poddasze oraz tylną część parteru. Warto zwrócić uwagę na garaż z bezpośrednim przejściem do części mieszkalnej, co docenimy zwłaszcza w zimne i deszczowe dni. Dodatkowym atutem budynku jest dostępny z salonu i jednej z sypialni zadaszony taras, który umożliwia relaks na świeżym powietrzu przy mniej sprzyjającej aurze.";s:21:"alternate_description";N;s:5:"price";s:7:"4999.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:616:"{"1":{"name":"pow. u\u017cytkowa","value":"139,35","unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":"159,95","unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":"19,55","unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":"22,8","unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":"5","unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":"35","unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":"7,91","unit":"m"},"17":{"name":"pow. netto poddasza","value":"44,15","unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"404639","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-11 15:42:00";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:189:"{"thumbnail":"607\/nefryt-wizualizacja-200-5954de0143b31.jpg","templateId":"3","isbn":"978-83-7559-104-0","isbn_mirror":"978-83-7559-108-8","price_other_type":null,"skeleton_disabled":null}";}i:982;a:22:{s:2:"id";i:397;s:6:"id_old";i:397;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:357;s:4:"name";s:7:"Walczyk";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:82:"Dom parterowy z poddaszem użytkowym i garażem, z gankiem i niezadaszonym tarasem";s:11:"description";s:610:"Walczyk już na pierwszy rzut oka urzeka prostotą i stonowaną kolorystyką. Oryginalnym akcentem jest lekko wysunięta do przodu bryła garażu. Efektowny ganek – połączenie drewnianego zdobienia nad daszkiem i kamiennych elementów po bokach – to strzał w dziesiątkę. Dom jest nie tylko atrakcyjny, ale również praktyczny – na poddaszu pomyślano o sypialniach oraz o schowkach. Parter to typowa strefa dzienna z pokojem dziennym, kuchnią, łazienką i gabinetem. Z pokoju dziennego wychodzimy wprost na taras, gdzie w ciepłe dni będzie skupiać się życie trzy- lub czteroosobowej rodziny.";s:21:"alternate_description";N;s:5:"price";s:7:"4599.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:635:"{"1":{"name":"pow. u\u017cytkowa","value":117.05,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":117.9,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":20.7,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":18.2,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":5,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":40,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":7.96,"unit":"m"},"17":{"name":"pow. netto poddasza","value":77.25,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"362600","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-13 15:50:28";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:208:"{"features":["10"],"thumbnail":"397\/walczyk-wizualizacja-200-5954de10b0d83.jpg","templateId":"3","isbn":"978-83-7356-886-0","isbn_mirror":"978-83-7356-891-4","price_other_type":null,"skeleton_disabled":null}";}i:983;a:22:{s:2:"id";i:293;s:6:"id_old";i:293;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:274;s:4:"name";s:9:"Przystań";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:129:"Przestronny dom parterowy z odkrytym, półokrągłym tarasem na zapleczu budynku oraz 2-stanowiskowym garażem, energooszczędny";s:11:"description";s:455:"Rozłożysty, parterowy budynek przyciąga uwagę elegancką bryłą i jasną elewacją, doskonale zharmonizowaną ze stolarką okienno-drzwiową. Ciekawym i nietypowym rozwiązaniem jest półokrągły taras, na który wychodzimy wprost z pokoju dziennego. Cztery pokoje oraz pokój dzienny, dwie łazienki, kuchnia, jadalnia i schowek to gwarancja komfortu dla pięcioosobowej rodziny. W projekcie został również uwzględniony dwustanowiskowy garaż.";s:21:"alternate_description";N;s:5:"price";s:7:"5999.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:635:"{"1":{"name":"pow. u\u017cytkowa","value":190.7,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":269.35,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":27.45,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":28.7,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":5,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":30,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":6.54,"unit":"m"},"17":{"name":"pow. netto poddasza","value":null,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"542344","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-11 16:42:08";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:214:"{"features":["10","15"],"thumbnail":"293\/przystan-wizualizacja-200-5954d51491ea2.jpg","templateId":"1","isbn":"978-83-7356-354-4","isbn_mirror":"978-83-7356-359-9","price_other_type":null,"skeleton_disabled":null}";}i:984;a:22:{s:2:"id";i:239;s:6:"id_old";i:239;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:221;s:4:"name";s:12:"Willa Barona";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:111:"Parterowy dom z poddaszem użytkowym, z 4 sypialniami i 2-stanowiskowym garażem, taras częściowo w podcieniu";s:11:"description";s:670:"Willa Barona to zgrabna bryła nakryta wielospadowym dachem z elegancko wkomponowanym dwustanowiskowym garażem. W części frontowej uwagę zwraca przeszklony ryzalit tuż przy drzwiach wejściowych, gdzie mieści się kuchnia oraz łukowe podcienie, tworzące częściowo zadaszony taras. Niewątpliwą ozdobą jest również umieszczona na dachu lukarna. Na taras wychodzimy wprost z pokoju dziennego z jadalnią. Na poddaszu zaplanowano trzy pokoje, dwie łazienki, praktyczną garderobę oraz aż dwa pomieszczenia rekreacyjne, które można wykorzystać na domową siłownię lub pracownię. Dom jest idealną propozycją dla pięcio- lub sześcioosobowej rodziny.";s:21:"alternate_description";N;s:5:"price";s:7:"5599.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:638:"{"1":{"name":"pow. u\u017cytkowa","value":175.6,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":161.55,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":21.95,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":21.95,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":5,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":40,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":8.33,"unit":"m"},"17":{"name":"pow. netto poddasza","value":126.65,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"525355","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-13 16:23:16";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:213:"{"features":["10"],"thumbnail":"239\/willa-barona-wizualizacja-200-5954d51bf33a7.jpg","templateId":"3","isbn":"978-83-7356-430-5","isbn_mirror":"978-83-7356-435-0","price_other_type":null,"skeleton_disabled":null}";}i:985;a:22:{s:2:"id";i:1161;s:6:"id_old";i:1161;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:1130;s:4:"name";s:9:"Fiesta II";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:103:"Parterowy dom z kopertowym dachem oraz odkrytym tarasem wypoczynkowym z tyłu budynku, energooszczędny";s:11:"description";s:380:"Energooszczędny projekt dla ceniących sobie prywatność i komfortowe warunki. Trzy sypialnie wyposażone we własne łazienki zostały rozmieszczone w oddzielnych częściach domu. Wspólna przestrzeń pokoju dziennego i jadalni to serce tego domu, która zachęca do spędzania czasu przy rodzinnym stole lub na kanapie w pobliżu rozgrzewającego w chłodne wieczory kominka.";s:21:"alternate_description";N;s:5:"price";s:7:"5299.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:636:"{"1":{"name":"pow. u\u017cytkowa","value":157.15,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":194.65,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":24.4,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":21.15,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":4,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":25,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":6.17,"unit":"m"},"17":{"name":"pow. netto poddasza","value":null,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"430434","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-10 11:27:47";s:10:"technology";s:156:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:210:"{"thumbnail":"1161\/fiesta-ii-wizualizacja-200-5954fd3642c5f.jpg","templateId":"1","isbn":"978-83-7937-314-7","isbn_mirror":"978-83-7937-315-4","features":["9"],"price_other_type":null,"skeleton_disabled":null}";}i:986;a:22:{s:2:"id";i:1117;s:6:"id_old";i:1117;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:1024;s:4:"name";s:6:"Zoja V";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:114:"Dom parterowy z poddaszem użytkowym i 4 sypialniami, z kotłownią na paliwo stałe, bez garażu i podpiwniczenia";s:11:"description";s:411:"Oryginalny kształt budynku sprawia, że ta bryła z pewnością wyróżni się wśród innych. Użytkowe poddasze składające się z czterech sypialni i łazienki sprawia, że dom doskonale sprawdzi się dla rodzin pięcioosobowych lub większych dzięki dodatkowemu pokojowi na parterze. Duży przedsionek, szeroki hall z komunikacją oraz otwarta przestrzeń dzienna gwarantują dużą wygodę użytkowania.";s:21:"alternate_description";N;s:5:"price";s:7:"4799.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:611:"{"1":{"name":"pow. u\u017cytkowa","value":"128,2","unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":"96,8","unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":"19","unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":"16,88","unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":"6","unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":"45","unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":"8,78","unit":"m"},"17":{"name":"pow. netto poddasza","value":"73,95","unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"358063","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-13 16:42:59";s:10:"technology";s:191:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas, blacha tytanowo-cynkowa (lukarna). Drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:276:"{"garages":["34","35","509","510","540","545","546","593","606"],"features":["1","36"],"thumbnail":"1117\/zoja-v-wizualizacja-200-699ef2aecf930.jpg","templateId":"3","isbn":"978-83-7937-090-0","isbn_mirror":"978-83-7937-091-7","price_other_type":null,"skeleton_disabled":null}";}i:987;a:22:{s:2:"id";i:1101;s:6:"id_old";i:1101;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:1022;s:4:"name";s:9:"Karmel II";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:90:"Dom parterowy z poddaszem użytkowym i garażem, 4 sypialnie i częściowo zadaszony taras";s:11:"description";s:658:"Jednorodzinny dom z poddaszem użytkowym i jednostanowiskowym garażem. Najbardziej nasłonecznionym miejscem w budynku jest jadalnia, która dzięki prostokątnemu, przeszklonemu ryzalitowi będzie łapać promienie słońca niezależnie od pory dnia. Program użytkowy parteru mieści również kuchnię, łazienkę, pokój dzienny z wyjściem na taras oraz zaciszny gabinet. W części sypialnej zaprojektowanej na poddaszu znajdziemy dużą sypialnię, trzy mniejsze pokoje z dostępem do balkonu oraz komfortową łazienkę. Kotłownia została przygotowana pod montaż pieca na paliwo stałe. Dom będzie wygodnym  lokum nawet dla 5-6 osobowej rodziny.";s:21:"alternate_description";N;s:5:"price";s:7:"4999.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:614:"{"1":{"name":"pow. u\u017cytkowa","value":"146,75","unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":"145,2","unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":"22,2","unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":"19,6","unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":"6","unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":"40","unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":"8,57","unit":"m"},"17":{"name":"pow. netto poddasza","value":"100,7","unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"420478","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-10 14:09:02";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:215:"{"features":["1","36"],"thumbnail":"1101\/karmel-ii-wizualizacja-200-5954f3dfdd17c.jpg","templateId":"3","isbn":"978-83-7937-082-5","isbn_mirror":"978-83-7937-083-2","price_other_type":null,"skeleton_disabled":null}";}i:988;a:22:{s:2:"id";i:1022;s:6:"id_old";i:1022;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:958;s:4:"name";s:14:"Winston III SP";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:112:"Parterowy dom z kotłownią na paliwo stałe, odkrytym, narożnym tarasem wypoczynkowym oraz z garażem i wiatą";s:11:"description";s:753:"W tej wersji urzeka oszczędna, minimalistyczna kolorystyka, podkreślająca najlepsze cechy domów w rodziny Winston– prostotę i elegancję. Jak się okazuje, klasyka nigdy nie wychodzi z mody! Dodatkowo projekt jest bardzo ekonomiczny w realizacji, a dom można wybudować również na wąskiej działce. W projekcie uwzględniono garaż oraz wiatę, umieszczoną tuż obok. W lewej części parterowego domu zaplanowano część dzienną, wspólną, z pokojem dziennym z jadalnią, skąd wychodzimy przez przeszklone drzwi na taras oraz kuchnią i spiżarnią. Po prawej zaprojektowano część nocną, z trzema pokojami, łazienką i garderobą. Dla wielu inwestorów dodatkowym atutem projektu będzie zaprojektowana kotłownia na paliwo stałe.";s:21:"alternate_description";N;s:5:"price";s:7:"4699.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:633:"{"1":{"name":"pow. u\u017cytkowa","value":105.8,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":188,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":19.73,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":26.98,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":4,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":30,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":6.15,"unit":"m"},"17":{"name":"pow. netto poddasza","value":null,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"305115","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-02-26 10:36:24";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:231:"{"features":["1","36","26"],"thumbnail":"1022\/winston-iii-sp-wizualizacja-200-5954f3e731037.jpg","templateId":"1","isbn":"978-83-7937-028-3   ","isbn_mirror":"978-83-7937-029-0   ","price_other_type":null,"skeleton_disabled":null}";}i:989;a:22:{s:2:"id";i:958;s:6:"id_old";i:958;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:948;s:4:"name";s:8:"Tokyo II";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:102:"Nowoczesny dom parterowy z płaskim dachem oraz narożnym, zakrytym tarasem wypoczynkowym i z garażem";s:11:"description";s:540:"Nowoczesny wygląd projektu idzie w parze z funkcjonalnym, dostosowanym do potrzeb trzyosobowej rodziny wnętrzem. Poza dwiema sypialniami do dyspozycji domowników pozostaje jasny i przestronny pokój dzienny z wyjściem na taras, a także jadalnia i kuchnia. Strefę gospodarczą tworzą spiżarnia, kotłownia oraz obszerny garaż, w którym  poza samochodem zmieszczą się również rowery i sprzęty konieczne do utrzymania ogrodu. Projekt spełni oczekiwania Inwestorów, poszukujących niewielkiego domu o nowoczesnej architekturze.";s:21:"alternate_description";N;s:5:"price";s:7:"4799.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:639:"{"1":{"name":"pow. u\u017cytkowa","value":100.45,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":188.35,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":20.49,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":24.85,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":3,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":null,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":4.32,"unit":"m"},"17":{"name":"pow. netto poddasza","value":null,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"302699","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-13 14:54:55";s:10:"technology";s:201:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: papa termozgrzewalna, ew. membrana dachowa. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:209:"{"thumbnail":"958\/tokyo-ii-wizualizacja-200-5954f3ee513d5.jpg","templateId":"1","price_other_type":null,"skeleton_disabled":null,"isbn":"978-83-7559-979-4","isbn_mirror":"978-83-7559-983-1","features":["47"]}";}i:990;a:22:{s:2:"id";i:1042;s:6:"id_old";i:1042;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:910;s:4:"name";s:16:"Compact House II";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:96:"Parterowy dom z poddaszem użytkowym, z 4 sypialniami i garażem, z kotłownią na paliwo stałe";s:11:"description";s:404:"Energooszczędny, kompaktowy dom jednorodzinny, w którym wszystko ma swoje miejsce i żadna powierzchnia nie pozostaje niewykorzystana. Pokój dzienny z wyjściem na taras znajduje się z tyłu domu, pozwalając na niczym nie zakłócony wypoczynek w bliskim kontakcie z naturą. Poddasze mieści aż cztery dobrze doświetlone sypialnie, stanowiące wygodną strefę nocną dla pięcioosobowej rodziny.";s:21:"alternate_description";N;s:5:"price";s:7:"4699.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:611:"{"1":{"name":"pow. u\u017cytkowa","value":"107,15","unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":"97,3","unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":"19","unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":"16,94","unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":"5","unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":"45","unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":"8,75","unit":"m"},"17":{"name":"pow. netto poddasza","value":"73,7","unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"341331","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-02-26 12:31:56";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:217:"{"features":["1"],"thumbnail":"1042\/compact-house-ii-wizualizacja-200-5954f3f566291.jpg","templateId":"3","isbn":"978-83-7559-972-5","isbn_mirror":"978-83-7559-976-3","price_other_type":null,"skeleton_disabled":null}";}i:991;a:22:{s:2:"id";i:879;s:6:"id_old";i:879;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:815;s:4:"name";s:12:"Ricardo VIII";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:111:"Niewielki dom parterowy z klasycznym dwuspadowym dachem oraz przestronnym tarasem na zapleczu, energooszczędny";s:11:"description";s:578:"Kolejna odsłona popularnej parterówki, prostej i taniej w budowie. Duża przestrzeń dla niedużej rodziny będzie gwarancją komfortowego użytkowania na co dzień. Po solidnym wypoczynku w jasnej i przytulnej sypialni z własną łazienką można cieszyć się poranną filiżanką kawy na zaprojektowanym w części ogrodowej tarasie. W chłodne dni do tego samego zaprasza przestronny pokój dzienny z kominkiem, w którym znalazło się miejsce także na rodzinny stół. Tuż obok kuchni ulokowano spiżarkę – praktyczne pomieszczenie na domowe przetwory i nie tylko.";s:21:"alternate_description";N;s:5:"price";s:7:"4199.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:635:"{"1":{"name":"pow. u\u017cytkowa","value":75.95,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":107.7,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":19.45,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":18.08,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":2,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":30,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":6.28,"unit":"m"},"17":{"name":"pow. netto poddasza","value":null,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"192078","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-02-20 12:56:53";s:10:"technology";s:156:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:254:"{"garages":["37","155","322","323","511","512","652","701"],"thumbnail":"879\/ricardo-viii-wizualizacja-200-5954eb60d0b55.jpg","templateId":"1","isbn":"978-83-7559-713-4","isbn_mirror":"978-83-7559-717-2","price_other_type":null,"skeleton_disabled":null}";}i:992;a:22:{s:2:"id";i:766;s:6:"id_old";i:766;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:729;s:4:"name";s:12:"Bukowa Chata";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:139:"Dom regionalny beskidzki, piętrowy, częściowo z poddaszem użytkowym, oryginalnym przeszklonym salonem i wykuszami dachowymi, z garażem";s:11:"description";s:344:"Piętrowy dom jednorodzinny przykryty dachem półszczytowym. Strefa wypoczynku na piętrze obejmuje dużą sypialnię z osobną łazienką oraz trzy mniejsze pokoje z łazienką dostępną z korytarza. Konstrukcja dachu oraz dobudowana z boku domu przeszklona weranda pełniąca funkcję pokoju dziennego nadają budynkowi regionalnego sznytu.";s:21:"alternate_description";N;s:5:"price";s:7:"5399.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:635:"{"1":{"name":"pow. u\u017cytkowa","value":144.5,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":133.75,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":23.3,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":18.55,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":5,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":38,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":8.98,"unit":"m"},"17":{"name":"pow. netto poddasza","value":null,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":83.8,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"420741","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-09 15:15:36";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:213:"{"features":["10"],"thumbnail":"766\/bukowa-chata-wizualizacja-200-5954eb6b0785f.jpg","templateId":"2","isbn":"978-83-7559-537-6","isbn_mirror":"978-83-7559-541-3","price_other_type":null,"skeleton_disabled":null}";}i:993;a:22:{s:2:"id";i:763;s:6:"id_old";i:763;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:722;s:4:"name";s:11:"Śnieżynka";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:84:"Dom regionalny w stylu beskidzkim, parterowy z poddaszem użytkowym, z 4 sypialniami";s:11:"description";s:418:"Oryginalny dach z lukarnami oraz kamienne i drewniane wykończenia elewacji nawiązują do charakterystycznego stylu regionalnych domów beskidzkich. Dzięki przemyślanemu rozplanowaniu pomieszczeń, w średniej wielkości wnętrzu znalazło się miejsce na pięć komfortowych pokojów, dwie łazienki, garderobę, kuchnię, niewielki przedsionek oraz otwartą przestrzeń połączonego z jadalnią pokoju dziennego.";s:21:"alternate_description";N;s:5:"price";s:7:"5199.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:635:"{"1":{"name":"pow. u\u017cytkowa","value":149.4,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":125.7,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":24.09,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":16.59,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":6,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":45,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":8.21,"unit":"m"},"17":{"name":"pow. netto poddasza","value":83.1,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"393968","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-13 13:55:01";s:10:"technology";s:156:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:192:"{"thumbnail":"763\/sniezynka-wizualizacja-200-5954eb726621d.jpg","templateId":"3","isbn":"978-83-7559-580-2","isbn_mirror":"978-83-7559-584-0","price_other_type":null,"skeleton_disabled":null}";}i:994;a:22:{s:2:"id";i:708;s:6:"id_old";i:708;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:654;s:4:"name";s:5:"Mango";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:104:"Parterowy dom z poddaszem użytkowym i garażem 2-stanowiskowym, z 5 sypialniami i niezadaszonym tarasem";s:11:"description";s:915:"Średniej wielkości dom z bogatym programem użytkowym, zapewniającym komfort użytkowania dużej rodzinie. Stonowana kolorystyka budynku w połączeniu z zastosowanymi detalami architektonicznymi tworzą ciekawy efekt wizualny w postaci nowoczesnego projektu domu. Uwagę przykuwa dach bez okapów, przykryty blachą tytanowo-cynkową w kolorze miedzi, co dodaje budynkowi niepowtarzalnego charakteru. Duże przeszklenia doświetlają wnętrze naturalnym światłem, w szczególności zaprojektowane w otwartej przestrzeni kuchnię, jadalnię i salon, z którego można wyjść wprost na narożny, częściowo zadaszony taras. W programie parteru mieszczą się dodatkowo pokój, łazienka i schowek a także duża kotłownia za garażem. Na poddaszu zaprojektowano aż pięć pokoi, w tym jeden w własną łazienką oraz ogólnodostępną łazienkę. Jeden z pokoi posiada wyjście na duży taras nad garażem.";s:21:"alternate_description";N;s:5:"price";s:7:"5399.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:633:"{"1":{"name":"pow. u\u017cytkowa","value":145.1,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":149.9,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":24.9,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":18.4,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":7,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":40,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":8.16,"unit":"m"},"17":{"name":"pow. netto poddasza","value":94.2,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"454921","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-11 12:44:47";s:10:"technology";s:182:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: blacha tytanowo-cynkowa. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:207:"{"features":["10"],"thumbnail":"708\/mango-wizualizacja-200-5954eb8885751.jpg","templateId":"3","isbn":"978-83-7559-330-3 ","isbn_mirror":"978-83-7559-334-1","price_other_type":null,"skeleton_disabled":null}";}i:995;a:22:{s:2:"id";i:249;s:6:"id_old";i:249;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:231;s:4:"name";s:6:"Tosiek";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:97:"Dom parterowy z poddaszem użytkowym i garażem, z przeszklonym ryzalitem i niezadaszonym tarasem";s:11:"description";s:961:"Prosty w konstrukcji dom o ponadczasowej bryle, który będzie wygodnym lokum dla cztero a nawet pięciosobowej rodziny. W centrum części dziennej zaprojektowano kominek, dzięki któremu można stworzyć ciepłą, domową atmosferę w zimowe wieczory. Zaprojektowana od strony frontowej kuchnia jest otwarta na jadalnię ale oddzielona ścianą od pokoju dziennego. Na poziomie parteru znajduje się również dodatkowy pokój, który może pełnić funkcję sypialni, ponieważ obok zaprojektowano łazienkę. Duża kotłownia mieści piec gazowy a szafy wnękowe w holu z powodzeniem zastąpią garderobę. Przedłużeniem wspólnej strefy wypoczynku jest niewielki taras, z którego po stopniach można zejść wprost do ogrodu. Kontakt z otaczającą dom zielenią umożliwia także umieszczony nad wielokątnym ryzalitem balkon, dostępny z dwóch sypialni na poddaszu. Obok głównej bryły budynku zaprojektowano garaż przykryty jednospadowym dachem.";s:21:"alternate_description";N;s:5:"price";s:7:"4899.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:633:"{"1":{"name":"pow. u\u017cytkowa","value":136.4,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":126.2,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":22.53,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":16.95,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":5,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":45,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":8.92,"unit":"m"},"17":{"name":"pow. netto poddasza","value":77,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"395833","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-13 15:04:28";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:189:"{"thumbnail":"249\/tosiek-wizualizacja-200-5954d5309038a.jpg","templateId":"3","isbn":"978-83-7356-390-2","isbn_mirror":"978-83-7356-395-7","price_other_type":null,"skeleton_disabled":null}";}i:996;a:22:{s:2:"id";i:993;s:6:"id_old";i:993;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:1018;s:4:"name";s:11:"Ekspert III";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:98:"Dom parterowy z poddaszem użytkowym, z garażem i 4 sypialniami, z częściowo zadaszonym tarasem";s:11:"description";s:388:"Energooszczędny dom parterowy z jednostanowiskowym garażem. Rodzinne posiłki będą prawdziwą przyjemnością zarówno w zaciszu częściowo zadaszonego tarasu, jak i w jasnej i przestronnej jadalni, której panoramiczne okna pozwolą cieszyć oczy otaczającym dom ogrodem. Poddasze mieści cztery sypialnie, w tym trzy z dostępem do balkonów a także dużą i wygodną łazienkę.";s:21:"alternate_description";N;s:5:"price";s:7:"4799.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:637:"{"1":{"name":"pow. u\u017cytkowa","value":128.25,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":124.05,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":20.35,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":19.3,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":5,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":40,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":8.15,"unit":"m"},"17":{"name":"pow. netto poddasza","value":94.05,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"394721","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-10 09:34:23";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:194:"{"thumbnail":"993\/ekspert-iii-wizualizacja-200-5954f3fc7b436.jpg","templateId":"3","isbn":"978-83-7937-066-5","isbn_mirror":"978-83-7937-067-2","price_other_type":null,"skeleton_disabled":null}";}i:997;a:22:{s:2:"id";i:992;s:6:"id_old";i:992;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:1001;s:4:"name";s:7:"Zorba V";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:109:"Mały parterowy dom z wejściem z kolumnami oraz tarasem umiejscowionym na zapleczu budynku, energooszczędny";s:11:"description";s:451:"Ergonomiczny dom parterowy. Wnętrze zostało podzielone na część dzienną, zaprojektowaną w sposób, który sprzyja komunikacji pomieszczeń oraz sypialnianą. Usytuowane blisko siebie trzy pokoje oddalone od reszty domu gwarantują spokojny wypoczynek. Prosta, jasna elewacja połączona z drewnianymi elementami idealnie współgra z grafitowym dachem, tworząc niebanalny efekt wizualny. Projekt godny uwagi osób szukających domów do 80 m2.";s:21:"alternate_description";N;s:5:"price";s:7:"4199.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:633:"{"1":{"name":"pow. u\u017cytkowa","value":72.3,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":100.9,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":18.9,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":17.45,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":4,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":25,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":5.39,"unit":"m"},"17":{"name":"pow. netto poddasza","value":null,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"182847","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-02-23 15:09:09";s:10:"technology";s:156:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:213:"{"thumbnail":"992\/zorba-v-wizualizacja-200-5954f4013e772.jpg","templateId":"1","isbn":"978-83-7937-002-3","isbn_mirror":"978-83-7937-003-0","features":["23","21"],"price_other_type":null,"skeleton_disabled":null}";}i:998;a:22:{s:2:"id";i:1017;s:6:"id_old";i:1017;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:994;s:4:"name";s:11:"Max Plus II";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:67:"Parterowy dom z użytkowym poddaszem i garażem, z odkrytym tarasem";s:11:"description";s:509:"Mały, biały domek z urokliwym ryzalitem, w którym zaprojektowano jadalnię. Wygodny przedsionek, kotłownia, która może pełnić również rolę spiżarni, kuchnia połączona z jadalnią i salonem oraz łazienka to pomieszczenia parteru. Na poddaszu zaprojektowano trzy pokoje i łazienkę. Z dwóch pokoi można wyjść na balkon, znajdujący się od strony ogrodowej. Do bryły budynku doprojektowano garaż z pomieszczeniem gospodarczym. Max Plus II będzie wygodnym lokum dla czteroosobowej rodziny.";s:21:"alternate_description";N;s:5:"price";s:7:"4799.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:636:"{"1":{"name":"pow. u\u017cytkowa","value":106.45,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":111.65,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":20.05,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":17.3,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":4,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":40,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":8.17,"unit":"m"},"17":{"name":"pow. netto poddasza","value":57.3,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"335889","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-11 12:54:06";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:199:"{"thumbnail":"1017\/max-plus-ii-wizualizacja-200-5954f408434a1.jpg","templateId":"3","price_other_type":null,"skeleton_disabled":null,"isbn":"978-83-7937-172-3   ","isbn_mirror":"978-83-7937-173-0 "}";}i:999;a:22:{s:2:"id";i:956;s:6:"id_old";i:956;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:960;s:4:"name";s:8:"Gama III";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:97:"Dom parterowy z poddaszem użytkowym i garażem 2-stanowiskowym, 4 sypialnie i niezadaszony taras";s:11:"description";s:979:"Średniej wielkości dom z poddaszem użytkowym i dwustanowiskowym garażem. Miejscem wspólnych spotkań w rodzinnym gronie jest strefa dzienna z jadalnią, kuchnią i dużym pokojem ogrzewanym ciepłem kominka w chłodne jesienne wieczory. Na parterze zaprojektowano także praktyczne pomieszczenie gospodarcze i kotłownię w przedłużonej powierzchni garażu oraz dodatkowy pokój, który można przeznaczyć na gabinet. We wspomnianej kotłowni przewidziano kocioł opalany gazem, ale bez problemu zafunkcjonuje tu piec na paliwo stałe. Poddasze to już klasyczna strefa nocna, w skład której wchodzą cztery duże, ustawne pokoje obsługiwane przez sporą łazienkę, z której wyjść można na balkon. Na ten sam balkon wyjdziemy również z największej sypialni. Dodatkowo jeden pokój posiada dostęp do niezależnej garderoby oraz wyjście na taras nad garażem. Ten dom to idealne rozwiązanie dla pięcioosobowej rodziny ceniącej wygodę, spokój i wypoczynek.";s:21:"alternate_description";N;s:5:"price";s:7:"5799.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:632:"{"1":{"name":"pow. u\u017cytkowa","value":157,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":176.7,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":25.45,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":19.6,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":6,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":40,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":8.52,"unit":"m"},"17":{"name":"pow. netto poddasza","value":92.9,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"501431","self":null}";s:10:"meta_title";s:81:"Gama III. Średniej wielkości dom z poddaszem, garażem i tarasem. Studio Atrium";s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-10 12:18:15";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:220:"{"thumbnail":"956\/gama-iii-wizualizacja-200-5954f41642859.jpg","templateId":"3","isbn":"978-83-7937-036-8   ","isbn_mirror":"978-83-7937-037-5   ","features":["10","23"],"price_other_type":null,"skeleton_disabled":null}";}i:1000;a:22:{s:2:"id";i:1034;s:6:"id_old";i:1034;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:946;s:4:"name";s:10:"Fortuna IV";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:138:"Dom parterowy z poddaszem użytkowym i garażem 2-stanowiskowym, przestronny taras częściowo w podcieniu, z kotłownią na paliwo stałe";s:11:"description";s:377:"Elegancki dom jednorodzinny z dwustanowiskowym garażem. Wnętrze podzielono funkcjonalnie na strefę dzienną na parterze oraz część sypialną na poddaszu. Największy pokój poddasza będzie świetnym miejscem na wspólną rekreację – pomieści stół do biliarda czy piłkarzyków lub duży ekran i rzutnik, pozwalające stworzyć kino domowe w zaciszu własnego domu.";s:21:"alternate_description";N;s:5:"price";s:7:"4899.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:635:"{"1":{"name":"pow. u\u017cytkowa","value":125.1,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":152.3,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":24.13,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":19.3,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":4,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":42,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":8.49,"unit":"m"},"17":{"name":"pow. netto poddasza","value":117.4,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"424965","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-10 12:07:38";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:216:"{"features":["1","36"],"thumbnail":"1034\/fortuna-iv-wizualizacja-200-5954f41d55e30.jpg","templateId":"3","isbn":"978-83-7559-963-3","isbn_mirror":"978-83-7559-967-1","price_other_type":null,"skeleton_disabled":null}";}i:1001;a:22:{s:2:"id";i:1048;s:6:"id_old";i:1048;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:918;s:4:"name";s:8:"Jawor II";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:97:"Parterowy dom z poddaszem użytkowym, z garażem i odkrytym tarasem, idealny na wąską działkę";s:11:"description";s:604:"Drzwi wejściowe osłania niewielki, zadaszony ganek, który prowadzi do przytulnego i komfortowego wnętrza. Parter stanowi część dzienną , zawierającą przechodnią kuchnię, łazienkę oraz duży pokój dzienny, w którym znajdzie się także miejsce na rodzinny stół jadalny. Wielbicieli spędzania czasu na świeżym powietrzu ucieszy także dobudowany z tyłu domu taras, stanowiący łącznik nasłonecznionego wnętrza z otoczeniem budynku. Strefę sypialną z dwoma mniejszymi sypialniami połączonymi balkonem oraz większym pokojem wyposażonym w garderobę zaprojektowano na poddaszu.";s:21:"alternate_description";N;s:5:"price";s:7:"4899.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:613:"{"1":{"name":"pow. u\u017cytkowa","value":"117,95","unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":"109,4","unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":"15,9","unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":"22,09","unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":"4","unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":"45","unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":"8,5","unit":"m"},"17":{"name":"pow. netto poddasza","value":"81,4","unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"373389","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-10 13:37:41";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:192:"{"thumbnail":"1048\/jawor-ii-wizualizacja-200-5954f42dedee2.jpg","templateId":"3","isbn":"978-83-7559-937-4","isbn_mirror":"978-83-7559-941-1","price_other_type":null,"skeleton_disabled":null}";}i:1002;a:22:{s:2:"id";i:1166;s:6:"id_old";i:1166;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:1115;s:4:"name";s:6:"Neo IX";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:97:"Dom parterowy z dwuspadowym dachem, odkrytym tarasem i garażem 2-stanowiskowym, energooszczędny";s:11:"description";s:671:"Bryła zaprojektowana na planie prostokąta z dobudowanym dwustanowiskowym garażem stanowi komfortowe lokum dla czteroosobowej rodziny. Życie domowe skupi się wokół obszernej strefy dziennej, która dzięki otwartej kompozycji pozwoli na wspólne spędzanie czasu w gronie rodzinnym. W ciepłe dni do przebywania w otoczeniu zieleni ogrodu zachęci częściowo zadaszony taras z tyłu domu, na który prowadzą przeszklone drzwi pokoju dziennego. W strefie sypialnej zaprojektowano trzy pokoje i łazienkę. Prosta bryła przykryta dwuspadowym dachem gwarantuje niskie koszty budowy a zwarta bryła o niewielkiej powierzchni ekonomiczne użytkowanie w przyszłości.";s:21:"alternate_description";N;s:5:"price";s:7:"4499.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:575:"{"1":{"name":"pow. u\u017cytkowa","value":"94,7","unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":"169,45","unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":"25,95","unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":"18,79","unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":"4","unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":"25","unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":"5,93","unit":"m"},"17":{"name":"pow. netto poddasza"},"18":{"name":"pow. netto pi\u0119tra"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"301140","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-02-23 13:59:42";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:218:"{"thumbnail":"1166\/neo-ix-wizualizacja-200-5954fd3b54568.jpg","templateId":"1","isbn":"978-83-7937-254-6","isbn_mirror":"978-83-7937-255-3","price_other_type":null,"skeleton_disabled":null,"features":["23","22","30"]}";}i:1003;a:22:{s:2:"id";i:1169;s:6:"id_old";i:1169;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:1102;s:4:"name";s:10:"Riwiera II";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:108:"Duży dom parterowy ze strychem, bez garażu i podpiwniczenia, z narożnym tarasem - częściowo w podcieniu";s:11:"description";s:630:"Riwiera II to obszerna parterówka ze strychem do adaptacji. Komfortowym miejscem na organizację rodzinnych uroczystości będzie jadalnia połączona z kuchnią w otwartej zabudowie, a spokojny wypoczynek zagwarantuje oddalona od pozostałych pomieszczeń sypialnia z własną łazienką. W przestrzeni parteru zaprojektowano także pokój z dodatkową kuchnią i łazienką oraz garderobą, który może być  przeznaczony dla starszych rodziców lub odwiedzających nas gości. Spore możliwości dalszej aranżacji stwarza strych o powierzchni ponad 110 m2, na który prowadzą wkomponowane w projekt pokoju dziennego schody.";s:21:"alternate_description";N;s:5:"price";s:7:"5899.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:636:"{"1":{"name":"pow. u\u017cytkowa","value":187.85,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":240.05,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":27,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":22.95,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":3,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":30,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":7.65,"unit":"m"},"17":{"name":"pow. netto poddasza","value":203.05,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"456476","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-12 15:40:05";s:10:"technology";s:156:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:217:"{"features":["10","26"],"thumbnail":"1169\/riwiera-ii-wizualizacja-200-5954fd42f3bc3.jpg","templateId":"3","isbn":"978-83-7937-202-7","isbn_mirror":"978-83-7937-203-4","price_other_type":null,"skeleton_disabled":null}";}i:1004;a:22:{s:2:"id";i:1164;s:6:"id_old";i:1164;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:1078;s:4:"name";s:7:"Fado IV";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:88:"Dom parterowy z poddaszem użytkowym i garażem, z kopertowym dachem, bez podpiwniczenia";s:11:"description";s:383:"Chłodna kolorystyka dachu i elewacji została zrównoważona ciepłym odcieniem stolarki okiennej i drzwiowej. Wnętrze podzielono na strefę dzienną na parterze oraz część sypialną na poddaszu. Wielbicieli natury ucieszą nie tylko energooszczędne rozwiązania, ale także taras w części ogrodowej oraz loggia nad garażem, które umożliwią relaks na świeżym powietrzu.";s:21:"alternate_description";N;s:5:"price";s:7:"4899.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:635:"{"1":{"name":"pow. u\u017cytkowa","value":127.6,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":124.9,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":19.6,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":20.45,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":5,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":35,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":7.83,"unit":"m"},"17":{"name":"pow. netto poddasza","value":98.95,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"393000","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-10 11:10:11";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 25 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:213:"{"thumbnail":"1164\/fado-iv-wizualizacja-200-5954f4353ec02.jpg","templateId":"3","features":["10","9"],"price_other_type":null,"skeleton_disabled":null,"isbn":"978-83-7937-304-8","isbn_mirror":"978-83-7937-301-7"}";}i:1005;a:22:{s:2:"id";i:1162;s:6:"id_old";i:1162;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:1019;s:4:"name";s:8:"Remik VI";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:117:"Niewielki, parterowy dom z klasycznym dwuspadowym dachem, tani w budowie i eksploatacji, bez garażu i podpiwniczenia";s:11:"description";s:857:"Prosty, funkcjonalny dom parterowy, przykryty dwuspadowym dachem. Uwagę zwracają dwa podcienia, tworzące funkcjonalne zadaszenie wejścia do budynku oraz klimatyczny taras na elewacji ogrodowej. W Remiku VI obowiązuje wyraźny podział na część dzienną i nocną. Strefa sypialna została zlokalizowana w szerszym skrzydle i obejmuje trzy pokoje. W pozostałej części znajduje się pokój dzienny z aneksem kuchennym oraz łazienka, kotłownia, garderoba i przedsionek. Niewątpliwym atutem jest jeden komin, w którym zaprojektowano wszystkie niezbędne kanały spalinowe i wentylacyjne. Prostota bryły gwarantuje również niewysokie koszty budowy i eksploatacji. Na jednej ze ścian bocznych nie ma okien i drzwi, co umożliwia lokalizację budynku bliżej granicy działki. Remik VI będzie wygodnym lokum dla trzy- lub czteroosobowej rodziny.";s:21:"alternate_description";N;s:5:"price";s:7:"4199.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:633:"{"1":{"name":"pow. u\u017cytkowa","value":78.3,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":112.9,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":18.08,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":18.7,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":4,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":40,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":8.26,"unit":"m"},"17":{"name":"pow. netto poddasza","value":null,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"198021","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-02-23 15:35:46";s:10:"technology";s:156:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:269:"{"garages":["37","155","322","323","511","652","701","829"],"thumbnail":"1162\/remik-vi-wizualizacja-200-5954f44b354ba.jpg","templateId":"1","price_other_type":null,"skeleton_disabled":null,"isbn":"978-83-7937-070-2","isbn_mirror":"978-83-7937-071-9","features":["38"]}";}i:1006;a:22:{s:2:"id";i:1165;s:6:"id_old";i:1165;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:1009;s:4:"name";s:8:"Amber IX";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:74:"Dom parterowy z kotłownią na paliwo stałe, bez garażu i podpiwniczenia";s:11:"description";s:557:"Idealna propozycja dla inwestorów pragnących mieszkać w parterowym domu o dość wysokim kącie nachylenia dachu który często dyktują lokalne warunki zabudowy. Kuchenne okna wychodzące od frontu pozwolą obserwować okolicę w trakcie codziennych obowiązków, a szeroki, komfortowy taras z tyłu domu zapewni wypoczynek w bliskim kontakcie z naturą. Na uwagę zasługuje także strefa sypialna wraz z łazienką, która została oddzielona od reszty domu niewielkim korytarzem. Projekt posiada dodatkowe wyjście przez kotłownię na paliwo stałe.";s:21:"alternate_description";N;s:5:"price";s:7:"4599.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:636:"{"1":{"name":"pow. u\u017cytkowa","value":106.55,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":133.8,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":19.63,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":20.73,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":4,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":35,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":6.88,"unit":"m"},"17":{"name":"pow. netto poddasza","value":null,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"269465","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-02-26 11:57:01";s:10:"technology";s:156:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:219:"{"features":["1","36","38"],"thumbnail":"1165\/amber-ix-wizualizacja-200-5954f4529683d.jpg","templateId":"1","isbn":"978-83-7937-034-4","isbn_mirror":"978-83-7937-035-1","price_other_type":null,"skeleton_disabled":null}";}i:1007;a:22:{s:2:"id";i:1029;s:6:"id_old";i:1029;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:916;s:4:"name";s:9:"Jupiter X";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:138:"Dom parterowy z poddaszem użytkowym i 2-stanowiskowym garażem, z przestronnym, niezadaszonym tarasem, z rekuperacją, w standardzie NF40";s:11:"description";s:525:"Energooszczędny dom dla cztero- lub pięcioosobowej rodziny. Sypialnia rodziców na poddaszu to prawdziwa oaza spokoju z własną łazienką i garderobą. Pozostałe dwie przestronne sypialnie mają dostęp do dużej i wygodnej łazienki na korytarzu. Dodatkowe miejsce gwarantuje wykorzystanie przestrzeni nad dwustanowiskowym garażem – zaprojektowany w ten sposób strych można zaadaptować wedle własnych upodobań. Parter to funkcjonalna i wygodna strefa dzienna powiększona o rozległy taras w części ogrodowej.";s:21:"alternate_description";N;s:5:"price";s:7:"5999.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:635:"{"1":{"name":"pow. u\u017cytkowa","value":162.7,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":169.4,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":23.75,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":19.6,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":5,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":35,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":9.05,"unit":"m"},"17":{"name":"pow. netto poddasza","value":129.2,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"504414","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-02-27 12:23:14";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:235:"{"features":["2","3"],"thumbnail":"1029\/jupiter-x-wizualizacja-200-5954f45ed770c.jpg","templateId":"3","price_other_type":null,"skeleton_disabled":null,"isbn":"978-83-7559-921-3","isbn_mirror":"978-83-7559-925-1","sun_ratio":"0.0168"}";}i:1008;a:22:{s:2:"id";i:1033;s:6:"id_old";i:1033;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:904;s:4:"name";s:7:"Samba X";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:119:"Parterowy dom z poddaszem użytkowym, przeszklonym ryzalitem, z 4 sypialniami i 2-stanowiskowym garażem, podpiwniczony";s:11:"description";s:557:"Wysunięty przed bryłę dwustanowiskowy garaż został poszerzony o osłaniającą wejście wiatę wspartą na filarach. Wspólna strefa dzienna to umieszczony częściowo w przeszklonym ryzalicie pokój dzienny z kominkiem oraz oddzielona od niego ściankami strefa kuchenno-jadalna. Sporo możliwości otwiera także podpiwniczenie całości domu. Poza pomieszczeniami przeznaczonymi do aranżacji lub na cele gospodarcze, znalazła się w nim spora pralnia z suszarnią oraz sauna, która doskonale poprawia samopoczucie i korzystnie wpływa na zdrowie.";s:21:"alternate_description";N;s:5:"price";s:7:"5499.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:616:"{"1":{"name":"pow. u\u017cytkowa","value":"128,85","unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":"148,35","unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":"18,2","unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":"24,39","unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":"6","unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":"40","unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":"8,14","unit":"m"},"17":{"name":"pow. netto poddasza","value":"69,45","unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"553285","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-10 15:21:20";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:208:"{"features":["2"],"thumbnail":"1033\/samba-x-wizualizacja-200-5954f465e1f86.jpg","templateId":"3","isbn":"978-83-7559-924-4","isbn_mirror":"978-83-7559-928-2","price_other_type":null,"skeleton_disabled":null}";}i:1009;a:22:{s:2:"id";i:1049;s:6:"id_old";i:1049;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:889;s:4:"name";s:16:"Słodka Zosia SP";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:120:"Dom parterowy z poddaszem użytkowym, z 4 sypialniami i niezadaszonym tarasem, z gankiem, z kotłownią na paliwo stałe";s:11:"description";s:533:"Jednorodzinny dom z przestronnym poddaszem użytkowym, na którym zaprojektowano strefę sypialną z czterema pokojami i komfortową łazienką. Parter z obszerną strefą dzienną łączącą kuchnię, jadalnię i salon będzie reprezentacyjną częścią domu, do której z przyjemnością zaprosimy rodzinę i przyjaciół. Bardziej intymną atmosferę oferuje zaciszny gabinet oddzielony od pozostałych pomieszczeń hallem z komunikacją. Atutem budynku jest duża kotłownia, w której przewidziano ogrzewanie na paliwo stałe.";s:21:"alternate_description";N;s:5:"price";s:7:"4699.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:634:"{"1":{"name":"pow. u\u017cytkowa","value":117.5,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":94.75,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":18.36,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":18.78,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":6,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":45,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":8.7,"unit":"m"},"17":{"name":"pow. netto poddasza","value":68.4,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"328178","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-13 14:21:52";s:10:"technology";s:156:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:279:"{"garages":["34","35","509","510","545","546","593","606"],"features":["1","36"],"thumbnail":"1049\/slodka-zosia-sp-wizualizacja-200-5954eb8fee4ab.jpg","templateId":"3","isbn":"978-83-7559-807-0","isbn_mirror":"978-83-7559-811-7","price_other_type":null,"skeleton_disabled":null}";}i:1010;a:22:{s:2:"id";i:1282;s:6:"id_old";i:1282;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:9990737;s:4:"name";s:20:"Chata Pod Jaworem SZ";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:57:"Szkieletowy dom z poddaszem użytkowym w stylu beskidzkim";s:11:"description";s:629:"Regionalny dom beskidzki w stylu góralskim świetnie nadający się do realizacji w technologii szkieletowej. Posiada ciekawie zaakcentowane, zadaszone wejście, taras wypoczynkowy i charakterystyczny ryzalit z jadalnią. Na parterze oprócz wspomnianej jadalni znajduje się duży salon z kominkiem, kuchnia, łazienka i kotłownia. Na poddaszu zaprojektowano strefę wypoczynkową z trzema sypialniami i drugą łazienką. Oryginalna forma dachu, wspomniany ryzalit i zadaszone wejście, balkony i taras tworzą uroczą propozycję dla wszystkich miłośników architektury regionalnej, w szczególności terenów górzystych.";s:21:"alternate_description";N;s:5:"price";s:7:"4799.00";s:8:"discount";s:4:"0.00";s:4:"type";s:8:"skeleton";s:6:"status";s:9:"published";s:14:"params_general";s:615:"{"1":{"name":"pow. u\u017cytkowa","value":"107,5","unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":"92,75","unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":"20,79","unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":"17,38","unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":"4","unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":"40","unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":"7,87","unit":"m"},"17":{"name":"pow. netto poddasza","value":"67,25","unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"300248","self":null}";s:10:"meta_title";s:76:"Chata Pod Jaworem SZ. Szkieletowy dom z poddaszem użytkowym - Studio Atrium";s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-02-25 13:11:38";s:10:"technology";s:184:"Ściany w szkielecie drewnianym + ocieplenie z wełny mineralnej + płyty OSB + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:294:"{"thumbnail":"1282\/chata-pod-jaworem-sz-wizualizacja-200-5954fd4d2751c.jpg","templateId":"3","linkedProjects":["770"],"price_other_type":null,"skeleton_disabled":null,"isbn":"978-83-7937-848-7","isbn_mirror":"978-83-7937-849-4","wooddom":"520000","doomyprice1":"264524","doomyprice2":"683589"}";}i:1011;a:22:{s:2:"id";i:903;s:6:"id_old";i:903;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:856;s:4:"name";s:4:"Tuba";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:107:"Okrągły dom piętrowy z kopertowym dachem, nieszablonowe wnętrza, przestronny otwarty taras wypoczynkowy";s:11:"description";s:649:"Niezwykły dom zaprojektowany na planie koła, nakryty dachem namiotowym z szerokimi okapami wspartymi na czterech filarach. Podział pomieszczeń zaplanowano w oparciu o promienie okręgu, tworząc uporządkowaną i czytelną przestrzeń. Parter obejmuje kuchnię, spiżarnię, jadalnię, pokój dzienny gabinet i łazienkę. Duża powierzchnia przeszkolona zapewnia dobre nasłonecznienie wnętrza i otwarcie go na otaczającą budynek zieleń ogrodu. Piętro mieści sypialnie rodziców z garderobą, dwie dodatkowe sypialnie, łazienkę i ogólnodostępną garderobę. Oryginalna propozycja dla Inwestorów lubiących nieszablonowe rozwiązania.";s:21:"alternate_description";N;s:5:"price";s:8:"11399.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:637:"{"1":{"name":"pow. u\u017cytkowa","value":165.65,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":132.8,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":20.24,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":20.24,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":5,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":30,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":9.97,"unit":"m"},"17":{"name":"pow. netto poddasza","value":null,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":81.85,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"426217","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-13 15:04:58";s:10:"technology";s:387:"Technologia murowana: ściany w systemie YTONG Energo (parter pustak 48 cm + 24 cm wełny mineralnej, poddasze pustak 24cm + 24 cm wełny mineralnej). Podłoga na parterze docieplona wełną mineralną o grubości 20 cm. Strop piętra docieplony wełną mineralną 40cm. Pokrycie dachu: dachówka Braas. Ogrzewanie budynku pompą ciepła z rekuperacją. Drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:222:"{"garages":["1075"],"thumbnail":"903\/tuba-wizualizacja-200-5954eb9fbd9b2.jpg","templateId":"2","isbn":"978-83-7559-832-2","isbn_mirror":"978-83-7559-836-0","cost":"662240","price_other_type":null,"skeleton_disabled":null}";}i:1012;a:22:{s:2:"id";i:1024;s:6:"id_old";i:1024;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:846;s:4:"name";s:10:"Samba VIII";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:127:"Parterowy dom z poddaszem użytkowym, z garażem 2-stanowiskowym i 4 sypialniami, z kotłownią na paliwo stałe, podpiwniczony";s:11:"description";s:389:"Wnętrze domu to praktycznie zorganizowana przestrzeń – wnęka na drewno za kominkiem, przechodnia spiżarka w pobliżu kuchni, otwarta kompozycja strefy dziennej czy dodatkowa łazienka na parterze podnoszą funkcjonalność domu i uprzyjemniają jego użytkowanie. Na poddaszu wsparty na kolumnach wykusz z przeszkloną ścianą zapewni piękny widok na okolicę z głównej sypialni.";s:21:"alternate_description";N;s:5:"price";s:7:"5499.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:615:"{"1":{"name":"pow. u\u017cytkowa","value":"129,45","unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":"174,7","unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":"23,25","unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":"19,2","unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":"6","unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":"40","unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":"7,93","unit":"m"},"17":{"name":"pow. netto poddasza","value":"79,85","unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"515803","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-10 15:20:09";s:10:"technology";s:227:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: część mieszkalna - dachówka Braas, garaż - papa termozgrzewalna. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:237:"{"features":["1","36"],"thumbnail":"1024\/samba-viii-wizualizacja-200-69cbaa1964c79.jpg","templateId":"3","isbn":"978-83-7559-763-9","isbn_mirror":"978-83-7559-767-7","price_other_type":null,"skeleton_disabled":null,"sun_ratio":"0.0160"}";}i:1013;a:22:{s:2:"id";i:872;s:6:"id_old";i:872;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:810;s:4:"name";s:13:"Poziomka Plus";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:98:"Dom parterowy z poddaszem użytkowym i garażem, z gankiem i przeszklonym ryzalitem, podpiwniczony";s:11:"description";s:655:"Prosty w konstrukcji dom z użytkowym poddaszem i piwnicą, w której poza kotłownią znajdują się jeszcze dwa pomieszczenia do zagospodarowania. Sercem parteru jest wspólna przestrzeń dzienna, obejmująca kuchnię, jadalnię i pokój dzienny, w którym zaprojektowano kominek.  Dodatkowy pokój może służyć  jako gabinet lub sypialnia. Poddasze zawiera trzy sypialnie, w tym dwie z dostępem  do balkonu, oraz łazienkę. Do bryły budynku doprojektowano garaż z pomieszczeniem gospodarczym. Jasna kolorystyka elewacji tworzy przyjemny obraz małego, sielskiego domu za miastem. Poziomka Plus będzie wygodnym lokum dla  czteroosobowej rodziny.";s:21:"alternate_description";N;s:5:"price";s:7:"5399.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:635:"{"1":{"name":"pow. u\u017cytkowa","value":113.1,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":119.5,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":19.35,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":19.65,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":5,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":45,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":8.62,"unit":"m"},"17":{"name":"pow. netto poddasza","value":61.3,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"464083","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-11 16:40:47";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:214:"{"features":["10"],"thumbnail":"872\/poziomka-plus-wizualizacja-200-5954ebb883131.jpg","templateId":"3","isbn":"978-83-7559-772-1","isbn_mirror":"978-83-7559-776-9","price_other_type":null,"skeleton_disabled":null}";}i:1014;a:22:{s:2:"id";i:707;s:6:"id_old";i:707;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:656;s:4:"name";s:9:"Fortunata";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:84:"Dom parterowy z poddaszem użytkowym, z 4 sypialniami, garażem i rozległym tarasem";s:11:"description";s:427:"Klasyczna, nakryta dwuspadowym dachem bryła pełna funkcjonalnych rozwiązań. Panoramiczne okna przestrzeni dziennej ogrzewają i rozjaśniają wnętrze, jednocześnie optycznie powiększając przestrzeń i ułatwiając kontakt z otaczającą dom przestrzenią. Poddasze to aż cztery sporych rozmiarów sypialnie, łazienka oraz garderoba. Dodatkowy pokój, który można zaaranżować na gabinet, znajduje się na parterze.";s:21:"alternate_description";N;s:5:"price";s:7:"5599.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:632:"{"1":{"name":"pow. u\u017cytkowa","value":162.2,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":133.75,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u01