0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:612:"{"1":{"name":"pow. u\u017cytkowa","value":"45,95","unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":"42,2","unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":"15,05","unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":"14,3","unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":"3","unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":"45","unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":"6,93","unit":"m"},"17":{"name":"pow. netto poddasza","value":"28,8","unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"128338","self":null}";s:10:"meta_title";s:87:"Bajka. Mały dom z poddaszem użytkowym z lukarną, na wąską działkę. Studio Atrium";s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-09 13:50:19";s:10:"technology";s:156:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:270:"{"garages":["34","35","509","510","540","545","546","593","606"],"thumbnail":"296\/bajka-wizualizacja-200-5954d42ae3f5d.jpg","templateId":"3","isbn":"978-83-7356-384-1","isbn_mirror":"978-83-7356-389-6","price_other_type":null,"skeleton_disabled":null,"features":["47"]}";}i:781;a:22:{s:2:"id";i:954;s:6:"id_old";i:954;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:926;s:4:"name";s:8:"Vesta II";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:92:"Dom parterowy z poddaszem użytkowym i kotłownią na paliwo stałe, z niezadaszonym tarasem";s:11:"description";s:541:"Mały, urokliwy dom z dwuspadowym dachem i dopracowanym detalem wykończeniowym. Połączenie jasnego koloru elewacji z ciemną dachówką i ozdobną cegłą nadało tej prostej bryle oryginalnego charakteru. Dopełnieniem są przypory w narożach budynku. Parter to strefa dzienna, w której poza kuchnią i salonem zaprojektowano wygodny przedsionek, w.c. i dużą kotłownię, przeznaczoną na montaż pieca na paliwo stałe. Poddasze mieści trzy sypialnie i dużą łazienkę. Vesta II będzie wygodnym lokum dla czteroosobowej rodziny.";s:21:"alternate_description";N;s:5:"price";s:7:"4599.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:632:"{"1":{"name":"pow. u\u017cytkowa","value":100.1,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":88,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":17.34,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":18.06,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":4,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":42,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":8.41,"unit":"m"},"17":{"name":"pow. netto poddasza","value":58.8,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"279579","self":null}";s:10:"meta_title";s:82:"Vesta II. Dom z poddaszem użytkowym i kotłownią na paliwo stałe. Studio Atrium";s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-13 15:17:34";s:10:"technology";s:156:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:282:"{"garages":["34","35","509","510","540","545","546","593","606"],"features":["1","36","21"],"thumbnail":"954\/vesta-ii-wizualizacja-200-5954f1c04afed.jpg","templateId":"3","isbn":"978-83-7559-909-2","isbn_mirror":"978-83-7559-906-0","price_other_type":null,"skeleton_disabled":null}";}i:782;a:22:{s:2:"id";i:938;s:6:"id_old";i:938;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:874;s:4:"name";s:5:"Miami";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:106:"Rozległy parterowy dom z dwoma niezależnymi lokalami, przestronnym tarasem oraz garażem 2-stanowiskowym";s:11:"description";s:738:"Miami to propozycja dla wymagających inwestorów posiadających rozległą działkę, pragnących mieszkać razem i jednocześnie osobno. Dwa niezależne wejścia do budynku oraz odpowiedni dla dwóch lokali układ pomieszczeń, pozwalający rozdzielić obie strefy jako niezależne, stanowią idealne rozwiązanie dla osób szukających właśnie takiej przestrzeni do zamieszkania. Pod względem architektonicznym budynek kojarzy się z rozłożystym bungalowem, w którym wygoda to atut numer jeden. Z nowinek instalacyjnych przewidziano w tym domu rekuperację i pompę ciepła. Stylistycznie wpisuje się najlepiej w podmiejski krajobraz, gdzie jest więcej otwartej przestrzeni oraz tak bardzo poszukiwanej w naszych czasach ciszy.";s:21:"alternate_description";N;s:5:"price";s:7:"6999.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:636:"{"1":{"name":"pow. u\u017cytkowa","value":253.4,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":413.15,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":40.25,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":32.95,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":7,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":30,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":6.83,"unit":"m"},"17":{"name":"pow. netto poddasza","value":null,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"713730","self":null}";s:10:"meta_title";s:81:"Miami. Rozległy parterowy dom z niezależnymi lokalami i garażem. Studio Atrium";s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-11 13:52:49";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:210:"{"features":["2","16"],"thumbnail":"938\/miami-wizualizacja-200-5954e7a89ac5f.jpg","templateId":"1","isbn":"978-83-7559-885-8","isbn_mirror":"978-83-7559-889-6","price_other_type":null,"skeleton_disabled":null}";}i:783;a:22:{s:2:"id";i:816;s:6:"id_old";i:816;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:759;s:4:"name";s:5:"Vista";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:90:"Nowoczesny dom parterowy z płaskim dachem, odkrytym tarasem wypoczynkowym oraz z garażem";s:11:"description";s:577:"Oryginalny miks intensywnego pomarańczu oraz drewnianych elementów elewacji robi wrażenie, zwłaszcza że doskonale koresponduje z prostą, nakrytą płaskim dachem bryłą budynku. Współczesna, klarowna forma jest zwiastunem komfortowego i dobrze skomunikowanego wnętrza, w którym znajdziemy otwartą przestrzeń dzienną z wyjściem na rozległy taras oraz strefę sypialną z dwoma obszernymi pokojami i łazienką. Całość uzupełnia praktyczny przedsionek z kotłownią, która poza piecem na gaz mieści również pralkę oraz wkomponowany w bryłę domu garaż.";s:21:"alternate_description";N;s:5:"price";s:7:"4599.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:636:"{"1":{"name":"pow. u\u017cytkowa","value":80.25,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":141.65,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":24.5,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":17.2,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":3,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":null,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\