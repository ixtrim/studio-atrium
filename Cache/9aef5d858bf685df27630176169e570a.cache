07 dzia\u0142ki","value":20.75,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":18.85,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":6,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":40,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":8.4,"unit":"m"},"17":{"name":"pow. netto poddasza","value":83.7,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"404514","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-09 14:12:34";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:190:"{"thumbnail":"717\/bellus-wizualizacja-200-5954ee0eb96bc.jpg","templateId":"3","isbn":"978-83-7559-319-8 ","isbn_mirror":"978-83-7559-323-5","price_other_type":null,"skeleton_disabled":null}";}i:1132;a:22:{s:2:"id";i:718;s:6:"id_old";i:718;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:659;s:4:"name";s:9:"Stella II";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:118:"Dom parterowy z poddaszem użytkowym i 2-stanowiskowym garażem, z 4 sypialniami i przestronnym, odsłoniętym tarasem";s:11:"description";s:430:"Swój nowoczesny wygląd projekt zawdzięcza krytemu blachą dachowi bez okapów oraz oszczędną w detalach elewacją w stonowanej kolorystyce. Duże, efektowne przeszklenia otwierają wnętrze na piękno otaczającej dom natury, tworząc atmosferę relaksu i wyciszenia. Zmotoryzowanych z pewnością przekona dwustanowiskowy garaż z bezpośrednim przejściem do wnętrza domu. Dom z powodzeniem wpisze się w wąskie działki.";s:21:"alternate_description";N;s:5:"price";s:7:"5599.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:633:"{"1":{"name":"pow. u\u017cytkowa","value":174.25,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":163.25,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":19,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":24.25,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":5,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":40,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":8.61,"unit":"m"},"17":{"name":"pow. netto poddasza","value":123,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"537206","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-13 14:00:36";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:193:"{"thumbnail":"718\/stella-ii-wizualizacja-200-5954ee16371c6.jpg","templateId":"3","isbn":"978-83-7559-371-6","isbn_mirror":"978-83-7559-374-7 ","price_other_type":null,"skeleton_disabled":null}";}i:1133;a:22:{s:2:"id";i:724;s:6:"id_old";i:724;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:638;s:4:"name";s:4:"Navi";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:111:"Parterowy dom z poddaszem użytkowym, garażem i 4 sypialniami, z dwuspadowym dachem i lukarnami, podpiwniczony";s:11:"description";s:602:"Oryginalny front budynku z przeszkloną lukarną, która jednocześnie stanowi zadaszenie wejścia, z pewnością wyróżni projekt spośród wielu innych. Dzięki takiemu rozwiązaniu jedna z sypialni zyskuje wiele światła i korzystny widok na okolicę. Pozostałe 3 pokoje na poddaszu doświetlają mniejsze lukarny od strony ogrodowej oraz okna szczytowe. Na parterze mieści się otwarta przestrzeń dzienna, a także dodatkowy pokój mogący pełnić funkcję gabinetu. Część mieszkalna budynku została całkowicie podpiwniczona, jedynie pod częścią garażową nie zaprojektowano piwnicy.";s:21:"alternate_description";N;s:5:"price";s:7:"5499.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:635:"{"1":{"name":"pow. u\u017cytkowa","value":122.8,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":118.9,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":22.05,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":18.35,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":6,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":45,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":8.61,"unit":"m"},"17":{"name":"pow. netto poddasza","value":83.1,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"492057","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-11 15:40:32";s:10:"technology";s:221:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas, blacha tytanowo-cynkowa (wykusz oraz lukarny). Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:206:"{"features":["10"],"thumbnail":"724\/navi-wizualizacja-200-5954ee27d338f.jpg","templateId":"3","isbn":"978-83-7559-301-3","isbn_mirror":"978-83-7559-305-1 ","price_other_type":null,"skeleton_disabled":null}";}i:1134;a:22:{s:2:"id";i:657;s:6:"id_old";i:657;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:422;s:4:"name";s:7:"Top Dom";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:283:"Budynek mieszkalny, wielorodzinny, z sześcioma mieszkaniami, o czterech kondygnacjach nadziemnych, podpiwniczony, z 6 garażami
<p style='margin-top: 10px;'><strong>Uwaga! W związku ze zmianą przepisów, układ funkcjonalny wnętrz i powierzchnie mogą ulec zmianie.</strong></p>";s:11:"description";s:570:"Wielorodzinny budynek z poddaszem użytkowym i podpiwniczeniem, w którym stosownie do ilości lokali mieszkalnych zaprojektowano sześć miejsc garażowych. Parter i pierwsze piętro obejmują po dwa mieszkania, zawierające otwartą strefę dzienną oraz dwie sypialnie. Drugie piętro i poddasze przeznaczono na obszerne, dwupoziomowe lokale o powierzchni  140 m2 każdy. Komunikację miedzy piwnicą a parterem, poza klatką schodową zapewnia praktyczna winda. Lokalizacja pokoju dziennego sprawia że budynek ten świetnie sprawdzi się na działkach od południa.";s:21:"alternate_description";N;s:5:"price";s:8:"18999.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:657:"{"1":{"name":"pow. u\u017cytkowa","value":"608,7","unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":"234,05","unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":"35,7","unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":"31,65","unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":"10","unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":"30","unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":"15,1","unit":"m"},"17":{"name":"pow. netto poddasza","value":"144,2","unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":"186,45","unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:97:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"1572881","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-13 14:56:47";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:168:"{"thumbnail":"657\/top-dom-wizualizacja-200-5954e2553920e.jpg","templateId":"6","price_other_type":null,"skeleton_disabled":null,"cost":"-1","isbn":"978-83-7356-670-5"}";}i:1135;a:22:{s:2:"id";i:695;s:6:"id_old";i:695;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:636;s:4:"name";s:5:"Korab";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:103:"Dom parterowy z poddaszem użytkowym, z lukarnami w części ogrodowej, 4 sypialniami i dwoma garażami";s:11:"description";s:694:"Parterowy dom jednorodzinny z poddaszem użytkowym. Klasyczna bryła zwraca uwagę oryginalną kolorystyką stolarki okiennej i drzwiowej, a także symetrycznie zaprojektowanym frontem z dwoma garażami po bokach. Parter budynku został przystosowany dla osób niepełnosprawnych i starszych, podjazdy do drzwi wejściowych i tarasowych oraz przestronne pomieszczenia ułatwią poruszanie się wewnątrz i wokół domu. W programie parteru zaprojektowane w otwartej przestrzeni kuchnia, jadalnia i salon, a także  sypialnia, łazienka oraz duża kotłownia. Poddasze to komfortowa strefa nocna z trzema sypialniami, w tym jedną z własną łazienką i przechodnią garderobą, oraz łazienka.";s:21:"alternate_description";N;s:5:"price";s:7:"5399.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:627:"{"1":{"name":"pow. u\u017cytkowa","value":141.1,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":169.3,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":24,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":26,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":5,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":45,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":8.15,"unit":"m"},"17":{"name":"pow. netto poddasza","value":86,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"372081","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-10 15:32:15";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:188:"{"thumbnail":"695\/korab-wizualizacja-200-5954ee36c4fac.jpg","templateId":"3","isbn":"978-83-7559-384-6","isbn_mirror":"978-83-7559-388-4","price_other_type":null,"skeleton_disabled":null}";}i:1136;a:22:{s:2:"id";i:997;s:6:"id_old";i:997;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:1010;s:4:"name";s:10:"Credo Plus";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:99:"Niewielki, parterowy dom z dwuspadowym dachem i poddaszem użytkowym, z odkrytym tarasem i garażem";s:11:"description";s:401:"Mały dom jednorodzinny z poddaszem użytkowym i garażem będzie świetnym wyborem dla poszukujących powierzchni do 100 m2. Prostą bryłę nakrytą dwuspadowym dachem urozmaica niewielki, otoczony murkiem ganek we frontowej części budynku. Wnętrze mieści m.in. duży pokój dzienny, w którym znajdzie się sporo miejsca na rodzinny stół oraz strefę nocną z trzema sypialniami i łazienką.";s:21:"alternate_description";N;s:5:"price";s:7:"4399.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:636:"{"1":{"name":"pow. u\u017cytkowa","value":99.85,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":108.05,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":19.7,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":18.35,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":4,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":45,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":9.22,"unit":"m"},"17":{"name":"pow. netto poddasza","value":73.85,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"328290","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-09 15:30:49";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:193:"{"thumbnail":"997\/credo-plus-wizualizacja-200-5954f50fcd936.jpg","templateId":"3","isbn":"978-83-7937-038-2","isbn_mirror":"978-83-7937-039-9","price_other_type":null,"skeleton_disabled":null}";}i:1137;a:22:{s:2:"id";i:26;s:6:"id_old";i:26;s:12:"symbol_alpha";s:3:"GLX";s:10:"symbol_num";i:28;s:4:"name";s:6:"Kacper";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:106:"Dom parterowy z możliwością adaptacji poddasza, z gankiem i kolumnami, z częściowo zadaszonym tarasem";s:11:"description";s:540:"W tym parterowym domu wygodnie zamieszka czteroosobowa rodzina. Powierzchnię mieszkalną wyraźnie rozdzielono na dużą i przestronną strefę dzienną oraz mniejszą i bardziej przytulną część sypialną z trzema niezależnymi pokojami. Połączony z jadalnią pokój dzienny będzie doskonałym miejscem wspólnie spędzanego czasu, także w chłodne wieczory, dzięki ciepłu znajdującego się w nim kominka. Łącznikiem wnętrza z otaczającą budynek zielenią ogrodu będzie niewielki, częściowo zadaszony taras z tyłu domu.";s:21:"alternate_description";N;s:5:"price";s:7:"4699.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:631:"{"1":{"name":"pow. u\u017cytkowa","value":114.7,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":154,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":21.2,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":22.08,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":4,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":40,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":8.1,"unit":"m"},"17":{"name":"pow. netto poddasza","value":null,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"290076","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-10 13:49:24";s:10:"technology";s:156:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:227:"{"garages":["30","33","36","506","508"],"thumbnail":"26\/kacper-wizualizacja-200-5954d66d82bf6.jpg","templateId":"1","isbn":"978-83-89103-54-3","isbn_mirror":"978-83-7356-139-7","price_other_type":null,"skeleton_disabled":null}";}i:1138;a:22:{s:2:"id";i:615;s:6:"id_old";i:615;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:530;s:4:"name";s:7:"Karolek";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:129:"Mały domek z poddaszem użytkowym, z lukarną i balkonem nad odkrytym tarasem, z garażem w podpiwniczeniu, na wąską działkę";s:11:"description";s:583:"Spełnienie marzeń o przytulnym i funkcjonalnym domu o powierzchni do 100 m2. Klasyczną bryłę urozmaica oryginalna, nakryta płaskim zadaszeniem lukarna, która nawiązuje do nowoczesnych trendów w budownictwie. Wnętrze, mimo niewielkiej powierzchni użytkowej, wygodnie pomieści nawet pięcioosobową rodzinę, dzięki dodatkowemu pokojowi na parterze oraz dwóm komfortowym łazienkom. W podpiwniczeniu zaprojektowano duży, jednostanowiskowy garaż, sporą kotłownię oraz niewielki schowek. Nieduże gabaryty budynku czynią go doskonałym projektem na wąską działkę.";s:21:"alternate_description";N;s:5:"price";s:7:"4899.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:610:"{"1":{"name":"pow. u\u017cytkowa","value":"89","unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":"80,6","unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":"16,3","unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":"22,35","unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":"5","unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":"45","unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":"8,77","unit":"m"},"17":{"name":"pow. netto poddasza","value":"49,95","unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"346577","self":null}";s:10:"meta_title";s:74:"Karolek. Niewielki podpiwniczony dom z poddaszem użytkowym. Studio Atrium";s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-10 14:10:02";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:208:"{"features":["10"],"thumbnail":"615\/karolek-wizualizacja-200-5954e06539aa7.jpg","templateId":"3","isbn":"978-83-7559-112-5","isbn_mirror":"978-83-7559-116-3","price_other_type":null,"skeleton_disabled":null}";}i:1139;a:22:{s:2:"id";i:602;s:6:"id_old";i:602;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:550;s:4:"name";s:9:"Adela Bis";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:126:"Podpiwniczony dom parterowy z poddaszem użytkowym i garażem, z niewielkim gankiem frontowym i lukarnami w części ogrodowej";s:11:"description";s:819:"Mały dom jednorodzinny wyraźnie podzielony na strefę dzienną, która otwartymi przestrzeniami parteru zachęca do wspólnego spędzania czasu oraz strefę wypoczynku znajdującą się na poddaszu. Parter oferuje domownikom duży salon z kominkiem połączony z jadalnią i kuchnią oraz dodatkowy pokój, który świetnie sprawdzi się jako gościnny lub gabinet. Atutem jest również jednostanowiskowy garaż skomunikowany z częścią mieszkalną specjalnym łącznikiem. Na poddaszu znajdziemy trzy przestronne sypialnie oraz dużą łazienkę i garderobę, które  zagwarantują komfort czteroosobowej rodzinie. Podpiwniczenie generuje dodatkowe miejsce na pomieszczenia gospodarcze, w tym sporą kotłownię z piecem gazowym, w  której po pewnych modyfikacjach może zafunkcjonować kocioł na paliwo stałe.";s:21:"alternate_description";N;s:5:"price";s:7:"5099.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:637:"{"1":{"name":"pow. u\u017cytkowa","value":112.95,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":110.5,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":20.95,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":17.25,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":5,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":45,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":8.55,"unit":"m"},"17":{"name":"pow. netto poddasza","value":78.45,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"458988","self":null}";s:10:"meta_title";s:77:"Adela Bis. Podpiwniczony dom z poddaszem, garażem i lukarnami. Studio Atrium";s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-02-27 12:58:41";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:215:"{"features":["10","28"],"thumbnail":"602\/adela-bis-wizualizacja-200-5b051bf74614f.jpg","templateId":"3","isbn":"978-83-7559-114-9","isbn_mirror":"978-83-7559-118-7","price_other_type":null,"skeleton_disabled":null}";}i:1140;a:22:{s:2:"id";i:536;s:6:"id_old";i:536;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:485;s:4:"name";s:5:"Omega";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:80:"Dom parterowy z poddaszem użytkowym i garażem, z klasycznym dwuspadowym dachem";s:11:"description";s:534:"Intryguje niebanalną formą, zwieńczoną dwuspadowym dachem i kamiennymi przyporami na elewacji. Całość utrzymana jest w ciepłych, naturalnych barwach, nawiązujących m. in. do piaskowca. Ciekawym rozwiązaniem jest uwzględnienie na poddaszu tzw. zaplecza – miejsca, które można przeznaczyć na pralnię, suszarnię lub prasowalnię, w zależności od potrzeb. Niewątpliwą zaletą projektu jest relatywnie niski koszt inwestycji oraz użytkowania. Omega będzie wygodnym lokum dla cztero a nawet pięcioosobowej rodziny.";s:21:"alternate_description";N;s:5:"price";s:7:"4799.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:543:"{"1":{"name":"pow. u\u017cytkowa","value":"113,4","unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":"20,8","unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":"18,05","unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":"5","unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":"42","unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":"8,41","unit":"m"},"17":{"name":"pow. netto poddasza","value":"73,6","unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"350724","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-11 15:55:42";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:188:"{"thumbnail":"536\/omega-wizualizacja-200-5954df6e09a94.jpg","templateId":"3","isbn":"978-83-7559-048-7","isbn_mirror":"978-83-7559-052-4","price_other_type":null,"skeleton_disabled":null}";}i:1141;a:22:{s:2:"id";i:665;s:6:"id_old";i:665;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:588;s:4:"name";s:9:"Jawor Bis";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:114:"Dom parterowy z poddaszem użytkowym, z lukarną i odsłoniętym tarasem, idealny na wąską działkę, z garażem";s:11:"description";s:514:"Stonowaną kolorystykę i prostą formę projektu urozmaicają drewniane szczyty oraz kamienne wykończenia elewacji i kominów. Użytkowa część mieszkalna została zaprojektowana w tylnej części domu i odizolowana od zgiełku ulicy wbudowanym w bryłę jednostanowiskowym garażem, natomiast w części ogrodowej zaprojektowano rozległy taras, na którym miłe chwile spędzą amatorzy rodzinnych spotkań przy grillu. Prywatną strefę wypoczynku z trzema sypialniami i łazienką przewidziano na poddaszu.";s:21:"alternate_description";N;s:5:"price";s:7:"4899.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:636:"{"1":{"name":"pow. u\u017cytkowa","value":119.95,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":107.15,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":15.8,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":21.95,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":4,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":50,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":8.93,"unit":"m"},"17":{"name":"pow. netto poddasza","value":82.5,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"368084","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-10 13:35:12";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:192:"{"thumbnail":"665\/jawor-bis-wizualizacja-200-5954df9ea712d.jpg","templateId":"3","isbn":"978-83-7559-225-2","isbn_mirror":"978-83-7559-229-0","price_other_type":null,"skeleton_disabled":null}";}i:1142;a:22:{s:2:"id";i:643;s:6:"id_old";i:643;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:586;s:4:"name";s:13:"Fistaszek Bis";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:117:"Dom parterowy z garażem i poddaszem użytkowym, z dwuspadowym dachem, przeszklonym ryzalitem i odsłoniętym tarasem";s:11:"description";s:474:"Prosta, klasyczna bryła z wkomponowanym w całość jednostanowiskowym garażem doskonale wpasuje się zarówno w miejski jak i wiejski krajobraz. Ten projekt to dobre rozwiązanie dla pracujących w domu – poza trzema sypialniami na poddaszu, dom zawiera dodatkowy pokój na parterze, który może posłużyć za biuro lub gabinet. Poza tym przestrzeń dzienna mieści przestronny pokój z kominkiem, jadalnię oraz znajdującą się we frontowej części domu kuchnię.";s:21:"alternate_description";N;s:5:"price";s:7:"4899.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:636:"{"1":{"name":"pow. u\u017cytkowa","value":119.8,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":119.4,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":21.41,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":18.65,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":5,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":40,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":8.12,"unit":"m"},"17":{"name":"pow. netto poddasza","value":79.95,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"367384","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-10 11:47:40";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:214:"{"features":["10"],"thumbnail":"643\/fistaszek-bis-wizualizacja-200-5954dfa792519.jpg","templateId":"3","isbn":"978-83-7559-201-6","isbn_mirror":"978-83-7559-205-4","price_other_type":null,"skeleton_disabled":null}";}i:1143;a:22:{s:2:"id";i:609;s:6:"id_old";i:609;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:553;s:4:"name";s:10:"Panonia II";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:140:"Dom z poddaszem użytkowym - 4 sypialniami, parterowy, z przeszkloną wieżyczką i narożnym tarasem w podcieniu, podpiwniczony, z garażem";s:11:"description";s:748:"Nowa odsłona popularnego projektu Panonia. Paleta kolorystyczna koncentruje się tym razem na chłodnych odcieniach, przede wszystkim bieli i szarości, co nadaje całości bardziej nowoczesny wygląd. Ta wersja została wzbogacona o mocno rozbudowaną część piwniczną, w której znajdują się – oprócz kotłowni i holu – aż cztery pomieszczenia do zagospodarowania. Jadalnia będzie najbardziej słonecznym miejscem w domu, dzięki zlokalizowaniu jej w przeszklonej wieżyczce - ganku. Na poddaszu, pełniącym funkcję sypialną, znajdują się trzy sypialnie wraz z łazienką oraz przestrzeń nad garażem do dowolnej aranżacji. Dom będzie z pewnością komfortowym miejscem do życia dla cztero lub nawet pięcioosobowej rodziny.";s:21:"alternate_description";N;s:5:"price";s:7:"5899.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:613:"{"1":{"name":"pow. u\u017cytkowa","value":"151","unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":"174,65","unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":"20,33","unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":"25,55","unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":"6","unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":"38","unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":"8,5","unit":"m"},"17":{"name":"pow. netto poddasza","value":"128,5","unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"607869","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-11 16:11:26";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:193:"{"thumbnail":"609\/panonia-ii-wizualizacja-200-5954e0225e933.jpg","templateId":"3","isbn":"978-83-7559-138-5","isbn_mirror":"978-83-7559-142-2","price_other_type":null,"skeleton_disabled":null}";}i:1144;a:22:{s:2:"id";i:43;s:6:"id_old";i:43;s:12:"symbol_alpha";s:3:"GLZ";s:10:"symbol_num";i:31;s:4:"name";s:8:"Victoria";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:93:"Dom parterowy z poddaszem użytkowym i garażem, z klasycznym, dwuspadowym dachem i lukarnami";s:11:"description";s:798:"Nieduży, prosty budowie dom o bardzo dobrej funkcji. Piękno tradycyjnej bryły podkreślają urokliwe detale – dwuspadowy dach ozdobiony lukarnami, drewniane okiennice i kamienne przypory.  Połączona z jadalnią kuchnia posiada dostęp do kotłowni, która w tym wypadku może pełnić również funkcję spiżarni. W częściowo oddzielonym od kuchni pokoju dziennym zaprojektowano kominek oraz wyjście na taras. Dodatkowy pokój na parterze sprawdzi się jako gabinet lub pokój gościnny. Ponadto w programie parteru jest przedsionek z szafa wnękową oraz łazienka  z kabiną prysznicową. Na poddaszu mieszczą się trzy sypialnie oraz łazienka z funkcjonalnym zapleczem, które będzie świetnym miejscem na pralnię i suszarnię. Vitoria to optymalny dom dla czteroosobowej rodziny.";s:21:"alternate_description";N;s:5:"price";s:7:"4899.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:637:"{"1":{"name":"pow. u\u017cytkowa","value":122.85,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":129.85,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":19.95,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":18.48,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":5,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":40,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":7.94,"unit":"m"},"17":{"name":"pow. netto poddasza","value":76.7,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"370633","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-13 15:21:26";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:190:"{"thumbnail":"43\/victoria-wizualizacja-200-5954d640f1507.jpg","templateId":"3","isbn":"978-83-87603-45-8","isbn_mirror":"978-83-7356-090-1","price_other_type":null,"skeleton_disabled":null}";}i:1145;a:22:{s:2:"id";i:45;s:6:"id_old";i:45;s:12:"symbol_alpha";s:3:"GLX";s:10:"symbol_num";i:33;s:4:"name";s:15:"Chatka Puchatka";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:86:"Dom parterowy z poddaszem użytkowym i garażem, z przeszklonym ryzalitem, z wykuszami";s:11:"description";s:532:"Ciekawa propozycja wśród domów o powierzchni do 100 m2. Zgrabny budynek nakryty dachem naczółkowym zyskuje wiele uroku dzięki wykuszowi we frontowej części domu oraz niedużej lukarnie na elewacji ogrodowej. Parter budynku to tradycyjna strefa dzienna z kominkiem ustawionym w centrum oraz otwartą kuchnią. Poddasze mieści dwie duże sypialnie (w tym jedną z dostępem do balkonu), wygodną łazienkę oraz doświetlony oknami połaciowymi schowek w przestrzeni nad garażem. Idealna propozycja dla 3-4 osobowej rodziny.";s:21:"alternate_description";N;s:5:"price";s:7:"4599.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:610:"{"1":{"name":"pow. u\u017cytkowa","value":"86,15","unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":"93,8","unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":"21","unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":"16,5","unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":"4","unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":"45","unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":"7,79","unit":"m"},"17":{"name":"pow. netto poddasza","value":"63,65","unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"283993","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-02-25 13:13:42";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:197:"{"thumbnail":"45\/chatka-puchatka-wizualizacja-200-5954d64fc97ee.jpg","templateId":"3","isbn":"978-83-89103-58-1","isbn_mirror":"978-83-7356-100-7","price_other_type":null,"skeleton_disabled":null}";}i:1146;a:22:{s:2:"id";i:1098;s:6:"id_old";i:1098;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:957;s:4:"name";s:11:"Filemon III";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:135:"Mały, tani w budowie dom parterowy z klasycznym dwuspadowym dachem, oryginalnym frontonem wejściowym oraz tarasem na zapleczu budynku";s:11:"description";s:390:"Wypuszczony przed bryłę, ozdobiony frontonem przedsionek nadaje temu małemu domowi dworkowy charakter, który podkreślają także utrzymane w stylistyce okna ze szprosami. Nieduża powierzchnia oraz posadowienie na planie prostokąta pozwalają na zbudowanie projektu także na wąskiej działce. Wnętrze mieści sypialnię, kuchnię z aneksem jadalnym, pokój dzienny oraz łazienkę.";s:21:"alternate_description";N;s:5:"price";s:7:"3899.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:574:"{"1":{"name":"pow. u\u017cytkowa","value":"47,25","unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":"65,95","unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":"14,3","unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":"17,05","unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":"2","unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":"40","unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":"6,94","unit":"m"},"17":{"name":"pow. netto poddasza"},"18":{"name":"pow. netto pi\u0119tra"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"119495","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-10 11:39:42";s:10:"technology";s:156:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:277:"{"garages":["37","155","322","323","511","512","652"],"thumbnail":"1098\/filemon-iii-wizualizacja-200-5954f5088562c.jpg","templateId":"1","isbn":"978-83-7937-024-5   ","isbn_mirror":"978-83-7937-025-2   ","features":["21","38"],"price_other_type":null,"skeleton_disabled":null}";}i:1147;a:22:{s:2:"id";i:520;s:6:"id_old";i:520;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:469;s:4:"name";s:20:"Zakątek Szczęścia";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:110:"Klasyczny dom parterowy z dwuspadowym dachem i poddaszem użytkowym, z odkrytym tarasem, na płytką działkę";s:11:"description";s:455:"Obszerny piętrowy dom pełen zakamarków i miejsc, w których dzieci mogą pobawić się w chowanego. Niewątpliwym atutem jest praktyczne i wygodne rozplanowanie pomieszczeń, wśród których znajduje się m. in. kilka wnęk garderobianych i dwa schowki. Ten duży dom jest idealny dla sporej rodziny, a praktyczne rozwiązania pomogą w utrzymaniu porządku. Komfort użytkowania zapewniają także łazienki w pobliżu każdej z sypialni na poddaszu.";s:21:"alternate_description";N;s:5:"price";s:7:"5799.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:637:"{"1":{"name":"pow. u\u017cytkowa","value":192.25,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":129.85,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":25.25,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":15.5,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":5,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":30,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":8.12,"unit":"m"},"17":{"name":"pow. netto poddasza","value":97.35,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"467168","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-13 16:39:27";s:10:"technology";s:156:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:265:"{"garages":["37","155","322","323","511","512","539","544","652"],"thumbnail":"520\/zakatek-szczescia-wizualizacja-200-5954e0e4d4018.jpg","templateId":"3","isbn":"978-83-7356-654-5","isbn_mirror":"978-83-7356-659-0","price_other_type":null,"skeleton_disabled":null}";}i:1148;a:22:{s:2:"id";i:600;s:6:"id_old";i:600;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:548;s:4:"name";s:12:"Szarotka Bis";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:103:"Mały domek parterowy z dwuspadowym dachem i poddaszem użytkowym, tani w budowie, na wąską działkę";s:11:"description";s:454:"Niewielki, bo ok. 60 metrowy, ale niezwykle urokliwy dom dla 2-3 osobowej rodziny. Kompaktowe wnętrze mieści przestronny pokój dzienny połączony z komunikacją, kuchnię z aneksem jadalnym oraz łazienkę. Każda z dwóch sypialni na poddaszu posiada dostęp do balkonu, zachęcając do relaksu na świeżym powietrzu. Bliższy kontakt z otaczającą dom zielenią zapewni taras, na którym można spędzać przyjemne wieczory przy kawie lub grillu.";s:21:"alternate_description";N;s:5:"price";s:7:"3899.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:613:"{"1":{"name":"pow. u\u017cytkowa","value":"58,5","unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":"55,55","unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":"15,55","unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":"15,9","unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":"3","unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":"45","unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":"7,64","unit":"m"},"17":{"name":"pow. netto poddasza","value":"33,45","unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"168558","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-13 14:19:00";s:10:"technology";s:156:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:259:"{"garages":["34","35","509","510","540","545","546","593","606"],"thumbnail":"600\/szarotka-bis-wizualizacja-200-5954e036e5182.jpg","templateId":"3","isbn":"978-83-7559-197-2","isbn_mirror":"978-83-7559-102-6","price_other_type":null,"skeleton_disabled":null}";}i:1149;a:22:{s:2:"id";i:1198;s:6:"id_old";i:1198;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:864;s:4:"name";s:11:"Winston XIV";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:104:"Dom parterowy z niezadaszonym tarasem wypoczynkowym w tylnej części budynku i garażem 2-stanowiskowym";s:11:"description";s:584:"Ciemne, nasycone drewno i beżowy kolor elewacji stwarzają nieprzeparte wrażenie swojskości, przytulności i z pewnością wzmocnią rodzinną atmosferę. Kolejny już projekt z linii Winston zachwyca klasycznym, eleganckim wyglądem i praktycznością zastosowanych rozwiązań. Dobrym przykładem jest niezwykle funkcjonalny rozkład pomieszczeń z wyodrębnioną częścią dzienną i nocną. Nie zapomniano również o spiżarni czy garderobie, które wydatnie przyczyniają się do utrzymania porządku w całym domu. Dom jest świetną propozycją dla czteroosobowej rodziny.";s:21:"alternate_description";N;s:5:"price";s:7:"4799.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:632:"{"1":{"name":"pow. u\u017cytkowa","value":115.85,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":200.5,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":20,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":26.8,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":4,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":35,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":7.14,"unit":"m"},"17":{"name":"pow. netto poddasza","value":null,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"359673","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-02-26 10:43:07";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:195:"{"thumbnail":"1198\/winston-xiv-wizualizacja-200-5954ee63990ee.jpg","templateId":"1","isbn":"978-83-7559-896-4","isbn_mirror":"978-83-7559-801-8","price_other_type":null,"skeleton_disabled":null}";}i:1150;a:22:{s:2:"id";i:789;s:6:"id_old";i:789;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:637;s:4:"name";s:9:"Maxima II";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:104:"Dom parterowy z poddaszem użytkowym, gankiem i narożnym tarasem w podcieniu, podpiwniczony, z garażem";s:11:"description";s:713:"Urokliwy dom z wejściem od szczytu z dekoracyjnym gankiem z charakterystyczną przyporą. Elewacja boczna urzeka trapezowym ryzalitem i stanowiącym jego kontynuację podcieniem, tworzącym zadaszenie nad tarasem. Parter mieści przestronną strefę dzienną z kuchnią, jadalnią we wspomnianym już ryzalicie, salonem, gabinetem oraz łazienką. Na poddaszu zaprojektowano trzy sypialnie i łazienkę. Do bryły budynku dołączono duży garaż, w którym poza samochodem zmieszczą się rowery, motor oraz kosiarka. Pod częścią budynku zaprojektowano piwnicę, w której umieszczono kotłownię i pomieszczenia gospodarcze do dowolnej adaptacji. Maxima II będzie wygodnym lokum dla czteroosobowej rodziny.";s:21:"alternate_description";N;s:5:"price";s:7:"5399.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:615:"{"1":{"name":"pow. u\u017cytkowa","value":"124,05","unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":"150,05","unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":"21,9","unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":"22,8","unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":"5","unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":"40","unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":"8,45","unit":"m"},"17":{"name":"pow. netto poddasza","value":"72,65","unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"544788","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-11 12:54:44";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:210:"{"features":["10"],"thumbnail":"789\/maxima-ii-wizualizacja-200-5954ee2f567b7.jpg","templateId":"3","isbn":"978-83-7559-392-1","isbn_mirror":"978-83-7559-396-9","price_other_type":null,"skeleton_disabled":null}";}i:1151;a:22:{s:2:"id";i:579;s:6:"id_old";i:579;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:524;s:4:"name";s:11:"Dziesiątka";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:83:"Klasyczny, parterowy dom z dwuspadowym dachem i poddaszem użytkowym, podpiwniczony";s:11:"description";s:364:"Wybór tego projektu na wąską działkę to strzał w dziesiątkę. Posadowienie budynku na planie kwadratu pozwala na maksymalne wykorzystanie przestrzeni wewnątrz, a prosty, dwuspadowy dach gwarantuje niskie koszty budowy. Sporo dodatkowego miejsca do przechowywania generuje piwnica, w której zaprojektowano kotłownię oraz cztery pomieszczenia gospodarcze.";s:21:"alternate_description";N;s:5:"price";s:7:"5099.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:611:"{"1":{"name":"pow. u\u017cytkowa","value":"124,35","unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":"105,35","unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":"18","unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":"18","unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":"5","unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":"40","unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":"8,68","unit":"m"},"17":{"name":"pow. netto poddasza","value":"74,75","unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"487374","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-10 09:31:24";s:10:"technology";s:156:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:275:"{"garages":["34","35","509","510","540","545","546","593","606"],"features":["10"],"thumbnail":"579\/dziesiatka-wizualizacja-200-5954e073ee393.jpg","templateId":"3","isbn":"978-83-7559-067-8","isbn_mirror":"978-83-7559-071-5","price_other_type":null,"skeleton_disabled":null}";}i:1152;a:22:{s:2:"id";i:567;s:6:"id_old";i:567;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:495;s:4:"name";s:5:"Lutek";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:105:"Mały domek, parterowy, z poddaszem użytkowym i garażem, z lukarnami frontowymi i odsłoniętym tarasem";s:11:"description";s:787:"Mały dom jednorodzinny z poddaszem użytkowym jest ciekawą propozycją dla czteroosobowej rodziny. Parter, dzięki otwartej zabudowie, daje wiele możliwości aranżacji a jednocześnie stwarza odpowiednią ilość przestrzeni do wypoczynku i wspólnej rekreacji. Doskonałym miejscem relaksu i wyciszenia w kojącym otoczeniu zieleni będzie również taras z tyłu domu. W dużym przedsionku zaprojektowano wydzieloną przestrzeń na praktyczne szafy. Zlokalizowana blisko kuchni kotłownia może równocześnie pełnić funkcję spiżarni. Poddasze to tradycyjna strefa sypialna z trzema pokojami i komfortową łazienką. Prosta bryła jest urozmaicona urokliwymi lukarnami i dekoracyjnymi przyporami. Bryłę domu uzupełnia jednostanowiskowy  garaż, przykryty pulpitowym dachem.";s:21:"alternate_description";N;s:5:"price";s:7:"4199.00";s:8:"discount";s:6:"555.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:609:"{"1":{"name":"pow. u\u017cytkowa","value":"86","unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":"94,4","unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":"18,9","unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":"16,7","unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":"4","unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":"45","unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":"8,58","unit":"m"},"17":{"name":"pow. netto poddasza","value":"51,50","unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"280530","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-10 15:42:08";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:188:"{"thumbnail":"567\/lutek-wizualizacja-200-5954e0ab3d405.jpg","templateId":"3","isbn":"978-83-7356-881-5","isbn_mirror":"978-83-7356-821-1","price_other_type":null,"skeleton_disabled":null}";}i:1153;a:22:{s:2:"id";i:559;s:6:"id_old";i:559;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:494;s:4:"name";s:11:"Victoria II";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:101:"Parterowy dom z poddaszem użytkowym i dwuspadowym dachem, z lukarnami i odkrytym tarasem, z garażem";s:11:"description";s:628:"Tradycyjny, nieduży dom o urokliwym wyglądzie i funkcjonalnym wnętrzu. Program użytkowy parteru mieści obszerny salon z kominkiem, połączoną z jadalnią kuchnię oraz łazienkę i dodatkowy pokój, mogący pełnić funkcję sypialni dla gości lub gabinetu. Praktycznym rozwiązaniem jest przechodnia kotłownia, przez którą można przedostać się z garażu do wnętrza domu. Poddasze to komfortowa strefa sypialna z trzema pokojami oraz dużą łazienką. Obszerny hol na poddaszu można w części zagospodarować na domową biblioteczkę z wygodnym fotelem. Dom będzie optymalnym lokum dla czteroosobowej rodziny.";s:21:"alternate_description";N;s:5:"price";s:7:"4899.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:615:"{"1":{"name":"pow. u\u017cytkowa","value":"132,6","unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":"132,01","unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":"20,55","unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":"18,8","unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":"5","unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":"40","unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":"8,29","unit":"m"},"17":{"name":"pow. netto poddasza","value":"82,85","unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"385812","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-13 15:34:32";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:194:"{"thumbnail":"559\/victoria-ii-wizualizacja-200-5954e0b02078b.jpg","templateId":"3","isbn":"978-83-7356-579-1","isbn_mirror":"978-83-7356-866-2","price_other_type":null,"skeleton_disabled":null}";}i:1154;a:22:{s:2:"id";i:494;s:6:"id_old";i:494;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:455;s:4:"name";s:5:"Sunny";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:138:"Dom parterowy z dwuspadowym dachem, poddaszem użytkowym i podpiwniczeniem, z przeszklonym ryzalitem i lukarną z balkonem, dom na skarpę";s:11:"description";s:474:"Urokliwy dom z podpiwniczeniem i poddaszem użytkowym, który doskonale sprawdzi się na wąskiej działce ze spadkiem terenu. Przytulne wnętrze tradycyjnie podzielono funkcjonalnie według poziomów. Na parterze znajduje się strefa dzienna z jadalnią w przeszklonym ryzalicie o oryginalnym, półokrągłym kształcie. W programie użytkowym przewidziano także dodatkowy pokój, który można przeznaczyć na gabinet. Na poddaszu usytuowano trzy sypialnie i łazienkę.";s:21:"alternate_description";N;s:5:"price";s:7:"5199.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:614:"{"1":{"name":"pow. u\u017cytkowa","value":"114","unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":"91,65","unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":"17,84","unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":"19,69","unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":"5","unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":"45","unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":"11,31","unit":"m"},"17":{"name":"pow. netto poddasza","value":"58,30","unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"447866","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-13 14:03:37";s:10:"technology";s:156:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:270:"{"garages":["34","35","509","510","540","545","546","593","606"],"features":["10"],"thumbnail":"494\/sunny-wizualizacja-200-5954e1237376d.jpg","templateId":"3","isbn":"978-83-7356-673-6","isbn_mirror":"978-83-7356-678-1","price_other_type":null,"skeleton_disabled":null}";}i:1155;a:22:{s:2:"id";i:273;s:6:"id_old";i:273;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:254;s:4:"name";s:8:"Szarotka";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:79:"Parterowy dom z poddaszem użytkowym i dwuspadowym dachem, na wąską działkę";s:11:"description";s:521:"Mały dom jednorodzinny z poddaszem użytkowym, w którym wygodnie zamieszka dwu a nawet trzyosobowa rodzina. Utrzymana w brązach kolorystyka elewacji i dachu nadaje całości ciepły, gościnny charakter, który doskonale koresponduje z przytulnym wnętrzem. Parter to strefa dzienna, która mimo niewielkiej powierzchni jest przestronna i komfortowa, co zawdzięcza przede wszystkim otwartej kompozycji pomieszczeń. Na wyższej kondygnacji znalazły się dwie sypialnie z dostępem do balkonu oraz nieduża łazienka.";s:21:"alternate_description";N;s:5:"price";s:7:"3899.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:613:"{"1":{"name":"pow. u\u017cytkowa","value":"58,45","unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":"55,55","unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":"15,55","unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":"15,9","unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":"3","unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":"45","unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":"7,6","unit":"m"},"17":{"name":"pow. netto poddasza","value":"33,40","unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"168558","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-13 14:17:50";s:10:"technology";s:156:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:255:"{"garages":["34","35","509","510","540","545","546","593","606"],"thumbnail":"273\/szarotka-wizualizacja-200-5954d6f903433.jpg","templateId":"3","isbn":"978-83-7356-303-2","isbn_mirror":"978-83-7356-308-7","price_other_type":null,"skeleton_disabled":null}";}i:1156;a:22:{s:2:"id";i:261;s:6:"id_old";i:261;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:242;s:4:"name";s:8:"Namiocik";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:117:"Oryginalny, tani w budowie dom parterowy, sezonowy lub całoroczny, z dachem dwuspadowym poprowadzonym do samej ziemi";s:11:"description";s:532:"Mały, ale niezwykle oryginalny dom, obok którego nie można przejść obojętnie. Został zaprojektowany jako dom całoroczny, jednak dzięki swoim niewielkim gabarytom z powodzeniem może pełnić funkcję rekreacyjną. Parterowe wnętrze mieści otwartą przestrzeń dzienną z kominkiem umieszczonym w centrum oraz strefę sypialną z dwoma przytulnymi pokojami i łazienką. Większość pomieszczeń została doświetlona oknami połaciowymi dzięki czemu część mieszkalna jest nasłoneczniona i komfortowa w użytkowaniu.";s:21:"alternate_description";N;s:5:"price";s:7:"3899.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:573:"{"1":{"name":"pow. u\u017cytkowa","value":"65,25","unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":"101","unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":"18,05","unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":"18,05","unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":"3","unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":"40","unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":"5,82","unit":"m"},"17":{"name":"pow. netto poddasza"},"18":{"name":"pow. netto pi\u0119tra"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"165017","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-02-24 14:58:41";s:10:"technology";s:156:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:191:"{"thumbnail":"261\/namiocik-wizualizacja-200-5954d70f8a76a.jpg","templateId":"1","isbn":"978-83-7356-332-2","isbn_mirror":"978-83-7356-337-7","price_other_type":null,"skeleton_disabled":null}";}i:1157;a:22:{s:2:"id";i:256;s:6:"id_old";i:256;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:237;s:4:"name";s:4:"Duet";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:74:"Dom bliźniaczy, parterowy, z poddaszem użytkowym, z garażem w segmencie";s:11:"description";s:497:"Dzięki bliźniaczej zabudowie oraz energooszczędnym rozwiązaniom projekt będzie niedrogi  zarówno w budowie jak i użytkowaniu. Wysunięty przed bryłę budynku garaż izoluje część mieszkalną od ulicy, pozwalając na spokojny wypoczynek, a osłaniający wejście niewielki daszek chroni wnętrze przed deszczem i śniegiem. Duża powierzchnia przestrzeni dziennej na parterze to gwarancja komfortowego spędzania wspólnego czasu, także dzięki wyjściu na taras zbudowany z tyłu domu.";s:21:"alternate_description";N;s:5:"price";s:7:"6999.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:611:"{"1":{"name":"pow. u\u017cytkowa","value":"83,35","unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":"92,15","unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":"22","unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":"23,95","unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":"4","unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":"40","unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":"8,26","unit":"m"},"17":{"name":"pow. netto poddasza","value":"53,6","unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"266421","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-10 09:21:20";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:174:"{"features":["6","7"],"thumbnail":"256\/duet-wizualizacja-200-5954d76ea4306.jpg","templateId":"3","isbn":"978-83-7356-431-2","price_other_type":null,"skeleton_disabled":null}";}i:1158;a:22:{s:2:"id";i:237;s:6:"id_old";i:237;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:219;s:4:"name";s:7:"Bogusia";s:14:"alternate_name";s:0:"";s:12:"search_names";N;s:17:"short_description";s:91:"Dom parterowy, dwulokalowy z poddaszem użytkowym, z drewnianą werandą i odkrytym tarasem";s:11:"description";s:356:"Dwulokalowy dom z poddaszem użytkowym. Znajdujące się wewnątrz dwa niezależne mieszkania łączy wspólne wejście, jednak schody prowadzące na poddasze nie kolidują z komunikacją parteru, pozwalając na zachowanie prywatności obu rodzinom zamieszkującym budynek. Nieco większy parter mieści trzy sypialnie, poddasze zawiera jeden pokój mniej.";s:21:"alternate_description";N;s:5:"price";s:7:"5699.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:618:"{"1":{"name":"pow. u\u017cytkowa","value":"189,35","unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":"155,35","unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":"21,95","unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":"21,61","unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":"7","unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":"42","unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":"8,66","unit":"m"},"17":{"name":"pow. netto poddasza","value":"113,45","unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"460121","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-09 15:04:57";s:10:"technology";s:156:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:254:"{"garages":["34","35","509","510","540","545","546","593","606"],"thumbnail":"237\/bogusia-wizualizacja-200-5954d98284db8.jpg","templateId":"3","isbn":"978-83-7356-410-7","isbn_mirror":"978-83-7356-415-2","price_other_type":null,"skeleton_disabled":null}";}i:1159;a:22:{s:2:"id";i:787;s:6:"id_old";i:787;s: