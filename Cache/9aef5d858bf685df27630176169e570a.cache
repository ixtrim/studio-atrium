e":"4","unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":"35","unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":"8,22","unit":"m"},"17":{"name":"pow. netto poddasza","value":"56,6","unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"304432","self":null}";s:10:"meta_title";s:78:"Double House. Dwulokalowy dom z poddaszem użytkowym i garażem. Studio Atrium";s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-02-26 12:23:12";s:10:"technology";s:213:"Technologia murowana: pustak ceramiczny gr. 25 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas oraz blacha tytanowo-cynkowa (lukarny). Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:219:"{"features":["12","19"],"thumbnail":"1220\/double-house-wizualizacja-200-5954fc665bd7c.jpg","templateId":"3","isbn":"978-83-7937-528-8","isbn_mirror":"978-83-7937-529-5","price_other_type":null,"skeleton_disabled":null}";}i:775;a:22:{s:2:"id";i:443;s:6:"id_old";i:443;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:403;s:4:"name";s:11:"Willa Jawor";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:92:"Parterowy dom z poddaszem użytkowym i garażem, lukarną z balkonem nad wejściem i tarasem";s:11:"description";s:658:"Niewątpliwym atutem Willi Jawor jest minimalistyczna kolorystyka – szarość dachu i stolarki okienno-drzwiowej w połączeniu z jasną elewacją i ciemnym drewnem przy wykończeniach dachu i na drzwiach garażowych daje znakomity efekt. Przyciąga wzrok lukarna nad drzwiami wejściowymi i kamienne, ozdobne narożniki. W bocznej części umieszczono przeszklony ryzalit, w którym znajduje się kuchnia z jadalnią. Pomyślano również o spiżarni na parterze i garderobie na poddaszu, gdzie druga łazienka została wzbogacona o zaplecze. Trzy pokoje sypialne na poddaszu gwarantują, że dom będzie optymalną propozycją dla czteroosobowej rodziny.";s:21:"alternate_description";N;s:5:"price";s:7:"4999.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:636:"{"1":{"name":"pow. u\u017cytkowa","value":146.6,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":139.15,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":21.05,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":21.2,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":5,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":40,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":8.51,"unit":"m"},"17":{"name":"pow. netto poddasza","value":105.8,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"424411","self":null}";s:10:"meta_title";s:76:"Willa Jawor. Dom z poddaszem użytkowym, garażem i lukarną - Studio Atrium";s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-13 16:23:41";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:212:"{"thumbnail":"443\/willa-jawor-wizualizacja-200-5954dca6233c3.jpg","templateId":"3","price_other_type":null,"skeleton_disabled":null,"isbn":"978-83-7356-874-7","isbn_mirror":"978-83-7356-879-2","features":["10"]}";}i:776;a:22:{s:2:"id";i:402;s:6:"id_old";i:402;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:362;s:4:"name";s:8:"Romantyk";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:103:"Dom parterowy z poddaszem użytkowym i garażem, gankiem wejściowym z kolumnami, niezadaszonym tarasem";s:11:"description";s:633:"Urokliwy, kompaktowy projekt domu jednorodzinnego z jednostanowiskowym garażem wysuniętym przed bryłę. Wejście osłonięte wspartym na filarach daszkiem, drewniane okiennice oraz kopertowy dach nawiązują do stylu podmiejskich dworków, a kamienne przypory nadają całości solidnego wyglądu. Na parterze znajduje się pokój dzienny z jadalnią i częściowo zamkniętą kuchnią oraz niewielki gabinet i łazienka.Poddasze mieści trzy komfortowe sypialnie, łazienkę oraz spory hall z wnękami, które można wykorzystać pod zabudowę. Dodatkowym atutem budynku jest sporych rozmiarów kotłownia usytuowana za garażem.";s:21:"alternate_description";N;s:5:"price";s:7:"4799.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:615:"{"1":{"name":"pow. u\u017cytkowa","value":"115,55","unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":"121,65","unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":"22,6","unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":"17,45","unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":"5","unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":"45","unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":"7,81","unit":"m"},"17":{"name":"pow. netto poddasza","value":"90,7","unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"359624","self":null}";s:10:"meta_title";s:84:"Romantyk. Jednorodzinny dom z poddaszem, gankiem i dużą kotłownią. Studio Atrium";s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-13 12:56:37";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:209:"{"features":["10"],"thumbnail":"402\/romantyk-wizualizacja-200-5954dcb54c6f4.jpg","templateId":"3","isbn":"978-83-7356-777-1","isbn_mirror":"978-83-7356-782-5","price_other_type":null,"skeleton_disabled":null}";}i:777;a:22:{s:2:"id";i:441;s:6:"id_old";i:441;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:401;s:4:"name";s:12:"Orle Gniazdo";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:64:"Dom jednorodzinny, parterowy z poddaszem użytkowym i z garażem";s:11:"description";s:765:"To średniej wielkości dom o ciekawej bryle, zwieńczony kopertowym dachem. Uwagę zwracają kamienne przypory w narożach domu i drewniane zdobienie poddasza, świetnie komponujące się z podtrzymującymi wystający dach kolumnami. Przestronny parter, pięknie doświetlony oknami w wykuszach, sprzyja relaksowi w gronie rodziny i przyjaciół. Dodatkowy pokój to świetne miejsce dla pracujących w domu lub pomieszczenie gościnne. Poddasze wyposażono w trzy sypialnie oraz łazienkę z zapleczem przeznaczonym na pralnię i suszarnię. Drewniane słupy podpierające więźbę dachową, widoczne w większości pomieszczeń mogą stanowić ciekawy element dekoracyjny we wnętrzu.  Dom sprawdzi się jako wygodne lokum dla  trzy- lub czteroosobowej rodziny,";s:21:"alternate_description";N;s:5:"price";s:7:"5299.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:616:"{"1":{"name":"pow. u\u017cytkowa","value":"150,35","unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":"137,45","unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":"20,8","unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":"23,35","unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":"5","unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":"42","unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":"8,78","unit":"m"},"17":{"name":"pow. netto poddasza","value":"101,3","unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"439157","self":null}";s