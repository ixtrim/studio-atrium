;s:6:"555.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:573:"{"1":{"name":"pow. u\u017cytkowa","value":"47,2","unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":"86,35","unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":"17,7","unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":"17,05","unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":"2","unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":"30","unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":"5,93","unit":"m"},"17":{"name":"pow. netto poddasza"},"18":{"name":"pow. netto pi\u0119tra"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"151946","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-10 12:24:24";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:209:"{"thumbnail":"419\/gniazdko-wizualizacja-200-5954dd605abbb.jpg","templateId":"1","isbn":"978-83-7356-778-8","isbn_mirror":"978-83-7356-783-2","features":["22"],"price_other_type":null,"skeleton_disabled":null}";}i:841;a:22:{s:2:"id";i:1114;s:6:"id_old";i:1114;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:1046;s:4:"name";s:6:"Gama V";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:97:"Dom parterowy z poddaszem użytkowym i garażem, z 4 sypialniami i częściowo zadaszonym tarasem";s:11:"description";s:442:"Dom jednorodzinny z poddaszem użytkowym mieszczącym cztery przestronne sypialnie oraz dużą łazienkę. Częściowo zadaszony, rozległy taras to doskonałe miejsce na rodzinne spotkania przy grillu lub relaks w samotności z ulubioną książką na kolanach. Kontakt z otaczającą przyrodą zapewniają także panoramiczne okna parteru oraz loggie dostępne z poddasza. Projekt wpasuje się zarówno w miejski jak i podmiejski krajobraz.";s:21:"alternate_description";N;s:5:"price";s:7:"5599.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:633:"{"1":{"name":"pow. u\u017cytkowa","value":136.45,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":145.3,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":22,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":19.6,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":5,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":40,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":8.52,"unit":"m"},"17":{"name":"pow. netto poddasza","value":94.05,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"394503","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-10 12:18:53";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:207:"{"thumbnail":"1114\/gama-v-wizualizacja-200-5954f27e3be98.jpg","templateId":"3","isbn":"978-83-7937-178-5","isbn_mirror":"978-83-7937-179-2","features":["9"],"price_other_type":null,"skeleton_disabled":null}";}i:842;a:22:{s:2:"id";i:930;s:6:"id_old";i:930;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:898;s:4:"name";s:4:"Argo";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:72:"Dom parterowy z poddaszem użytkowym i garażem, z niezadaszonym tarasem";s:11:"description";s:390:"Mariaż tradycji z nowoczesnością. Do klasycznego pokrytego dwuspadowym dachem projektu dobudowano geometryczną bryłę garażu wkomponowanego w całość dzięki połączeniu z praktycznym przedsionkiem. Ciekawy efekt tworzy wykończenie elewacji drewnianymi elementami w wiśniowym odcieniu. Mimo małej powierzchni budynek jest pakowny zapewniając użytkownikom komfort użytkowania.";s:21:"alternate_description";N;s:5:"price";s:7:"4699.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:635:"{"1":{"name":"pow. u\u017cytkowa","value":106,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":119.25,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":18.96,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":18.74,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":5,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":45,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":9.08,"unit":"m"},"17":{"name":"pow. netto poddasza","value":48.55,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"331643","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-02-27 14:20:22";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:187:"{"thumbnail":"930\/argo-wizualizacja-200-5954e8a57edc4.jpg","templateId":"3","isbn":"978-83-7559-879-7","isbn_mirror":"978-83-7559-883-4","price_other_type":null,"skeleton_disabled":null}";}i:843;a:22:{s:2:"id";i:183;s:6:"id_old";i:183;s:12:"symbol_alpha";s:3:"GLZ";s:10:"symbol_num";i:165;s:4:"name";s:10:"Lutnia III";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:71:"Parterowy dom z poddaszem użytkowym, z lukarną i balkonem nad tarasem";s:11:"description";s:938:"Ta prosta w formie bryła przykryta dwuspadowym dachem dzięki przeszkleniom i stonowanej kolorystyce nabiera nowoczesnego charakteru.  Niewielka szerokość elewacji frontowej sprawia, że projekt zmieści się nawet na bardzo wąskich działkach.  Parter to otwarta przestrzeń z jasną jadalnią, dekoracyjnymi schodami na poddasze i pokojem dziennym z kominkiem. Od strony frontowej umieszczono niewielką  ale wygodną kuchnię. W programie parteru zaplanowano również łazienkę z wyodrębnioną częścią, w której umieszczono piec gazowy i pralkę. Poddasze to strefa nocna z dwoma mniejszymi sypialniami, dużą sypialnią rodziców oraz komfortową łazienką. Wszystkie pomieszczenia poddasza posiadają wyjścia na balkony. Przy budynku zaprojektowano dwa tarasy z różnych stron, co pozwoli na wybranie dogodnego miejsca odpoczynku niezależnie od pory dnia. Lutnia III będzie wygodnym lokum dla czteroosobowej rodziny.";s:21:"alternate_description";N;s:5:"price";s:7:"4599.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:632:"{"1":{"name":"pow. u\u017cytkowa","value":102.6,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":79,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":14.95,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":19.2,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":4,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":45,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":8.16,"unit":"m"},"17":{"name":"pow. netto poddasza","value":56.95,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"286562","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-10 15:42:46";s:10:"technology";s:156:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:257:"{"garages":["34","35","509","510","540","545","546","593","606"],"thumbnail":"183\/lutnia-iii-wizualizacja-200-5954d49ae92ce.jpg","templateId":"3","isbn":"978-83-7356-211-0","isbn_mirror":"978-83-7356-216-5","price_other_type":null,"skeleton_disabled":null}";}i:844;a:22:{s:2:"id";i:942;s:6:"id_old";i:942;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:903;s:4:"name";s:6:"Polo V";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:120:"Dom parterowy z poddaszem użytkowym i garażem w nowoczesnej odsłonie, z ryzalitem wejściowym i niezadaszonym tarasem";s:11:"description";s:1011:"Powiększona  wersja projektu Polo z przestronniejszym salonem oraz większymi gabinetem na parterze i dwiema sypialniami na poddaszu.  Ten nowoczesny wizualnie projekt posiada  tradycyjny podział na część dzienną, parterową i nocną, zlokalizowaną na poddaszu. Dobudowany z boku domu garaż przykryty płaskim dachem, ciekawie komponuje się z całością. Kuchnia, jadalnia i salon tworzą otwartą przestrzeń, która poprzez duże przeszklenie, łączy się z dużym narożnym tarasem. Dostępna z kuchni kotłownia może pełnić jednocześnie funkcję spiżarni. Dodatkowy pokój będzie optymalnym miejscem na gabinet lub w razie potrzeby może być użytkowany jako sypialnia. Poddasze stanowią trzy sypialnie, w tym dwie z oknami typu portfenetr oraz łazienka. Kolorystyka elewacji jest utrzymana w ciepłych barwach brązu, ale zestawiona z szarymi oknami oraz żelbetowym zadaszeniem nad wejściem i wjazdem do garażu. Dom będzie wygodnym lokum dla cztero, a nawet pięcioosobowej rodziny.";s:21:"alternate_description";N;s:5:"price";s:7:"4799.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:632:"{"1":{"name":"pow. u\u017cytkowa","value":121.6,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":125.5,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":22,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":18.45,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":5,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":40,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":8.47,"unit":"m"},"17":{"name":"pow. netto poddasza","value":70.7,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"383434","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-11 16:37:31";s:10:"technology";s:261:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas, blacha tytanowo-cynkowa (lukarna), garaż - papa termozgrzewalna ew. membrana dachowa. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:189:"{"thumbnail":"942\/polo-v-wizualizacja-200-5954f28fd152d.jpg","templateId":"3","isbn":"978-83-7559-916-9","isbn_mirror":"978-83-7559-920-6","price_other_type":null,"skeleton_disabled":null}";}i:845;a:22:{s:2:"id";i:245;s:6:"id_old";i:245;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:227;s:4:"name";s:6:"Chaber";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:83:"Mały parterowy dom z poddaszem użytkowym i garażem, idealny na wąską działkę";s:11:"description";s:359:"Czego chcieć więcej? Mały dom, doskonały na wąską działkę, w którym znalazło się wszystko, co niezbędne dla niedużej rodziny. Parter z kominkiem i wyjściem na taras to część dzienna, poddasze zostało przeznaczone na strefę sypialną z dwoma pokojami i łazienką. Do budynku dołączono jednostanowiskowy garaż przykryty dachem pulpitowym.";s:21:"alternate_description";N;s:5:"price";s:7:"4299.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:613:"{"1":{"name":"pow. u\u017cytkowa","value":"53,85","unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":"66,70","unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":"17,2","unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":"14,8","unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":"3","unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":"45","unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":"8,19","unit":"m"},"17":{"name":"pow. netto poddasza","value":"28,10","unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"187701","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-02-25 14:17:18";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:189:"{"thumbnail":"245\/chaber-wizualizacja-200-5954d4a2ab712.jpg","templateId":"3","isbn":"978-83-7356-341-4","isbn_mirror":"978-83-7356-346-9","price_other_type":null,"skeleton_disabled":null}";}i:846;a:22:{s:2:"id";i:767;s:6:"id_old";i:767;s:12:"symbol_alpha";s:3:"GLU";s:10:"symbol_num";i:5001;s:4:"name";s:9:"Usługowy";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:26:"Budynek handlowo-usługowy";s:11:"description";s:516:"Oryginalny budynek usługowy o powierzchni 441,5 m2. Projekt oparty na klasycznej bryle z dwuspadowym dachem został urozmaicony przeszkloną klatką schodową, nieco wysuniętą przed budynek oraz drewnianymi elementami. We wnętrzu znajdziemy salę sprzedaży, gabinet z pokojem konferencyjnym, pomieszczenia biurowe i socjalne oraz węzły sanitarne. Dzięki funkcjonalnemu wnętrzu oraz energooszczędnym rozwiązaniom, budynek będzie doskonałym wyborem dla Inwestorów poszukujących lokum dla własnej firmy.";s:21:"alternate_description";N;s:5:"price";s:8:"17999.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:589:"{"1":{"name":"pow. u\u017cytkowa","value":"441,5","unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":"283,25","unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":"35","unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":"20","unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi"},"27":{"name":"k\u0105t nachylenia dachu","value":"30","unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":"10,3","unit":"m"},"17":{"name":"pow. netto poddasza","value":"230,95","unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra"}}";s:11:"params_list";N;s:10:"build_cost";s:97:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"1285557","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-13 15:12:45";s:10:"technology";s:182:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: blacha tytanowo-cynkowa. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:130:"{"thumbnail":"767\/uslugowy-wizualizacja-200-5954fca3b2e33.jpg","templateId":"3","price_other_type":null,"skeleton_disabled":null}";}i:847;a:22:{s:2:"id";i:1142;s:6:"id_old";i:1142;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:1134;s:4:"name";s:10:"Senator II";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:83:"Dom piętrowy z płaskim dachem i 2-stanowiskowym garażem w nowoczesnej stylistyce";s:11:"description";s:460:"Duży dom jednorodzinny utrzymany w nowoczesnej stylistyce, w którym wygodnie zamieszka cztero-lub pięcioosobowa rodzina. Tarasy oraz ganek przy wejściu pozwolą na złapanie promieni słońca na zewnątrz, niezależnie od pory dnia. Spory przedsionek oraz duży hall z miejscem na szafy, a także spiżarka i garderoby na poddaszu polepszą organizację i ułatwią utrzymanie porządku, co przy dużej powierzchni mieszkalnej będzie nieocenioną zaletą.";s:21:"alternate_description";N;s:5:"price";s:7:"7399.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:640:"{"1":{"name":"pow. u\u017cytkowa","value":235.05,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":224.3,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":30.85,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":20.35,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":5,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":null,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":7.86,"unit":"m"},"17":{"name":"pow. netto poddasza","value":null,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":130.45,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"682836","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-13 13:25:03";s:10:"technology";s:201:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: papa termozgrzewalna, ew. membrana dachowa. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:194:"{"thumbnail":"1142\/senator-ii-wizualizacja-200-5954fcae861c7.jpg","templateId":"2","price_other_type":null,"skeleton_disabled":null,"isbn":"978-83-7937-330-7","isbn_mirror":"978-83-7937-331-4"}";}i:848;a:22:{s:2:"id";i:1111;s:6:"id_old";i:1111;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:1055;s:4:"name";s:10:"Amber VIII";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:85:"Niewielki dom parterowy z odkrytym, narożnym tarasem wypoczynkowym, energooszczędny";s:11:"description";s:426:"Popularny projekt energooszczędnego domu jednorodzinnego przeznaczonego na jeszcze węższe niż pozostałe Ambery działki. Maksymalne wykorzystanie przestrzeni wewnątrz budynku zapewnia komfortowe warunki jego mieszkańcom oraz stosunkowo niskie koszty budowy. Trzy sypialnie oraz otwarta przestrzeń dzienna to doskonały wybór dla czteroosobowej rodziny. Kotłownia na paliwo stałe posiada dodatkowe drzwi z zewnątrz.";s:21:"alternate_description";N;s:5:"price";s:7:"4599.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:575:"{"1":{"name":"pow. u\u017cytkowa","value":"94,4","unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":"120,15","unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":"19,05","unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":"19,59","unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":"4","unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":"30","unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":"6,25","unit":"m"},"17":{"name":"pow. netto poddasza"},"18":{"name":"pow. netto pi\u0119tra"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"238738","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-02-26 11:59:23";s:10:"technology";s:156:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:285:"{"garages":["37","155","322","323","511","652","701","829"],"thumbnail":"1111\/amber-viii-wizualizacja-200-5954f29f7d901.jpg","templateId":"1","features":["1","36","21","39"],"price_other_type":null,"skeleton_disabled":null,"isbn":"978-83-7937-212-6","isbn_mirror":"978-83-7937-213-3"}";}i:849;a:22:{s:2:"id";i:1171;s:6:"id_old";i:1171;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:1057;s:4:"name";s:9:"Tango III";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:76:"Parterowy dom z odkrytym tarasem wypoczynkowym na zapleczu, z pompą ciepła";s:11:"description";s:472:"Kompaktowy dom jednorodzinny o urokliwej, klasycznej bryle nakrytej dwuspadowym dachem. Dzięki przemyślanemu rozkładowi pomieszczeń, na 62-metrowej powierzchni zmieściły się aż trzy sypialnie, łazienka oraz otwarta przestrzeń dzienna. Z tyłu budynku zaplanowano komfortowy, otoczony niewielkim murkiem taras, na którym cała rodzina może spędzać czas w kojącym otoczeniu zieleni ogrodu. Dom sprawdzi się jako lokum dla trzy a nawet czteroosobowej rodziny.";s:21:"alternate_description";N;s:5:"price";s:7:"4199.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:572:"{"1":{"name":"pow. u\u017cytkowa","value":"62,4","unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":"87,3","unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":"19,8","unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":"16,25","unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":"4","unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":"30","unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":"5,88","unit":"m"},"17":{"name":"pow. netto poddasza"},"18":{"name":"pow. netto pi\u0119tra"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"157810","self":null}";s:10:"meta_title";s:80:"Tango III. Mały dom parterowy tani w budowie, bez garażu, taras. Studio Atrium";s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-02-20 13:57:36";s:10:"technology";s:156:"Technologia murowana: pustak ceramiczny gr. 25 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:264:"{"garages":["37","155","322","323","511","512","652"],"thumbnail":"1171\/tango-iii-wizualizacja-200-5954f2a95d0f8.jpg","templateId":"1","isbn":"978-83-7937-220-1","isbn_mirror":"978-83-7937-221-8","price_other_type":null,"skeleton_disabled":null,"features":["16"]}";}i:850;a:22:{s:2:"id";i:1172;s:6:"id_old";i:1172;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:1060;s:4:"name";s:5:"Neo X";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:79:"Niewielki dom parterowy ze strychem, z dwuspadowym dachem, z zadaszonym tarasem";s:11:"description";s:503:"Nieduży budynek parterowy z możliwością adaptacji strychu na cele mieszkalne, nawiązujący wyglądem do stylu skandynawskich domów. Prosta, oszczędna konstrukcja oraz stosunkowo niewielka powierzchnia gwarantują niskie koszty budowy oraz późniejszego użytkowania. Parter mieści się w ok. 90mkw i ma wszystko to co jest potrzebne czteroosobowej rodzinie - 3 sypialnie, salon z kuchnią i jadalnią oraz łazienkę i kotłownię. W hallu znajdują się okrągłe schody prowadzące na strych.";s:21:"alternate_description";N;s:5:"price";s:7:"4199.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:576:"{"1":{"name":"pow. u\u017cytkowa","value":"90,35","unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":"131,05","unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":"21,05","unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":"18,79","unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":"4","unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":"38","unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":"8,15","unit":"m"},"17":{"name":"pow. netto poddasza"},"18":{"name":"pow. netto pi\u0119tra"}}";s:11:"params_list";N;s:10:"build_cost";s:51:"{"closed":"136268","full":"252348","self":"174120"}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date";s:19:"2020-04-07 15:08:00";s:10:"technology";s:156:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:287:"{"garages":["37","155","322","323","511","652","701","829"],"thumbnail":"1172\/neo-x-wizualizacja-200-5954f2b095a4c.jpg","templateId":"3","cost":"318783","isbn":"978-83-7937-232-4","isbn_mirror":"978-83-7937-233-1","features":["45","44"],"price_other_type":null,"skeleton_disabled":null}";}i:851;a:22:{s:2:"id";i:1173;s:6:"id_old";i:1173;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:1119;s:4:"name";s:8:"Saturn V";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:140:"Przestronny dom parterowy z wielospadowym dachem, bez podpiwniczenia, z 3 sypialniami i garażem, idealny na działki z wjazdem od południa";s:11:"description";s:1316:"Do wnętrza domu prowadzi duży przedsionek, który może pełnić również funkcję garderoby. Nasłoneczniona strefa dzienna w postaci dużego pokoju dziennego, jadalni i aneksu kuchennego, zachęca do wypoczynku w przyjemnej atmosferze i bliskości ogrodu widocznego z wewnątrz dzięki panoramicznym oknom. Do strefy nocnej, na którą składają się trzy ustawne sypialnie, w tym jedna z własną garderobą, prowadzi nas wygodny hall. Pokoje te obsługuje duża łazienka z wanną i kabiną prysznicową. Dla gości dostępne jest także praktyczne w.c. dostępne z przedsionka. Z tyłu garażu zaprojektowano dodatkowe pomieszczenie gospodarcze dostępne również ze strony ogrodu, które będzie doskonałym miejscem przechowywania niezbędnych narzędzi i sprzętów. Wyjście to zostało dodatkowo zadaszone, dzięki czemu uzyskano dodatkowo praktyczne miejsce do przechowywania np. drewna kominkowego. Do garażu dostaniemy się również przez sporą kotłownię, w której przewidziano także miejsce na pralkę. Ten dom to bardzo przemyślana, wygodna i elegancka propozycja dla czteroosobowej rodziny. Idealna również dla właścicieli działek z wjazdem od strony południowej. To dom, który dzięki swej ponadczasowej architekturze wpisze się zarówno w miejskie, jak i podmiejskie otoczenie.";s:21:"alternate_description";N;s:5:"price";s:7:"5099.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:637:"{"1":{"name":"pow. u\u017cytkowa","value":123.25,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":195.65,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":23.09,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":22.13,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":4,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":30,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":7.13,"unit":"m"},"17":{"name":"pow. netto poddasza","value":null,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"349806","self":null}";s:10:"meta_title";s:81:"Saturn V. Parterowy dom z wielospadowym dachem, garażem na 1 auto. Studio Atrium";s:16:"meta_description";N;s:11:"modify_date";s:19:"2026-03-13 13:14:13";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";s:214:"{"features":["10","9"],"thumbnail":"1173\/saturn-v-wizualizacja-200-5954fcb85fd3b.jpg","templateId":"1","isbn":"978-83-7937-270-6","isbn_mirror":"978-83-7937-271-3","price_other_type":null,"skeleton_disabled":null}";}i:852;a:22:{s:2:"id";i:52;s:6:"id_old";i:52;s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";i:40;s:4:"name";s:5:"Koral";s:14:"alternate_name";N;s:12:"search_names";N;s:17:"short_description";s:107:"Parterowy dom z poddaszem użytkowym i garażem 2-stanowiskowym, z gankiem i częściowo zadaszonym tarasem";s:11:"description";s:1185:"Niezwykle elegancka bryła w tradycyjnym stylu zaprojektowana z dużym polotem. W osłoniętej od wiatru przestrzeni tarasu zaprojektowano zadaszenie z umieszczonym pod nim zewnętrznym kominkiem, tworząc świetne miejsce na wspólne grillowanie lub wieczorne spotkania z przyjaciółmi. W centrum parteru umieszczono strefę użytkową z kuchnią i jadalnią, za którymi znajduje się duży, pełen wolnej przestrzeni pokój dzienny. Ryzalit od strony ogrodu nie tylko doświetla wnętrze, ale także otwiera je na otaczający budynek krajobraz, sprzyjając tym samym relaksowi. Dodatkowy pokój można przeznaczyć na gabinet lub sypialnię. Spokojny sen gwarantuje komfortowe poddasze z trzema pokojami oddzielonymi od siebie szerokim hallem. Dwie łazienki na poddaszu oraz jedna na parterze zapewniają wysoki komfort użytkowania. Wkomponowany w bryłę budynku dwustanowiskowy garaż jest skomunikowany z częścią mieszkalną poprzez kotłownię. Ten ciekawy projekt w kształcie litery „L” to propozycja dla Inwestorów, którzy cenią niebanalne rozwiązania tworzone na bazie klasycznych wzorców. Koral będzie wygodnym lokum dla cztero- lub pięcioosobowej rodziny.";s:21:"alternate_description";N;s:5:"price";s:7:"5399.00";s:8:"discount";s:4:"0.00";s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";s:636:"{"1":{"name":"pow. u\u017cytkowa","value":192.45,"unit":"m<sup>2<\/sup>"},"23":{"name":"pow. zabudowy","value":185,"unit":"m<sup>2<\/sup>"},"75":{"name":"szeroko\u015b\u0107 dzia\u0142ki","value":25.58,"unit":"m"},"76":{"name":"d\u0142ugo\u015b\u0107 dzia\u0142ki","value":24.48,"unit":"m"},"68":{"name":"ilo\u015b\u0107 pokoi","value":5,"unit":""},"27":{"name":"k\u0105t nachylenia dachu","value":45,"unit":"\u00b0"},"26":{"name":"wysoko\u015b\u0107 budynku","value":8.12,"unit":"m"},"17":{"name":"pow. netto poddasza","value":124.35,"unit":"m<sup>2<\/sup>"},"18":{"name":"pow. netto pi\u0119tra","value":null,"unit":"m<sup>2<\/sup>"}}";s:11:"params_list";N;s:10:"build_cost";s:96:"{"closed":null,"open":null,"fitting":null,"finish":null,"date":null,"full":"523507","self":null}";s:10:"meta_title";N;s:16:"meta_description";N;s:11:"modify_date