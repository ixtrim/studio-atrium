a:3:{s:3:"key";s:32:"6e8263c033d5b937a543eae1b3af5da5";s:3:"ttl";i:1800;s:5:"value";s:10874:"a:2:{i:0;a:3:{i:0;a:15:{s:2:"id";i:30110;s:15:"__foreign_props";a:0:{}s:12:"profile_name";s:25:"ProjectBuildingInProgress";s:8:"filename";s:24:"budowa-598b0e76cc5f9.jpg";s:4:"path";s:15:"594/realisation";s:5:"title";s:24:"Dom Roleks Bis w budowie";s:11:"description";s:0:"";s:9:"owner_uid";s:6:"152066";s:5:"props";a:6:{s:17:"original_filename";s:10:"roleks.jpg";s:4:"type";s:5:"image";s:10:"image_size";a:2:{s:5:"width";i:1920;s:6:"height";i:1280;}s:9:"file_size";i:207289;s:12:"file_created";i:1502285431;s:6:"storey";s:3:"yes";}s:7:"sorting";s:1:"3";s:20:"parent_attachment_id";i:0;s:19:"parent_relationship";s:0:"";s:4:"_uid";i:7708165;s:16:"childAttachments";a:0:{}s:6:"object";a:25:{s:2:"id";i:594;s:15:"__foreign_props";a:0:{}s:6:"id_old";s:3:"594";s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";s:3:"539";s:4:"name";s:10:"Roleks Bis";s:14:"alternate_name";s:0:"";s:12:"search_names";s:9:"Rolex Bis";s:17:"short_description";s:72:"Dom parterowy z poddaszem użytkowym i garażem, z niezadaszonym tarasem";s:11:"description";s:442:"Kamienna podmurówka oraz drewniane fragmenty elewacji nadają tej prostej bryle urokliwego charakteru, sprawiając że wpasuje się zarówno w miejską jak i podmiejską zabudowę. Jednak główną zaletą projektu jest ekonomiczne i przejrzyste wnętrze, w którym wygodnie zamieszka pięcioosobowa rodzina. Program użytkowy budynku tradycyjnie podzielono na strefę dzienną na parterze oraz część nocną znajdującą się na poddaszu.";s:21:"alternate_description";s:0:"";s:5:"price";d:4799;s:8:"discount";d:0;s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";a:9:{i:1;a:3:{s:4:"name";s:14:"pow. użytkowa";s:5:"value";s:5:"115,5";s:4:"unit";s:13:"m<sup>2</sup>";}i:23;a:3:{s:4:"name";s:13:"pow. zabudowy";s:5:"value";s:3:"117";s:4:"unit";s:13:"m<sup>2</sup>";}i:75;a:3:{s:4:"name";s:20:"szerokość działki";s:5:"value";s:4:"20,8";s:4:"unit";s:1:"m";}i:76;a:3:{s:4:"name";s:19:"długość działki";s:5:"value";s:5:"18,05";s:4:"unit";s:1:"m";}i:68;a:3:{s:4:"name";s:13:"ilość pokoi";s:5:"value";s:1:"5";s:4:"unit";s:0:"";}i:27;a:3:{s:4:"name";s:21:"kąt nachylenia dachu";s:5:"value";s:2:"42";s:4:"unit";s:2:"°";}i:26;a:3:{s:4:"name";s:18:"wysokość budynku";s:5:"value";s:4:"8,41";s:4:"unit";s:1:"m";}i:17;a:3:{s:4:"name";s:19:"pow. netto poddasza";s:5:"value";s:4:"73,8";s:4:"unit";s:13:"m<sup>2</sup>";}i:18;a:1:{s:4:"name";s:18:"pow. netto piętra";}}s:11:"params_list";N;s:10:"build_cost";a:7:{s:6:"closed";N;s:4:"open";N;s:7:"fitting";N;s:6:"finish";N;s:4:"date";N;s:4:"full";s:6:"356590";s:4:"self";N;}s:10:"meta_title";s:0:"";s:16:"meta_description";s:0:"";s:11:"modify_date";s:19:"2026-03-12 15:45:12";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";a:6:{s:9:"thumbnail";s:49:"594/roleks-bis-wizualizacja-200-5954dd9650785.jpg";s:10:"templateId";s:1:"3";s:4:"isbn";s:17:"978-83-7559-125-5";s:11:"isbn_mirror";s:17:"978-83-7559-129-3";s:16:"price_other_type";N;s:17:"skeleton_disabled";N;}s:11:"attachments";a:0:{}s:4:"_uid";i:152066;}}i:1;a:15:{s:2:"id";i:40841;s:15:"__foreign_props";a:0:{}s:12:"profile_name";s:25:"ProjectBuildingInProgress";s:8:"filename";s:24:"budowa-5df3577d9026e.jpg";s:4:"path";s:16:"1413/realisation";s:5:"title";s:20:"Dom Czajka w budowie";s:11:"description";s:46:"stan surowy zamknięty, widok od strony tarasu";s:9:"owner_uid";s:6:"361730";s:5:"props";a:6:{s:17:"original_filename";s:12:"czajka-2.jpg";s:4:"type";s:5:"image";s:10:"image_size";a:2:{s:5:"width";i:1920;s:6:"height";i:1280;}s:9:"file_size";i:471309;s:12:"file_created";i:1576228735;s:6:"storey";s:3:"yes";}s:7:"sorting";s:1:"2";s:20:"parent_attachment_id";i:0;s:19:"parent_relationship";s:0:"";s:4:"_uid";i:10455301;s:16:"childAttachments";a:0:{}s:6:"object";a:25:{s:2:"id";i:1413;s:15:"__foreign_props";a:0:{}s:6:"id_old";s:1:"0";s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";s:4:"1369";s:4:"name";s:6:"Czajka";s:14:"alternate_name";s:0:"";s:12:"search_names";s:7:"Czajka1";s:17:"short_description";s:125:"Dom jednorodzinny, parterowy, z dwustanowiskowym garażem, na działki z wjazdem od południa i zachodu, z dwuspadowym dachem";s:11:"description";s:914:"Czajka to ciekawa propozycja dla inwestorów poszukujących niewielkiego domu z bogatym programem użytkowym, do realizacji na działce z wjazdem od południa. Na niespełna 130m2 architekt zmieścił kuchnię z przestronnym salonem, cztery sypialnie, w tym jedną z garderobą, dwie łazienki, ale także przedsionek, hol z pojemnymi szafami, pralnię i kotłownię. Na elewacji bocznej zaprojektowano dwustanowiskowy garaż z zadaszeniem nad wjazdem i wejściem do budynku. Szczególną  uwagę zwraca strefa wypoczynkowa, czyli pokój dzienny z kominkiem, umilającym domownikom  jesienne i zimowe wieczory oraz wyjściem na zadaszony taras, zaprojektowany w podcieniu. Prosta bryła budynku, przykryta dwuspadowym dachem jest utrzymana w chłodnych odcieniach bieli i szarości. Dom będzie wygodnym lokum nawet dla pięcioosobowej rodziny i dobrze wpisze się zarówno w miejską, jak i podmiejską zabudowę.";s:21:"alternate_description";s:0:"";s:5:"price";d:4899;s:8:"discount";d:0;s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";a:9:{i:1;a:3:{s:4:"name";s:14:"pow. użytkowa";s:5:"value";s:5:"128,6";s:4:"unit";s:13:"m<sup>2</sup>";}i:23;a:3:{s:4:"name";s:13:"pow. zabudowy";s:5:"value";s:5:"226,1";s:4:"unit";s:13:"m<sup>2</sup>";}i:75;a:3:{s:4:"name";s:20:"szerokość działki";s:5:"value";s:4:"29,5";s:4:"unit";s:1:"m";}i:76;a:3:{s:4:"name";s:19:"długość działki";s:5:"value";s:5:"18,95";s:4:"unit";s:1:"m";}i:68;a:3:{s:4:"name";s:13:"ilość pokoi";s:5:"value";s:1:"5";s:4:"unit";s:0:"";}i:27;a:3:{s:4:"name";s:21:"kąt nachylenia dachu";s:5:"value";s:2:"30";s:4:"unit";s:2:"°";}i:26;a:3:{s:4:"name";s:18:"wysokość budynku";s:5:"value";s:4:"6,84";s:4:"unit";s:1:"m";}i:17;a:1:{s:4:"name";s:19:"pow. netto poddasza";}i:18;a:1:{s:4:"name";s:18:"pow. netto piętra";}}s:11:"params_list";N;s:10:"build_cost";a:7:{s:6:"closed";N;s:4:"open";N;s:7:"fitting";N;s:6:"finish";N;s:4:"date";N;s:4:"full";N;s:4:"self";N;}s:10:"meta_title";s:82:"Czajka. Parterowy dom na działki z wjazdem od południa i zachodu - Studio Atrium";s:16:"meta_description";s:0:"";s:11:"modify_date";s:19:"2026-02-26 12:04:05";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 25 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";a:8:{s:10:"templateId";s:1:"1";s:16:"price_other_type";N;s:17:"skeleton_disabled";N;s:9:"thumbnail";s:39:"1413/wizualizacja-200-5a9005530d126.jpg";s:4:"isbn";s:17:"978-83-7937-866-1";s:11:"isbn_mirror";s:17:"978-83-7937-867-8";s:8:"features";a:1:{i:0;s:2:"46";}s:9:"sun_ratio";s:6:"0.0214";}s:11:"attachments";a:0:{}s:4:"_uid";i:361730;}}i:2;a:15:{s:2:"id";i:29738;s:15:"__foreign_props";a:0:{}s:12:"profile_name";s:25:"ProjectBuildingInProgress";s:8:"filename";s:24:"budowa-598181b1ef638.jpg";s:4:"path";s:15:"644/realisation";s:5:"title";s:17:"Dom Ada w budowie";s:11:"description";s:22:"stan surowy zamknięty";s:9:"owner_uid";s:6:"164866";s:5:"props";a:6:{s:17:"original_filename";s:7:"ada.jpg";s:4:"type";s:5:"image";s:10:"image_size";a:2:{s:5:"width";i:1920;s:6:"height";i:1280;}s:9:"file_size";i:257209;s:12:"file_created";i:1501659578;s:6:"storey";s:3:"yes";}s:7:"sorting";s:1:"1";s:20:"parent_attachment_id";i:0;s:19:"parent_relationship";s:0:"";s:4:"_uid";i:7612933;s:16:"childAttachments";a:0:{}s:6:"object";a:25:{s:2:"id";i:644;s:15:"__foreign_props";a:0:{}s:6:"id_old";s:3:"644";s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";s:3:"587";s:4:"name";s:12:"Ada Plus Bis";s:14:"alternate_name";s:0:"";s:12:"search_names";s:40:"ada + bis,adaplusbis,adaplus bis,ada+bis";s:17:"short_description";s:107:"Podpiwniczony dom parterowy z poddaszem użytkowym i garażem, z dwuspadowym dachem i niezadaszonym tarasem";s:11:"description";s:912:"Ada Plus Bis to nieco odświeżona wizualnie wersja projektu <a href="/projekty-domow/Ada-plus,534.html">Ada Plus</a>. Powierzchnia użytkowa wynosząca niecałe 100 m<sup>2</sup>, może pomieścić naprawdę wiele. Jasny, przestronny pokój dzienny z centralnie usytuowanym kominkiem i otwarta kuchnia na parterze oraz trzy sypialnie i duża łazienka na poddaszu to doskonałe rozwiązanie dla rodziny 3+. Dodatkowym atutem z całą pewnością jest również dodatkowy pokój na parterze, który może pełnić funkcję gabinetu lub pokoju gościnnego. Prostota idzie w tym projekcie w parze z funkcjonalnością, a maksymalnemu wykorzystaniu przestrzeni użytkowej sprzyja piwnica z praktycznymi pomieszczeniami gospodarczymi i kotłownią oraz jednostanowiskowy garaż. Nowoczesne, odświeżone w stosunku do wspomnianego poprzednika wykończenia zewnętrzne, nadają projektowi niepowtarzalnego charakteru.";s:21:"alternate_description";s:0:"";s:5:"price";d:4899;s:8:"discount";d:0;s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";a:9:{i:1;a:3:{s:4:"name";s:14:"pow. użytkowa";s:5:"value";s:4:"97,8";s:4:"unit";s:13:"m<sup>2</sup>";}i:23;a:3:{s:4:"name";s:13:"pow. zabudowy";s:5:"value";s:5:"111,7";s:4:"unit";s:13:"m<sup>2</sup>";}i:75;a:3:{s:4:"name";s:20:"szerokość działki";s:5:"value";s:4:"19,7";s:4:"unit";s:1:"m";}i:76;a:3:{s:4:"name";s:19:"długość działki";s:5:"value";s:4:"17,3";s:4:"unit";s:1:"m";}i:68;a:3:{s:4:"name";s:13:"ilość pokoi";s:5:"value";s:1:"5";s:4:"unit";s:0:"";}i:27;a:3:{s:4:"name";s:21:"kąt nachylenia dachu";s:5:"value";s:2:"45";s:4:"unit";s:2:"°";}i:26;a:3:{s:4:"name";s:18:"wysokość budynku";s:5:"value";s:4:"8,62";s:4:"unit";s:1:"m";}i:17;a:3:{s:4:"name";s:19:"pow. netto poddasza";s:5:"value";s:5:"58,45";s:4:"unit";s:13:"m<sup>2</sup>";}i:18;a:1:{s:4:"name";s:18:"pow. netto piętra";}}s:11:"params_list";N;s:10:"build_cost";a:7:{s:6:"closed";N;s:4:"open";N;s:7:"fitting";N;s:6:"