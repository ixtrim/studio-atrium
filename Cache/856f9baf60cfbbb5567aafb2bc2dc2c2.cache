ge";s:10:"image_size";a:2:{s:5:"width";i:620;s:6:"height";i:420;}s:9:"file_size";i:9301;s:12:"file_created";i:1498822738;}s:7:"sorting";i:0;s:20:"parent_attachment_id";i:0;s:19:"parent_relationship";s:0:"";s:4:"_uid";i:7467013;s:16:"childAttachments";a:0:{}}i:1;a:14:{s:2:"id";i:29247;s:15:"__foreign_props";a:0:{}s:12:"profile_name";s:17:"ProjectExtraImage";s:8:"filename";s:17:"59563b84c5446.jpg";s:4:"path";s:10:"1194/extra";s:5:"title";s:23:"Usytuowanie na działce";s:11:"description";s:316:"Ostateczną odległość od drogi ustala plan ogólny zagospodarowania przestrzennego lub decyzja o warunkach zabudowy i zagospodarowania terenu. Odległości budynku od granic nie uwzględniają tarasów i schodów zewnętrznych. Powiększone gabaryty budynku uwzględniają grubość ozdobnych elementów elewacji.";s:9:"owner_uid";s:6:"305666";s:5:"props";a:5:{s:17:"original_filename";s:14:"1167-Plaza.jpg";s:4:"type";s:5:"image";s:10:"image_size";a:2:{s:5:"width";i:1000;s:6:"height";i:1000;}s:9:"file_size";i:180243;s:12:"file_created";i:1498823556;}s:7:"sorting";s:1:"1";s:20:"parent_attachment_id";i:0;s:19:"parent_relationship";s:0:"";s:4:"_uid";i:7487237;s:16:"childAttachments";a:0:{}}}s:15:"ProjectFile_Del";a:1:{i:0;a:14:{s:2:"id";i:38396;s:15:"__foreign_props";a:0:{}s:12:"profile_name";s:15:"ProjectFile_Del";s:8:"filename";s:51:"5bc438de9f074-gl_1167-bursztyn_plus-zestawienia.pdf";s:4:"path";s:9:"1194/file";s:5:"title";s:24:"Zestawienie materiałów";s:11:"description";s:0:"";s:9:"owner_uid";s:6:"305666";s:5:"props";a:4:{s:17:"original_filename";s:37:"GL 1167-Bursztyn Plus-zestawienia.pdf";s:9:"file_size";i:766600;s:12:"file_created";i:1539586270;s:6:"storey";s:9:"materials";}s:7:"sorting";i:0;s:20:"parent_attachment_id";i:0;s:19:"parent_relationship";s:0:"";s:4:"_uid";i:9829381;s:16:"childAttachments";a:0:{}}}s:11:"ProjectFile";a:3:{i:0;a:14:{s:2:"id";i:41688;s:15:"__foreign_props";a:0:{}s:12:"profile_name";s:11:"ProjectFile";s:8:"filename";s:33:"5e45143cdb630-gl_1167-dzialka.pdf";s:4:"path";s: