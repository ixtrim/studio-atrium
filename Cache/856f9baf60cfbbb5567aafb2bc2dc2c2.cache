a:3:{s:3:"key";s:32:"9aef5d858bf685df27630176169e570a";s:3:"ttl";i:1800;s:5:"value";s:197190:"a:2:{i:0;a:6:{i:0;a:25:{s:2:"id";i:1730;s:15:"__foreign_props";a:0:{}s:6:"id_old";s:1:"0";s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";s:7:"9991571";s:4:"name";s:10:"Rodrigo SZ";s:14:"alternate_name";s:0:"";s:12:"search_names";s:40:"rodrigo1sz,rodrigo 1sz,1571SZ,set-parter";s:17:"short_description";s:73:"Parterowy dom w technologii szkieletowej z częściowo zadaszonym tarasem";s:11:"description";s:888:"Niewielki parterowy dom zaprojektowany na planie prostokąta, z dwuspadowym dachem, bez garażu w technologii szkieletowej. Ta urokliwa parterówka spełni oczekiwania czteroosobowej rodziny. W planie funkcjonalnym znajdziemy przede wszystkim duży pokój dzienny z jadalnią, z którego poprzez duże przeszklenia wyjdziemy na częściowo zadaszony taras wypoczynkowy. Obok znajduje się otwarta na salon kuchnia z przejściem do kotłowni, w której przewidziano miejsce na kocioł gazowy oraz pralkę. Pomieszczenie to z powodzeniem będzie mogło posłużyć jako spiżarka. Mieszkańcy będą mogli cieszyć się także z trzech ustawnych pokoi oraz łazienki z wanną i prysznicem. Rodrigo SZ to ciekawa propozycja, taniego w budowie domu, który bez problemu zafunkcjonuje na działkach zarówno z otaczającą je okoliczną zabudową, jak i bez niej, w każdym otoczeniu przyrody.";s:21:"alternate_description";s:0:"";s:5:"price";d:4399;s:8:"discount";d:0;s:4:"type";s:8:"skeleton";s:6:"status";s:9:"published";s:14:"params_general";a:9:{i:1;a:3:{s:4:"name";s:14:"pow. użytkowa";s:5:"value";s:5:"80,45";s:4:"unit";s:13:"m<sup>2</sup>";}i:23;a:3:{s:4:"name";s:13:"pow. zabudowy";s:5:"value";s:6:"104,25";s:4:"unit";s:13:"m<sup>2</sup>";}i:75;a:3:{s:4:"name";s:20:"szerokość działki";s:5:"value";s:5:"19,40";s:4:"unit";s:1:"m";}i:76;a:3:{s:4:"name";s:19:"długość działki";s:5:"value";s:5:"15,90";s:4:"unit";s:1:"m";}i:68;a:3:{s:4:"name";s:13:"ilość pokoi";s:5:"value";s:1:"4";s:4:"unit";s:0:"";}i:27;a:3:{s:4:"name";s:21:"kąt nachylenia dachu";s:5:"value";s:2:"25";s:4:"unit";s:2:"°";}i:26;a:3:{s:4:"name";s:18:"wysokość budynku";s:5:"value";s:4:"5,41";s:4:"unit";s:1:"m";}i:17;a:1:{s:4:"name";s:19:"pow. netto poddasza";}i:18;a:1:{s:4:"name";s:18:"pow. netto piętra";}}s:11:"params_list";N;s:10:"build_cost";a:7:{s:6:"closed";N;s:4:"open";N;s:7:"fitting";N;s:6:"finish";N;s:4:"date";N;s:4:"full";N;s:4:"self";N;}s:10:"meta_title";s:77:"Rodrigo SZ. Niewielki dom parterowy w technologii szkieletowej. Studio Atrium";s:16:"meta_description";s:0:"";s:11:"modify_date";s:19:"2026-02-20 13:37:02";s:10:"technology";s:192:"Ściany w szkielecie drewnianym + ocieplenie z wełny mineralnej + płyty OSB + ocieplenie w systemie Termo Organika. Pokrycie dachu: blacha tytanowo-cynkowa. Drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";a:5:{s:10:"templateId";s:1:"1";s:16:"price_other_type";N;s:17:"skeleton_disabled";N;s:9:"thumbnail";s:39:"1730/wizualizacja-200-666068a21bf6c.jpg";s:14:"linkedProjects";a:1:{i:0;s:4:"1647";}}s:11:"attachments";a:3:{s:13:"ProjectSketch";a:1:{i:0;a:14:{s:2:"id";i:50175;s:15:"__foreign_props";a:0:{}s:12:"profile_name";s:13:"ProjectSketch";s:8:"filename";s:22:"rzut-666068f743cc8.png";s:4:"path";s:4:"1730";s:5:"title";s:12:"Rzut parteru";s:11:"description";s:0:"";s:9:"owner_uid";s:6:"442882";s:5:"props";a:10:{s:17:"original_filename";s:10:"1571SZ.png";s:4:"type";s:5:"image";s:10:"image_size";a:2:{s:5:"width";i:1071;s:6:"height";i:976;}s:9:"file_size";i:72419;s:12:"file_created";i:1717594359;s:5:"scale";d:1.71;s:5:"width";s:4:"1071";s:12:"mirror_scale";d:1.71;s:12:"mirror_width";s:4:"1071";s:6:"storey";s:12:"ground_floor";}s:7:"sorting";i:0;s:20:"parent_attachment_id";i:0;s:19:"parent_relationship";s:0:"";s:4:"_uid";i:12844805;s:16:"childAttachments";a:1:{s:4:"list";a:1:{i:0;a:14:{s:2:"id";i:50176;s:15:"__foreign_props";a:0:{}s:12:"profile_name";s:13:"ProjectSketch";s:8:"filename";s:26:"rzut-285-666068f743cc8.png";s:4:"path";s:4:"1730";s:5:"title";s:0:"";s:11:"description";s:0:"";s:9:"owner_uid