2:"search_names";s:43:"tangovsz,tango5sz,tango 5sz,1556,set-parter";s:17:"short_description";s:93:"Parterowy dom w technologii szkieletowej z dwuspadowym dachem, o powierzchni zabudowy do 70m2";s:11:"description";s:1106:"Niewielka parterówka zaprojektowana na planie prostokąta i przykryta dwuspadowym dachem to idealna propozycja dla Inwestorów planujących zamienić mieszkanie w bloku na własny mały dom, który świetnie wpisze się zarówno w miejską, jak i podmiejską przestrzeń. Jasna elewacja dobrze komponuje się z grafitową dachówką typu tegalit i zastosowanymi w narożach budynku płytami ze spieków kwarcowych, również w kolorze grafitowym. Program użytkowy przygotowano z myślą o dwu lub trzyosobowej rodzinie, do której dyspozycji zaprojektowano strefę dzienną i sypialną. Tę pierwszą tworzą zaprojektowane w otwartej przestrzeni kuchnia, jadalnia i pokój dzienny z kominkiem natomiast część sypialna mieści dwa pokoje. Program uzupełniają przedsionek z szafą wnękową, kotłownia oraz łazienka. Z pokoju dziennego i jednej z sypialni zaprojektowano wyjścia na przestronny taras. Zwarta bryła o małej powierzchni zabudowy to gwarancja, że koszty budowy i użytkowania nie będą wysokie. Atutem jest również to, że tego typu bryła zmieści się na niewielkiej działce.";s:21:"alternate_description";s:0:"";s:5:"price";d:3999;s:8:"discount";d:0;s:4:"type";s:8:"skeleton";s:6:"status";s:9:"published";s:14:"params_general";a:9:{i:1;a:3:{s:4:"name";s:14:"pow. użytkowa";s:5:"value";s:5:"54,45";s:4:"unit";s:13:"m<sup>2</sup>";}i:23;a:3:{s:4:"name";s:13:"pow. zabudowy";s:5:"value";s:4:"69,7";s:4:"unit";s:13:"m<sup>2</sup>";}i:75;a:3:{s:4:"name";s:20:"szerokość działki";s:5:"value";s:5:"17,25";s:4:"unit";s:1:"m";}i:76;a:3:{s:4:"name";s:19:"długość działki";s:5:"value";s:4:"14,8";s:4:"unit";s:1:"m";}i:68;a:3:{s:4:"name";s:13:"ilość pokoi";s:5:"value";s:1:"3";s:4:"unit";s:0:"";}i:27;a:3:{s:4:"name";s:21:"kąt nachylenia dachu";s:5:"value";s:2:"30";s:4:"unit";s:2:"°";}i:26;a:3:{s:4:"name";s:18:"wysokość budynku";s:5:"value";s:4:"5,88";s:4:"unit";s:1:"m";}i:17;a:1:{s:4:"name";s:19:"pow. netto poddasza";}i:18;a:1:{s:4:"name";s:18:"pow. netto piętra";}}s:11:"params_list";N;s:10:"build_cost";a:7:{s:6:"closed";N;s:4:"open";N;s:7:"fitting";N;s:6:"finish";N;s:4:"date";N;s:4:"full";N;s:4:"self";N;}s:10:"meta_title";s:81:"Tango V SZ. Dom parterowy w technologii szkieletowej na zgłoszenie. StudioAtrium";s:16:"meta_description";s:0:"";s:11:"modify_date";s:19:"2026-02-20 14:07:31";s:10:"technology";s:184:"Ściany w szkielecie drewnianym + ocieplenie z wełny mineralnej + płyty OSB + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";a:5:{s:10:"templateId";s:1:"1";s:16:"price_other_type";N;s:17:"skeleton_disabled";N;s:9:"thumbnail";s:39:"1648/wizualizacja-200-630cc2f8bcb16.jpg";s:14:"linkedProjects";a:1:{i:0;s:4:"1632";}}s:11:"attachments";a:3:{s:13:"ProjectRender";a:4:{i:0;a:14:{s:2:"id";i:47253;s:15:"__foreign_props";a:0:{}s:12:"profile_name";s:13:"ProjectRender";s:8:"filename";s:30:"wizualizacja-630cc2f8bcb16.jpg";s:4:"path";s:4:"1648";s:5:"title";s:133:"wizualizacja projektu domu Tango V SZ - drewniane elementy na elewacji dobrze komponują się z białym tynkiem i spiekami kwarcowymi";s:11:"description";s:0:"";s:9:"owner_uid";s:6:"421890";s:5:"props";a:5:{s:17:"original_filename";s:13:"9991556-F.jpg";s:4:"type";s:5:"image";s:10:"image_size";a:2:{s:5:"width";i:1920;s:6:"height";i:1280;}s:9:"file_size";i:348020;s:12:"file_created";i:1661780729;}s:7:"sorting";i:0;s:20:"parent_attachment_id";i:0;s:19:"parent_relationship";s:0:"";s:4:"_uid";i:12096773;s:16:"childAttachments";a:4:{s:12:"presentation";a:1:{i:0;a:14:{s:2:"id";i:47254;s:15:"__foreign_props";a:0:{}s:12:"profile_name";s:13:"ProjectRender";s:8:"filename";s:35:"wizualizacja-1350-630cc2f8bcb16.jpg";s:4:"path";s:4:"1648";s:5:"title";s:0:"";s:11:"description";s:0:"";s:9:"owner_uid";s:6:"421890";s:5:"props";a:5:{s:17:"original_filename";s:13:"9991556-F.jp