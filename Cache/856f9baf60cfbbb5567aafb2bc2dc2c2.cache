reated";i:1580994557;s:6:"storey";s:10:"parcel_dwg";}s:7:"sorting";s:1:"2";s:20:"parent_attachment_id";i:0;s:19:"parent_relationship";s:0:"";s:4:"_uid";i:10563077;s:16:"childAttachments";a:0:{}}i:2;a:14:{s:2:"id";i:43668;s:15:"__foreign_props";a:0:{}s:12:"profile_name";s:11:"ProjectFile";s:8:"filename";s:44:"5f17f0c870acd-gl_1286-pliszka_v-stolarka.pdf";s:4:"path";s:9:"1333/file";s:5:"title";s:20:"Zestawienie stolarki";s:11:"description";s:0:"";s:9:"owner_uid";s:6:"341250";s:5:"props";a:4:{s:17:"original_filename";s:30:"GL 1286-Pliszka V-stolarka.pdf";s:9:"file_size";i:331226;s:12:"file_created";i:1595404488;s:6:"storey";s:8:"woodwork";}s:7:"sorting";s:1:"3";s:20:"parent_attachment_id";i:0;s:19:"parent_relationship";s:0:"";s:4:"_uid";i:11179013;s:16:"childAttachments";a:0:{}}}}s:4:"_uid";i:341250;}i:3;a:25:{s:2:"id";i:1538;s:15:"__foreign_props";a:0:{}s:6:"id_old";s:1:"0";s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";s:4:"1480";s:4:"name";s:6:"Bosfor";s:14:"alternate_name";s:0:"";s:12:"search_names";s:16:"bosfor1,bosfor 1";s:17:"short_description";s:116:"Dom jednorodzinny, parterowy z poddaszem użytkowym, podpiwniczony, z dwuspadowym dachem i dwustanowiskowym garażem";s:11:"description";s:2075:"Bosfor to trzykondygnacyjny budynek, zaprojektowany na działki o dużym nachyleniu terenu. Zaprojektowaną na planie prostokąta bryłę wieńczy dwuspadowy dach. O nietuzinkowym charakterze tego budynku decydują przede wszystkim detale i zastosowane materiały wykończeniowe. Architekt zaproponował dwie wersje elewacji. W pierwszej zastosowano kontrastowe zestawienie bieli i grafitu. Jasny tynk zderzono z ciemnymi, wertykalnie ułożonymi deskami. W drugiej wersji zastosowano pionowe deskowanie na całym budynku. Elementami wspólnymi dla obu wersji są grafitowy dach pokryty dachówką typu tegalit, stolarka okienna w kolorze czerwonym oraz kamień na murach oporowych wokół piwnicy. Program użytkowy zapewni  wysoki komfort użytkowania czteroosobowej rodzinie. Do jej dyspozycji jest przyziemie, w którym mieści się nie tylko dwustanowiskowy garaż i pomieszczenia gospodarcze, takie jak kotłownia i pralnia. Kondygnacja ta obejmuje również strefę rekreacyjną, na którą składają się sauna i pomieszczenia, w których można zrelaksować się po dniu pracy. Parter mieści zarówno strefę dzienną, jak i sypialnię rodziców (master bedroom) z własną łazienką, garderobą i wyjściem na taras. W części dziennej uwagę przykuwa duża kuchnia ze spiżarnią, połączona z jadalnią, w której mieści się duży stół, stanowiący idealne miejsce na spotkania w dużym gronie rodziny i przyjaciół. Atutami pokoju dziennego są kominek oraz otwarta przestrzeń, stwarzająca wiele możliwości na ciekawą aranżację wnętrza. Program parteru uzupełniają przedsionek z szafą na odzież wierzchnią oraz w.c. Na poddaszu zaprojektowano dwie duże sypialnie i łazienkę. Bryłę domu uzupełnia przestronny taras otoczony szklaną balustradą, na który można wyjść zarówno z jadalni i pokoju dziennego, jak również z sypialni rodziców. Efektowna, narożna pergola tworzy funkcjonalne zadaszenie nad częścią tarasu. Bosfor to efektowny budynek, który świetnie wpisze się w podmiejskie działki z dużym spadkiem terenu.";s:21:"alternate_description";s:0:"";s:5:"price";d:5999;s:8:"discount";d:0;s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";a:9:{i:1;a:3:{s:4:"name";s:14:"pow. użytkowa";s:5:"value";s:5:"143,5";s:4:"unit";s:13:"m<sup>2</sup>";}i:23;a:3:{s:4:"name";s:13:"pow. zabudowy";s:5:"value";s:6:"168,25";s:4:"unit";s:13:"m<sup>2</sup>";}i:75;a:3:{s:4:"name";s:20:"szerokość działki";s:5:"value";s:4:"19,8";s:4:"unit";s:1:"m";}i:76;a:3:{s:4:"name";s:19:"długość działki";s:5:"value";s:4:"24,8";s:4:"unit";s:1:"m";}i:68;a:3:{s:4:"name";s:13:"ilość pokoi";s:5:"value";s:1:"4";s:4:"unit";s:0:"";}i:27;a:3:{s:4:"name";s:21:"kąt nachylenia dachu";s:5:"value";s:2:"38";s:4:"unit";s:2:"°";}i:26;a:3:{s:4:"name";s:18:"wysokość budynku";s:5:"value";s:5:"10,87";s:4:"unit";s:1:"m";}i:17;a:3:{s:4:"name";s:19:"pow. netto poddasza";s:5:"value";s:4:"81,4";s:4:"unit";s:13:"m<sup>2</sup>";}i:18;a:1:{s:4:"name";s:18:"pow. netto piętra";}}s:11:"params_list";N;s:10:"build_cost";a:7:{s:6:"closed";N;s:4:"open";N;s:7:"fitting";N;s:6:"finish";N;s:4:"date";N;s:4:"full";N;s:4:"self";N;}s:10:"meta_title";s:82:"Bosfor. Podpiwniczony dom z poddaszem na działki z dużym spadkiem. Studio Atrium";s:16:"meta_description";s:0:"";s:11:"modify_date";s:19:"2026-02-25 11:38:59";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 25 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";a:9:{s:10:"templateId";s:1:"3";s:16:"price_other_type";N;s:17:"skeleton_disabled";N;s:9:"thumbnail";s:46:"1538/bosfor-wizualizacja-200-613866f881add.jpg";s:4:"isbn";s:22:"ISBN 978-83-8145-154-3";s:11:"isbn_mirror";s:22:"ISBN 978-83-8145-155-0";s:8:"features";a:4:{i:0;s:2:"22";i:1;s:2:"28";i:2;s:2:"53";i:3;s:2:"54";}s:9:"newHouse1";s:6:"729100";s:9:"newHouse2";s:7:"1257500";}s:11:"attachments";a:7:{s:13:"ProjectRender";a:11:{i:0;a:14:{s:2:"id";i:42895;s:15:"__foreign_props";a:0:{}s:12:"profile_name";s:13:"ProjectRender";s:8:"filename";s:37:"bosfor-wizualizacja-613866f881add.jpg";s:4:"path";s:4:"1538";s:5:"title";s:104:"wizualizacja projektu domu Bosfor - ciekawie zadaszony i oświetlony taras nad garażem w podpiwniczeniu";s:11:"description";s:0:"";s:9:"owner_uid";s:6:"393730";s:5:"props";a:5:{s:17:"original_filename";s:10:"1480-F.jpg";s:4:"type";s:5:"image";s:10:"image_size";a:2:{s:5:"width";i:1920;s:6:"height";i:1280;}s:9:"file_size";i:346147;s:12:"file_created";i:1631086328;}s:7:"sorting";i:0;s:20:"parent_attachment_id";i:0;s:19:"parent_relationship";s:0:"";s:4:"_uid";i:10981125;s:16:"childAttachments";a:4:{s:12:"presentation";a:1:{i:0;a:14:{s:2:"id";i:42896;s:15:"__foreign_props";a:0:{}s:12:"profile_name";s:13:"ProjectRender";s:8:"filename";s:42:"bosfor-wizualizacja-1350-613866f881add.jpg";s:4:"path";s:4:"1538";s:5:"ti