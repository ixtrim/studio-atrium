;s:16:"childAttachments";a:0:{}s:6:"object";a:25:{s:2:"id";i:691;s:15:"__foreign_props";a:0:{}s:6:"id_old";s:3:"691";s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";s:3:"634";s:4:"name";s:5:"Astra";s:14:"alternate_name";s:0:"";s:12:"search_names";s:6:"astra1";s:17:"short_description";s:118:"Dom parterowy z poddaszem użytkowym i garażem, z lukarną i balkonem nad wejściem, z częściowo zadaszonym tarasem";s:11:"description";s:316:"Tradycyjne budownictwo w nowoczesnym wydaniu. Klasyczna bryła przykryta dwuspadowym dachem zyskuje nową jakość dzięki surowym, minimalistycznym balustradom zestawionym z drewnianą stolarką okienną i wykończeniom elewacji. Poddasze użytkowe kryje trzy pokoje, w tym jeden z własną łazienką i garderobą.";s:21:"alternate_description";s:0:"";s:5:"price";d:5299;s:8:"discount";d:0;s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";a:9:{i:1;a:3:{s:4:"name";s:14:"pow. użytkowa";s:5:"value";d:142.5;s:4:"unit";s:13:"m<sup>2</sup>";}i:23;a:3:{s:4:"name";s:13:"pow. zabudowy";s:5:"value";d:133.65000000000001;s:4:"unit";s:13:"m<sup>2</sup>";}i:75;a:3:{s:4:"name";s:20:"szerokość działki";s:5:"value";i:22;s:4:"unit";s:1:"m";}i:76;a:3:{s:4:"name";s:19:"długość działki";s:5:"value";d:18.149999999999999;s:4:"unit";s:1:"m";}i:68;a:3:{s:4:"name";s:13:"ilość pokoi";s:5:"value";i:5;s:4:"unit";s:0:"";}i:27;a:3:{s:4:"name";s:21:"kąt nachylenia dachu";s:5:"value";i:40;s:4:"unit";s:2:"°";}i:26;a:3:{s:4:"name";s:18:"wysokość budynku";s:5:"value";d:8.3399999999999999;s:4:"unit";s:1:"m";}i:17;a:3:{s:4:"name";s:19:"pow. netto poddasza";s:5:"value";d:97.25;s:4:"unit";s:13:"m<sup>2</sup>";}i:18;a:3:{s:4:"name";s:18:"pow. netto piętra";s:5:"value";N;s:4:"unit";s:13:"m<sup>2</sup>";}}s:11:"params_list";N;s:10:"build_cost";a:7:{s:6:"closed";N;s:4:"open";N;s:7:"fitting";N;s:6:"finish";N;s:4:"date";N;s:4:"full";s:6:"420045";s:4:"self";N;}s:10:"meta_title";s:0:"";s:16:"meta_description";s:0:"";s:11:"modify_date";s:19:"2026-02-27 14:50:46";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";a:7:{s:8:"features";a:2:{i:0;s:2:"10";i:1;s:1:"9";}s:9:"thumbnail";s:44:"691/astra-wizualizacja-200-5954e7e15d136.jpg";s:10:"templateId";s:1:"3";s:16:"price_other_type";N;s:17:"skeleton_disabled";N;s:4:"isbn";s:17:"978-83-7559-368-6";s:11:"isbn_mirror";s:17:"978-83-7559-372-3";}s:11:"attachments";a:0:{}s:4:"_uid";i:176898;}}i:2;a:15:{s:2:"id";i:42809;s:15:"__foreign_props";a:0:{}s:12:"profile_name";s:18:"ProjectRealisation";s:8:"filename";s:28:"realizacja-5e8494ce1bbde.jpg";s:4:"path";s:16:"1240/realisation";s:5:"title";s:28:"realizacja domu Merlin SP SZ";s:11:"description";s:56:"dom zrealizowany przez firmę MikroDom: www.mikro-dom.pl";s:9:"owner_uid";s:6:"317442";s:5:"props";a:6:{s:17:"original_filename";s:15:"melinspsz-2.jpg";s:4:"type";s:5:"image";s:10:"image_size";a:2:{s:5:"width";i:1920;s:6:"height";i:1280;}s:9:"file_size";i:264475;s:12:"file_created";i:1585747150;s:6:"storey";s:3:"yes";}s:7:"sorting";s:1:"2";s:20:"parent_attachment_id";i:0;s:19:"parent_relationship";s:0:"";s:4:"_uid";i:10959109;s:16:"childAttachments";a:0:{}s:6:"object";a:25:{s:2:"id";i:1240;s:15:"__foreign_props";a:0:{}s:6:"id_old";s:4:"1240";s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";s:7:"9991183";s:4:"name";s:12:"Merlin SP SZ";s:14:"alternate_name";s:0:"";s:12:"search_names";s:39:"merlinspsz,merlinsp sz,merlin spsz,1183";s:17:"short_description";s:185:"Parterowy dom w technologii szkieletowej na płycie fundamentowej, z dwustanowiskowym garażem i kotłownią na paliwo stałe, z rekuperacją, idealny na działki z wjazdem od południa";s:11:"description";s:925:"Funkcjonalna parterówka dla czteroosobowej rodziny zaprojektowana w technologii szkieletowej. Zlokalizowany od frontu pokój dzienny z aneksem kuchennym oraz zadaszony taras czynią ten projekt atrakcyjnym na działki z wjazdem od południa lub zachodu. W tylnej części domu mieści się strefa sypialna obejmująca pokój rodziców z garderobą, dwa pokoje dziecięce oraz łazienkę. Przemyślana część gospodarcza, w której skład wchodzą kotłownia na paliwo stałe oraz pralnia, podnoszą komfort użytkowania. Na elewacji bocznej zaprojektowano wygodny dwustanowiskowy garaż, który podobnie jak bryła budynku mieszkalnego, przykryty jest dwuspadowym dachem. Budynek cechuje chłodna, stonowana kolorystyka sprawiająca, że ta prosta bryła nabiera niezwykle eleganckiego wyrazu. Istotnym atutem tego domu jest fakt, że posiada on rekuperację. Zgodność ze standardem NF40 czyni ten dom energooszczędnym.";s:21:"alternate_description";s:0:"";s:5:"price";d:5099;s:8:"discount";d:0;s:4:"type";s:8:"skeleton";s:6:"status";s:9:"published";s:14:"params_general";a:9:{i:1;a:3:{s:4:"name";s:14:"pow. użytkowa";s:5:"value";s:6:"106,05";s:4:"unit";s:13:"m<sup>2</sup>";}i:23;a:3:{s:4:"name";s:13:"pow. zabudowy";s:5:"value";s:5:"206,2";s:4:"unit";s:13:"m<sup>2</sup>";}i:75;a:3:{s:4:"name";s:20:"szerokość działki";s:5:"value";s:5:"27,18";s:4:"unit";s:1:"m";}i:76;a:3:{s:4:"name";s:19:"długość działki";s:5:"value";s:5:"19,19";s:4:"unit";s:1:"m";}i:68;a:3:{s:4:"name";s:13:"ilość pokoi";s:5:"value";s:1:"4";s:4:"unit";s:0:"";}i:27;a:3:{s:4:"name";s:21:"kąt nachylenia dachu";s:5:"value";s:2:"38";s:4:"unit";s:2:"°";}i:26;a:3:{s:4:"name";s:18:"wysokość budynku";s:5:"value";s:4:"8,24";s:4:"unit";s:1:"m";}i:17;a:1:{s:4:"name";s:19:"pow. netto poddasza";}i:18;a:1:{s:4:"name";s:18:"pow. netto piętra";}}s:11:"params_list";N;s:10:"build_cost";a:7:{s:6:"closed";N;s:4:"open";N;s:7:"fitting";N;s:6:"finish";N;s:4:"date";N;s:4:"full";s:6:"335074";s:4:"self";N;}s:10:"meta_title";s:83:"Merlin SP SZ. Energooszczędny parterowy dom szkieletowy z kotłownią na paliwo st";s:16:"meta_description";s:0:"";s:11:"modify_date";s:19:"2026-02-23 13:21:29";s:10:"technology";s:202:"Ściany w szkielecie drewnianym + ocieplenie z wełny mineralnej + płyty OSB + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";a:9:{s:16:"price_other_type";N;s:9:"thumbnail";s:52:"1240/merlin-sp-sz-wizualizacja-200-5954fc3da364e.jpg";s:10:"templateId";s:1:"1";s:8:"features";a:4:{i:0;s:1:"1";i:1;s:2:"36";i:2;s:1:"2";i:3;s:1:"3";}s:17:"skeleton_disabled";N;s:14:"linkedProjects";a:1:{i:0;s:4:"1399";}s:4:"isbn";s:17:"978-83-7937-844-9";s:11:"isbn_mirror";s:17:"978-83-7937-845-6";s:9:"sun_ratio";s:6:"0.0177";}s:11:"attachments";a:0:{}s:4:"_uid";i:317442;}}}i:1;N;}";}