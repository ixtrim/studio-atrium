a:3:{s:3:"key";s:32:"20bf306a678a7ecc4957e30a126436b8";s:3:"ttl";i:1800;s:5:"value";s:10623:"a:2:{i:0;a:3:{i:0;a:15:{s:2:"id";i:29708;s:15:"__foreign_props";a:0:{}s:12:"profile_name";s:18:"ProjectRealisation";s:8:"filename";s:28:"realizacja-59807d18bd7e7.jpg";s:4:"path";s:15:"386/realisation";s:5:"title";s:24:"Realizacja domu Radość";s:11:"description";s:0:"";s:9:"owner_uid";s:5:"98818";s:5:"props";a:6:{s:17:"original_filename";s:11:"radosc2.jpg";s:4:"type";s:5:"image";s:10:"image_size";a:2:{s:5:"width";i:1920;s:6:"height";i:1280;}s:9:"file_size";i:204393;s:12:"file_created";i:1501592857;s:6:"storey";s:3:"yes";}s:7:"sorting";s:1:"2";s:20:"parent_attachment_id";i:0;s:19:"parent_relationship";s:0:"";s:4:"_uid";i:7605253;s:16:"childAttachments";a:0:{}s:6:"object";a:25:{s:2:"id";i:386;s:15:"__foreign_props";a:0:{}s:6:"id_old";s:3:"386";s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";s:3:"346";s:4:"name";s:8:"Radość";s:14:"alternate_name";s:0:"";s:12:"search_names";s:0:"";s:17:"short_description";s:117:"Dom parterowy z poddaszem użytkowym i garażem, z niezadaszonym tarasem, idealny na wąską działkę, podpiwniczony";s:11:"description";s:523:"Klasyczną bryłę nakrytą dwuspadowym dachem wyróżnia urokliwy, dobudowany z boku przedsionek, który wykończono ozdobnym kamieniem w ciepłym odcieniu, a drewniane okiennice nadają całości sielankowego charakteru. Kuchnię oddzielono od pozostałych pomieszczeń, dzięki czemu przygotowanie posiłków będzie możliwe w spokojnych warunkach, wciąż jednak w pobliżu jadalni i pokoju dziennego. Podpiwniczenie całości budynku wygenerowało sporą przestrzeń gospodarczą oraz miejsce na garaż i kotłownię.";s:21:"alternate_description";s:0:"";s:5:"price";d:5199;s:8:"discount";d:0;s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";a:9:{i:1;a:3:{s:4:"name";s:14:"pow. użytkowa";s:5:"value";s:6:"105,20";s:4:"unit";s:13:"m<sup>2</sup>";}i:23;a:3:{s:4:"name";s:13:"pow. zabudowy";s:5:"value";s:5:"97,15";s:4:"unit";s:13:"m<sup>2</sup>";}i:75