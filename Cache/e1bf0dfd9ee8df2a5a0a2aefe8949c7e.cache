e";s:9:"parent_id";i:55;s:11:"description";s:0:"";s:17:"short_description";s:0:"";s:12:"project_list";s:19:"1489,1492,1490,1491";s:20:"project_list_by_area";s:19:"1489,1492,1491,1490";s:7:"sorting";i:2;s:12:"is_highlight";i:0;s:13:"menu_position";i:3;s:10:"meta_title";s:0:"";s:16:"meta_description";s:0:"";s:6:"status";s:9:"published";s:8:"children";a:0:{}}}}i:1;a:17:{s:2:"id";i:48;s:4:"tree";s:5:"other";s:4:"name";s:18:"Mała architektura";s:14:"alternate_name";s:0:"";s:4:"link";s:26:"projekty/mala-architektura";s:9:"parent_id";i:0;s:11:"description";N;s:17:"short_description";N;s:12:"project_list";s:54:"1252,1100,1251,1508,1255,1104,1105,1262,1265,1264,1261";s:20:"project_list_by_area";s:34:"1255,1252,1104,1100,1105,1251,1508";s:7:"sorting";i:2;s:12:"is_highlight";i:0;s:13:"menu_position";i:2;s:10:"meta_title";s:79:"Mała archiektura - projekty wiat, altan ogrodowych i ogrodzeń | Studio Atrium";s:16:"meta_description";s:93:"Praktyczne i przydatne projekty małej architektury, wiaty i altany ogrodowe oraz ogrodzenia.";s:6:"status";s:9:"published";s:8:"children";a:3:{i:0;a:17:{s:2:"id";i:51;s:4:"tree";s:5:"other";s:4:"name";s:10:"Ogrodzenia";s:14:"alternate_name";s:0:"";s:4:"link";s:19:"projekty/ogrodzenia";s:9:"parent_id";i:48;s:11:"description";s:0:"";s:17:"short_description";s:0:"";s:12:"project_list";s:19:"1265,1264,1262,1261";s:20:"project_list_by_area";s:19:"1265,1264,1262,1261";s:7:"sorting";i:3;s:12:"is_highlight";i:0;s:13:"menu_position";i:2;s:10:"meta_title";s:0:"";s:16:"meta_description";s:0:"";s:6:"status";s:9:"published";s:8:"children";a:0:{}}i:1;a:17:{s:2:"id";i:37;s:4:"tree";s:5:"other";s:4:"name";s:5:"Wiaty";s:14:"alternate_name";s:0:"";s:4:"link";s:14:"projekty/wiaty";s:9:"parent_id";i:48;s:11:"description";s:375:"Wiata garażowa stanowi tańszą alternatywę dla tradycyjnego garażu wolnostojącego. Jej lekka konstrukcja ułatwia realizację, a dach chroni przed czynnikami atmosferycznymi. Może ona także pełnić inne funkcje: gospodarcze - jako podręczny, ogrodowy składzik, czy towarzyskie, stając się wtedy altaną służącą do miłego spędzania czasu na wolnym powietrzu.";s:17:"short_description";s:0:"";s:12:"project_list";s:14:"1105,1104,1508";s:20:"project_list_by_area";s:14:"1104,1105,1508";s:7:"sorting";i:4;s:12:"is_highlight";i:0;s:13:"menu_position";i:3;s:10:"meta_title";s:40:"Wiaty garażowe - projekty Studio Atrium";s:16:"meta_description";s:25:"Projekty wiat garażowych";s:6:"status";s:9:"published";s:8:"children";a:0:{}}i:2;a:17:{s:2:"id";i:34;s:4:"tree";s:5:"other";s:4:"name";s:6:"Altany";s:14:"alternate_name";s:0:"";s:4:"link";s:15:"projekty/altany";s:9:"parent_id";i:48;s:11:"description";s:291:"Przedstawiamy Państwu projekty altan, które znakomicie uzupełnią przydomowe obejście. Jest to atrakcyjna i niedroga propozycja nie tylko dla amatorów rodzinnych biesiad na świeżym powietrzu ale altana w razie potrzeby z powodzeniem może pełnić również funkcję wiaty garażowej.";s:17:"short_description";s:0:"";s:12:"project_list";s:19:"1255,1252,1251,1100";s:20:"project_list_by_area";s:19:"1255,1252,1100,1251";s:7:"sorting";i:5;s:12:"is_highlight";i:0;s:13:"menu_position";i:3;s:10:"meta_title";s:31:"Altany - projekty Studio Atrium";s:16:"meta_description";s:50:"Projekty altan, altany z funkcją wiaty garażowej";s:6:"status";s:9:"published";s:8:"children";a:0:{}}}}i:2;a:17:{s:2:"id";i:30;s:4:"tree";s:5:"other";s:4:"name";s:16:"Projekty garaży";s:14:"alternate_name";s:0:"";s:4:"link";s:0:"";s:9:"parent_id";i:0;s:11:"description";s:0:"";s:17:"short_description";s:0:"";s:12:"project_list";s:0:"";s:20:"project_list_by_area";s:0:"";s:7:"sorting";i:3;s:12:"is_highlight";i:0;s:13:"menu_position";i:1;s:10:"meta_title";s:0:"";s:16:"meta_description";s:0:"";s:6:"status";s:9:"published";s:8:"children";a:3:{i:0;a:17:{s:2:"id";i:32;s:4:"tree";s:5:"other";s:4:"name";s:25:"Garaże wielostanowiskowe";s:14:"alternate_name";s:0:"";s:4:"link";s:33:"projekty-garazy/wielostanowiskowe";s:9:"parent_id";i:30;s:11:"description";s:634:"Z myślą o właścicielach domów, którzy posiadają dwa, a nawet trzy samochody, przygotowaliśmy ofertę projektów garaży
wielostanowiskowych. Nasze rozwiązania zostały przygotowane w taki sposób, aby uwzględniać zarówno wymogi
budowlane, jak i stylistyczne. Doskonale wpasowują się w architekturę posesji i tworzą spójną całość z budynkiem
mieszkalnym. Ich dodatkową zaletą jest dodatkowo wydzielona przestrzeń gospodarcza, w której można zgromadzić
różnego rodzaju sprzęty czy urządzenia. Zapewniamy możliwość dostosowania poszczególnych parametrów do
określonych potrzeb naszych Klientów.";s:17:"short_description";s:156:"Najczęściej dwustanowiskowe, ale także garaże z większą ilością stanowisk. Zróżnicowane architektonicznie by ułatwić ci wybór tego najlepszego.";s:12:"project_list";s:137:"1779,1778,544,1503,1418,509,506,606,655,1374,155,513,701,656,38,1361,893,510,370,593,35,37,508,511,512,514,1168,546,700,1076,829,545,1075";s:20:"project_list_by_area";s:137:"1779,893,155,656,37,1076,35,38,1361,1418,829,606,593,1168,546,545,1075,509,655,508,513,514,701,700,1503,512,511,506,370,1778,1374,510,544";s:7:"sorting";i:1;s:12:"is_highlight";i:0;s:13:"menu_position";i:1;s:10:"meta_title";s:52:"Projekty Garaży Wielostanowiskowych | Studio Atrium";s:16:"meta_description";s:163:"Garaże dwu i wielostanowiskowe wolnostojące ➤ Gotowe projekty ➤ Parterowe, z wiatą, strychem i pomieszczeniem gospodarczym. Różne style i dachy. Sprawdź!";s:6:"status";s:9:"published";s:8:"children";a:0:{}}i:1;a:17:{s:2:"id";i:31;s:4:"tree";s:5:"other";s:4:"name";s:25:"Garaże jednostanowiskowe";s:14:"alternate_name";s:0:"";s:4:"link";s:33:"projekty-garazy/jednostanowiskowe";s:9:"parent_id";i:30;s:11:"description";s:576:"W ofercie naszego biura znajdziecie Państwo także projekty garaży jednostanowiskowych. Jest to propozycja stworzona dla właścicieli domów, którzy posiadają jeden samochód. Nasza oferta obejmuje obiekty utrzymane zarówno w nowoczesnej, i tradycyjnej stylistyce, o różnorodnej powierzchni użytkowej, dzięki czemu każdy z Państwa będzie mógł znaleźć tu rozwiązanie idealnie komponujące się z architekturą budynku mieszkalnego a także odpowiadające wielkości samochodu. Istnieje także możliwość dostosowania obiektu do konkretnych wymagań klienta.";s:17:"short_description";s:139:"Garaże wolnostojące przeznaczone dla jednego samochodu. Różne style, różne dachy, abys z łatwością dostosował je do swojego domu.";s:12:"project_list";s:43:"1420,1451,1362,539,31,323,36,34,540,652,654";s:20:"project_list_by_area";s:43:"323,34,36,1362,31,540,652,654,539,1420,1451";s:7:"sorting";i:2;s:12:"is_highlight";i:0;s:13:"menu_position";i:1;s:10:"meta_title";s:70:"Projekty Garaży Jednostanowiskowych - Najniższe Ceny | Studio Atrium";s:16:"meta_description";s:168:"Garaże jednostanowiskowe wolnostojące ➤ Duży wybór gotowych projektów ➤ Parterowe, z wiatą i strychem. Różne style i dachy. Wybierz projekt swojego garażu!";s:6:"status";s:9:"published";s:8:"children";a:0:{}}i:2;a:17:{s:2:"id";i:35;s:4:"tree";s:5:"other";s:4:"name";s:26:"Wszystkie projekty garaży";s:14:"alternate_name";s:0:"";s:4:"link";s:15:"projekty-garazy";s:9:"parent_id";i:30;s:11:"description";s:681:"Oprócz projektów domów, proponujemy Państwu także nowoczesne i dopracowane w detalach projekty garaży.
Przedstawiamy bardzo szerokie spektrum gotowych rozwiązań, co pozwoli każdemu znaleźć konstrukcję optymalnie dopasowaną do jego indywidualnych potrzeb oraz oczekiwań. Oferowane przez naszą firmę koncepcje garaży, wykonane zostały przez doświadczonych architektów. Jako równorzędne potraktowali oni zarówno aspekty wizualne, jak i użytkowe. Decydując się na naszą propozycję, z pewnością się Państwo nie rozczarujecie. Wykorzystując nasze gotowe koncepty, zyskujecie kompleksowe rozwiązanie, przy jednoczesnej oszczędności czasu i pieniędzy.";s:17:"short_description";s:0:"";s:12:"project_list";s:181:"1779,1778,1503,1418,544,1451,1420,539,1374,512,655,514,540,155,652,511,509,656,513,701,38,506,1361,1362,508,893,510,593,370,1168,37,829,1076,654,35,323,606,1075,700,34,546,31,545,36";s:20:"project_list_by_area";s:181:"323,34,36,1362,31,540,652,654,539,1420,1451,1779,893,155,656,37,1076,35,38,1361,1418,829,593,606,1168,546,545,1075,655,509,508,514,513,701,700,1503,512,511,506,370,1778,1374,510,544";s:7:"sorting";i:2;s:12:"is_highlight";i:0;s:13:"menu_position";i:1;s:10:"meta_title";s:48:"Projekty Garaży Wolnostojących | Studio Atrium";s:16:"meta_description";s:157:"Garaże wolnostojące ➤ Ponad 30 gotowych projektów garaży jedno i wielostanowiskowych ➤ Niskie ceny i wysoka jakość wykonania. Wybierz swój garaż!";s:6:"status";s:9:"published";s:8:"children";a:0:{}}}}}}s:3:"exp";i:1779795637;}