a:3:{s:3:"key";s:32:"e3c0b2b2068a7249ff4636366314fcd4";s:3:"ttl";i:1800;s:5:"value";s:12464:"a:2:{i:0;a:3:{i:0;a:15:{s:2:"id";i:30891;s:15:"__foreign_props";a:0:{}s:12:"profile_name";s:26:"ProjectRealisationInterior";s:8:"filename";s:24:"budowa-599c3955b0ddb.jpg";s:4:"path";s:15:"834/realisation";s:5:"title";s:26:"Realizacja domu Jupiter II";s:11:"description";s:17:"Wnętrze: kuchnia";s:9:"owner_uid";s:6:"213506";s:5:"props";a:6:{s:17:"original_filename";s:11:"jupiter.jpg";s:4:"type";s:5:"image";s:10:"image_size";a:2:{s:5:"width";i:1920;s:6:"height";i:1280;}s:9:"file_size";i:230251;s:12:"file_created";i:1503410519;s:6:"storey";s:3:"yes";}s:7:"sorting";s:1:"2";s:20:"parent_attachment_id";i:0;s:19:"parent_relationship";s:0:"";s:4:"_uid";i:7908101;s:16:"childAttachments";a:0:{}s:6:"object";a:25:{s:2:"id";i:834;s:15:"__foreign_props";a:0:{}s:6:"id_old";s:3:"834";s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";s:3:"794";s:4:"name";s:10:"Jupiter II";s:14:"alternate_name";s:0:"";s:12:"search_names";s:28:"jupiter2,jupiter 2,jupiterii";s:17:"short_description";s:85:"Dom parterowy z poddaszem użytkowym, 2-stanowiskowym garażem i przestronnym tarasem";s:11:"description";s:1411:"Doskonały wybór dla ceniących sobie komfort użytkowania i otwartą przestrzeń. Tych, którzy chętnie zapraszają gości i organizują domowe przyjęcia, z pewnością ucieszy obszerny pokój dzienny z wyjściem na taras, miejsce na duży stół jadalny oraz przestronna i funkcjonalna kuchnia z wyspą pośrodku. Gromadzenie domowych zapasów ułatwi sąsiadująca z kuchnią spiżarka, a do wspólnej rekreacji zaprasza pokój zaprojektowany nad dwustanowiskowym garażem, który pomieści mini kino domowe, stół bilardowy lub sprzęt do ćwiczeń. Dodatkowym atutem tego projektu domu jest również gabinet na parterze, który świetnie sprawdzi się jako pokój gościnny lub pracownia. Na uwagę zasługuje również sporych rozmiarów przedsionek, w którym bez problemu można zorganizować małą garderobę w postaci szaf do zabudowy. Dwustanowiskowy garaż oprócz swej podstawowej funkcji, zapewni również miejsce dla sprzętu ogrodowego, rowerów lub innych urządzeń domowych. Na poddaszu architekt zaprojektował ogromną, ponad trzydziestometrową sypialnię bez skosów, z ryzalitem i wyjściem na balkon. Oprócz niej do dyspozycji będą jeszcze dwa ustawne pokoje, w tym jeden z dostępem na wspomniany balkon. Ten dom to świetne rozwiązanie dla miłośników sporych przestrzeni i praktycznych rozwiązań. Swe miejsce odnajdzie tu każdy członek nawet pięcioosobowej rodziny.";s:21:"alternate_description";s:0:"";s:5:"price";d:5999;s:8:"discount";d:355;s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";a:9:{i:1;a:3:{s:4:"name";s:14:"pow. użytkowa";s:5:"value";s:5:"182,9";s:4:"unit";s:13:"m<sup>2</sup>";}i:23;a:3:{s:4:"name";s:13:"pow. zabudowy";s:5:"value";s:5:"176,5";s:4:"unit";s:13:"m<sup>2</sup>";}i:75;a:3:{s:4:"name";s:20:"szerokość działki";s:5:"value";s:4:"24,7";s:4:"unit";s:1:"m";}i:76;a:3:{s:4:"name";s:19:"długość działki";s:5:"value";s:4:"19,9";s:4:"unit";s:1:"m";}i:68;a:3:{s:4:"name";s:13:"ilość pokoi";s:5:"value";s:1:"5";s:4:"unit";s:0:"";}i:27;a:3:{s:4:"name";s:21:"kąt nachylenia dachu";s:5:"value";s:2:"35";s:4:"unit";s:2:"°";}i:26;a:3:{s:4:"name";s:18:"wysokość budynku";s:5:"value";s:3:"9,1";s:4:"unit";s:1:"m";}i:17;a:3:{s:4:"name";s:19:"pow. netto poddasza";s:5:"value";s:5:"139,9";s:4:"unit";s:13:"m<sup>2</sup>";}i:18;a:1:{s:4:"name";s:18:"pow. netto piętra";}}s:11:"params_list";N;s:10:"build_cost";a:7:{s:6:"closed";N;s:4:"open";N;s:7:"fitting";N;s:6:"finish";N;s:4:"date";N;s:4:"full";s:6:"518980";s:4:"self";N;}s:10:"meta_title";s:82:"Jupiter II. Dom z poddaszem, garażem na 2 auta i dużą sypialnią. Studio Atrium";s:16:"meta_description";s:0:"";s:11:"modify_date";s:19:"2026-02-27 12:06:54";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";a:7:{s:9:"thumbnail";s:49:"834/jupiter-ii-wizualizacja-200-5954e616b09df.jpg";s:10:"templateId";s:1:"3";s:16:"price_other_type";N;s:17:"skeleton_disabled";N;s:8:"features";a:3:{i:0;s:2:"10";i:1;s:2:"47";i:2;s:2:"27";}s:4:"isbn";s:17:"978-83-7559-677-9";s:11:"isbn_mirror";s:17:"978-83-7559-681-6";}s:11:"attachments";a:0:{}s:4:"_uid";i:213506;}}i:1;a:15:{s:2:"id";i:46972;s:15:"__foreign_props";a:0:{}s:12:"profile_name";s:26:"ProjectRealisationInterior";s:8:"filename";s:24:"budowa-62bbfd6d2e4bc.jpg";s:4:"path";s:16:"1477/realisation";s:5:"title";s:23:"wnętrze projektu Lopez";s:11:"description";s:37:"panoramiczne okno w pokoju na strychu";s:9:"owner_uid";s:6:"378114";s:5:"props";a:6:{s:17:"original_filename";s:6:"w4.jpg";s:4:"type";s:5:"image";s:10:"image_size";a:2:{s:5:"width";i:1920;s:6:"height";i:1204;}s:9:"file_size";i:238784;s:12:"file_created";i:1656487277;s:6:"storey";s:3:"yes";}s:7:"sorting";s:1:"6";s:20:"parent_attachment_id";i:0;s:19:"parent_relationship";s:0:"";s:4:"_uid";i:12024837;s:16:"childAttachments";a:0:{}s:6:"object";a:25:{s:2:"id";i:1477;s:15:"__foreign_props";a:0:{}s:6:"id_old";s:1:"0";s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";s:4:"1433";s:4:"name";s:5:"Lopez";s:14:"alternate_name";s:0:"";s:12:"search_names";s:20:"lopez1,lopez 1,lopes";s:17:"short_description";s:99:"Dom jednorodzinny, parterowy ze strychem, z dwustanowiskowym garażem, przykryty dwuspadowym dachem";s:11:"description";s:1454:"Lopez to projekt komfortowego domu parterowego z dwustanowiskowym garażem. Zaprojektowana na planie prostokąta bryła, przykryta dwuspadowym dachem nawiązuje do stylistyki "stodoły". Ważną rolę odgrywają tutaj materiały wykończeniowe, które świetnie współgrają ze sobą, tworząc bryłę o nietuzinkowym charakterze. Zastosowanie drewna i kamienia sprawia, że budynek świetnie wpisuje się w naturalny krajobraz podmiejski. Parter mieści zarówno strefę dzienną, jak i sypialną. Sercem części dziennej jest przestronny salon z jadalnią, nad którym pozostawiono otwartą przestrzeń. Poprzez duże przeszklenie pomieszczenie to jest jasne i otwarte na strefę ogrodową. Wnętrze zdobi kominek oraz ażurowe, spiralne schody na strych. Atutami dużej kuchni są funkcjonalna spiżarnia oraz wyspa, będąca centralnym punktem aranżacji wnętrza. Uwagę zwraca również duża sypialnia z własną łazienką i wyjściem na taras. Ponadto w programie parteru przewidziano gabinet, ogólnodostępną łazienkę, kotłownię oraz przestronny przedsionek, który stanowi pomieszczenie komunikacyjne pomiędzy strefą mieszkalną a garażem. Do dyspozycji domowników i ich gości jest przestrzeń strychu, w ramach którego wydzielono kilka pomieszczeń, w których można umieścić sypialnie, miejsce na pracownię lub hobby. Lopez to doskonała propozycja dla Inwestorów ceniących indywidualność, prostotę i funkcjonalność.";s:21:"alternate_description";s:0:"";s:5:"price";d:5499;s:8:"discount";d:0;s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";a:9:{i:1;a:3:{s:4:"name";s:14:"pow. użytkowa";s:5:"value";s:5:"101,9";s:4:"unit";s:13:"m<sup>2</sup>";}i:23;a:3:{s:4:"name";s:13:"pow. zabudowy";s:5:"value";s:5:"179,6";s:4:"unit";s:13:"m<sup>2</sup>";}i:75;a:3:{s:4:"name";s:20:"szerokość działki";s:5:"value";s:2:"22";s:4:"unit";s:1:"m";}i:76;a:3:{s:4:"name";s:19:"długość działki";s:5:"value";s:2:"23";s:4:"unit";s:1:"m";}i:68;a:3:{s:4:"name";s:13:"ilość pokoi";s:5:"value";s:1:"3";s:4:"unit";s:0:"";}i:27;a:3:{s:4:"name";s:21:"kąt nachylenia dachu";s:5:"value";s:2:"40";s:4:"unit";s:2:"°";}i:26;a:3:{s:4:"name";s:18:"wysokość budynku";s:5:"value";s:4:"7,17";s:4:"unit";s:1:"m";}i:17;a:1:{s:4:"name";s:19:"pow. netto poddasza";}i:18;a:1:{s:4:"name";s:18:"pow. netto piętra";}}s:11:"params_list";N;s:10:"build_cost";a:7:{s:6:"closed";N;s:4:"open";N;s:7:"fitting";N;s:6:"finish";N;s:4:"date";N;s:4:"full";N;s:4:"self";N;}s:10:"meta_title";s:82:"Lopez. Parterowy mały dom ze strychem w stylu nowoczesnej stodoły. Studio Atrium";s:16:"meta_description";s:0:"";s:11:"modify_date";s:19:"2026-02-19 15:44:31";s:10:"technology";s:235:"Technologia murowana: pustak ceramiczny gr. 25 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: część mieszkalna - blacha tytanowo-cynkowa, garaż - papa termozgrzewalna. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";a:7:{s:10:"templateId";s:1:"3";s:16:"price_other_type";N;s:17:"skeleton_disabled";N;s:9:"thumbnail";s:45:"1477/lopez-wizualizacja-200-5f72f9a2c5ff0.jpg";s:8:"features";a:1:{i:0;s:2:"53";}s:9:"newHouse1";s:6:"459200";s:9:"newHouse2";s:6:"834500";}s:11:"attachments";a:0:{}s:4:"_uid";i:378114;}}i:2;a:15:{s:2:"id";i:30384;s:15:"__foreign_props";a:0:{}s:12:"profile_name";s:26:"ProjectRealisationInterior";s:8:"filename";s:24:"budowa-599445b0b5314.jpg";s:4:"path";s:15:"192/realisation";s:5:"title";s:22:"Realizacja domu Ostoja";s:11:"description";s:17:"Wnętrze: kuchnia";s:9:"owner_uid";s:5:"49154";s:5:"props";a:6:{s:17:"original_filename";s:10:"ostoja.jpg";s:4:"type";s:5:"image";s:10:"image_size";a:2:{s:5:"width";i:1920;s:6:"height";i:1280;}s:9:"file_size";i:223142;s:12:"file_created";i:1502889394;s:6:"storey";s:3:"yes";}s:7:"sorting";s:1:"1";s:20:"parent_attachment_id";i:0;s:19:"parent_relationship";s:0:"";s:4:"_uid";i:7778309;s:16:"childAttachments";a:0:{}s:6:"object";a:25:{s:2:"id";i:192;s:15:"__foreign_props";a:0:{}s:6:"id_old";s:3:"192";s:12:"symbol_alpha";s:2:"GL";s:10:"symbol_num";s:3:"174";s:4:"name";s:6:"Ostoja";s:14:"alternate_name";s:0:"";s:12:"search_names";s:24:"ostoja1,ostoja 1,ostojai";s:17:"short_description";s:86:"Dom parterowy z tarasem w podcieniu oraz jednostanowiskowym garażem, energooszczędny";s:11:"description";s:898:"Ostoja będzie nią z pewnością dla wszystkich domowników. Elegancka bryła zwieńczona kopertowym dachem ukrywa trzy sypialnie i salon, połączony z jadalnią. To w nim zapewne będzie się skupiać życie rodzinne. Zlokalizowana we frontowej części domu kuchnia posiada dostęp do spiżarni. Przemyślany rozkład pomieszczeń zapewni komfortowe użytkowanie domu, podobnie jak położona blisko garażu kotłownia oraz osobna toaleta dla gości. Ostoja to dom uniwersalny, który może zainteresować zarówno zwolenników tradycyjnej, jak i nowoczesnej architektury. Ze względu na garaż wysunięty przed bryłę budynku świetnie sprawdzi się nawet na niezbyt szerokich działkach, z wjazdem od wschodu lub północy. W ofercie dostępna jest również wersja przeznaczona na działki z wjazdem od południa i od zachodu o nazwie <a href="/projekty-domow/Floryda,201.html">Floryda</a>.";s:21:"alternate_description";s:0:"";s:5:"price";d:4799;s:8:"discount";d:0;s:4:"type";s:5:"house";s:6:"status";s:9:"published";s:14:"params_general";a:9:{i:1;a:3:{s:4:"name";s:14:"pow. użytkowa";s:5:"value";s:6:"114,85";s:4:"unit";s:13:"m<sup>2</sup>";}i:23;a:3:{s:4:"name";s:13:"pow. zabudowy";s:5:"value";s:6:"192,80";s:4:"unit";s:13:"m<sup>2</sup>";}i:75;a:3:{s:4:"name";s:20:"szerokość działki";s:5:"value";s:4:"20,3";s:4:"unit";s:1:"m";}i:76;a:3:{s:4:"name";s:19:"długość działki";s:5:"value";s:5:"26,05";s:4:"unit";s:1:"m";}i:68;a:3:{s:4:"name";s:13:"ilość pokoi";s:5:"value";s:1:"4";s:4:"unit";s:0:"";}i:27;a:3:{s:4:"name";s:21:"kąt nachylenia dachu";s:5:"value";s:2:"30";s:4:"unit";s:2:"°";}i:26;a:3:{s:4:"name";s:18:"wysokość budynku";s:5:"value";s:3:"7,4";s:4:"unit";s:1:"m";}i:17;a:1:{s:4:"name";s:19:"pow. netto poddasza";}i:18;a:1:{s:4:"name";s:18:"pow. netto piętra";}}s:11:"params_list";N;s:10:"build_cost";a:7:{s:6:"closed";N;s:4:"open";N;s:7:"fitting";N;s:6:"finish";N;s:4:"date";N;s:4:"full";s:6:"332825";s:4:"self";N;}s:10:"meta_title";s:76:"Ostoja. Energooszczędny parterowy dom z tarasem w podcieniu - Studio Atrium";s:16:"meta_description";s:0:"";s:11:"modify_date";s:19:"2026-02-23 15:42:14";s:10:"technology";s:174:"Technologia murowana: pustak ceramiczny gr. 30 cm + ocieplenie w systemie Termo Organika. Pokrycie dachu: dachówka Braas. Brama garażowa i drzwi zewnętrzne marki Hörmann.";s:10:"extra_data";a:7:{s:9:"thumbnail";s:45:"192/ostoja-wizualizacja-200-5954d3e90f1d9.jpg";s:10:"