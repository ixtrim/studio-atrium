RewriteRule ^/?(projekty/(?:wiaty|altany|osadniki|ogrodzenia|gospodarcze|mala-architektura))/?$ index.php?module=project&action=list&category=$1 [L,NS]

#project's API
RewriteRule ^/?api/([^\/]+)/project/([0-9]+).json$ index.php?module=api&action=project&id=$2&signature=$1 [L,NS]
#RewriteRule ^/?api/([^\/]+)/list/([0-9]+)/([^\.]+).json$ index.php?module=api&action=list&category=$3&limit=$2&sort_order=ASC&signature=$1 [L,NS,QSA]
#RewriteRule ^/?api/([^\/]+)/list/([^\.]+).json$ index.php?module=api&action=list&category=$2&signature=$1 [L,NS]

#Katalog firm
RewriteRule ^/?katalog-firm/lista.html?$ index.php?module=companies&action=list [L,NS]

#PANEL I LOGOWANIE
RewriteRule ^/?wyloguj/?$ index.php?module=authenticate&action=logout [L,NS]
RewriteRule ^/?panel/?$ index.php?module=panel&action=helo [L,NS]
RewriteRule ^/?panel/twoje-konto.html?$ index.php?module=panel&action=account [L,NS]
RewriteRule ^/?panel/usun-konto.html?$ index.php?module=panel&action=account_delete [L,NS]
RewriteRule ^/?panel/wiadomosci.html$ index.php?module=panel&action=messages [L,NS,QSA]
RewriteRule ^/?panel/ulubione.html$ index.php?module=panel&action=favourite [L,NS]
RewriteRule ^/?panel/blogi.html$ index.php?module=panel&action=blog [L,NS]
RewriteRule ^/?panel/dyskusje.html$ index.php?module=panel&action=discuss [L,NS]
RewriteRule ^/?panel/komentarze.html$ index.php?module=panel&action=comment [L,NS]
RewriteRule ^/?panel/forum(,([0-9]+))?$ index.php?module=panel&action=forum&page=$2 [L,NS]
RewriteRule ^/?panel/forum-wiadomosci.html$ index.php?module=panel&action=forum_message [L,NS]
RewriteRule ^/?panel/promocje.html$ index.php?module=panel&action=promo [L,NS]
RewriteRule ^/?panel/zamowienia.html$ index.php?module=panel&action=transaction [L,NS]

#catalog
RewriteRule ^/?katalog-projektow.html$ index.php?module=catalog&action=form [L,NS]
RewriteRule ^/?katalog-projektow-online.html$ index.php?module=catalog&action=online [L,NS]
RewriteRule ^/?katalog.html$ index.php?module=catalog&action=pay_form [L,NS]
RewriteRule ^/?katalog/komunikat.html$ index.php?module=catalog&action=info [L,NS,QSA]
RewriteRule ^/?katalog/potwierdzenie,([^,]*),([^,]*).html$ index.php?module=catalog&action=activate&trans_id=$1&email=$2 [L,NS]

#varia
RewriteRule ^/?dokumenty/O-nas.html$ index.php?module=varia&action=about [L,NS]
RewriteRule ^/?przedstawiciele/([0-9]+)?$ index.php?module=varia&action=agent&region=$1 [L,NS,QSA]
RewriteRule ^/?przedstawiciele/([0-9]+),([0-9]+)/?$ index.php?module=varia&action=agent&region=$1&page=$2 [L,NS,QSA]
RewriteRule ^/?przedstawiciele/([^,]*),([0-9]+)\.html?$ index.php?module=varia&action=agent_detail&id=$2 [L,NS]
RewriteRule ^/?konkurs/fotograficzny.html$ index.php?module=contest&action=form [L,NS]
RewriteRule ^/?znajdziemy-dla-ciebie-projekt.html$ index.php?module=varia&action=project_helper [L,NS]
RewriteRule ^/?projekt-indywidualny.html$ index.php?module=varia&action=custom_project [L,NS]
RewriteRule ^/?oferty-domow-gotowych/?$ index.php?module=varia&action=build_offer [L,NS]
RewriteRule ^/?finansowanie.html$ index.php?module=varia&action=financing [L,NS]
RewriteRule ^/?kontakt/?$ index.php?module=contact&action=form [L,NS]

#STRONY STATYCZNE
RewriteRule ^/?brak-dostepu.html$ index.php?module=authenticate&action=authentication_required [L,NS]
RewriteRule ^/?404.html$ index.php?module=page&action=display404 [L,NS]

RewriteRule ^/?alfabetyczna-lista-projektow/([aA-zZ_0-9]+)??$ index.php?module=alphabet&action=list&letter=$1 [L,NS]

############################################################# 301 - ze starej strony ################################################################################################
#wyszukiwarka np: projekty-domow/szukaj/Y2hhdGthOzs7Ozs7Ozs7,r,d,28/
RewriteRule ^/?projekty-domow/szukaj/([^,]+),(s|n|u|r{1}),(a|d{1}),([0-9]{1,2})	/projekty-domow/ [L,R=301]

#dodane na wniosek Sempai - 25-11-2025
ErrorDocument 404 /404.html

AddType font/woff2 .woff2

#
<IfModule mod_expires.c>
  ExpiresActive on
  ExpiresByType image/webp                "access plus 1 year"
  ExpiresByType image/gif                 "access plus 1 year"
  ExpiresByType image/png                 "access plus 1 year"
  ExpiresByType image/jpg                 "access plus 1 year"
  ExpiresByType image/jpeg                "access plus 1 year"
  ExpiresByType video/ogg                 "access plus 1 year"
  ExpiresByType audio/ogg                 "access plus 1 year"
  ExpiresByType video/mp4                 "access plus 1 year"
  ExpiresByType video/webm                "access plus 1 year"
  ExpiresByType font/truetype             "access plus 1 year"
  ExpiresByType font/opentype             "access plus 1 year"
  ExpiresByType font/woff2  			  "access plus 1 year"
  ExpiresByType application/font-woff2    "access plus 1 year"
  ExpiresByType application/x-font-woff   "access plus 1 year"
  ExpiresByType image/svg+xml             "access plus 1 year"
  ExpiresByType application/vnd.ms-fontobject "access plus 1 year"
  ExpiresByType text/css                  "access plus 1 year"
  ExpiresByType application/javascript    "access plus 1 year"
  ExpiresByType text/javascript           "access plus 1 year"
  ExpiresByType image/x-icon              "access plus 1 year"
</IfModule>

# BROWSER CACHING USING CACHE-CONTROL HEADERS
<ifModule mod_headers.c>
	# One year for image and video files
    <filesMatch ".(flv|gif|ico|jpg|jpeg|mp4|mpeg|png|svg|swf|webp)$">
        Header set Cache-Control "max-age=31536000, public"
    </filesMatch>
</ifModule>

<Files ~ "\.pdf$">
  Header set X-Robots-Tag "noindex, nofollow"
</Files>
