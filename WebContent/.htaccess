SetEnvIf Cookie ^.*_st=.*$ HAVE_TEST_COOKIE
Header append P3P "CP=\"NOI DSP COR NID DEV PSA OUR IND\"" env=!HAVE_TEST_COOKIE
Header append Set-Cookie "_st=%{UNIQUE_ID}e; expires=Sun, 21-Mar-2027 10:33:56 GMT; path=/" env=!HAVE_TEST_COOKIE

# e-active 2018-01-08
SetEnvIf Request_URI "^.*/pdf/.*$" norobots=1
Header set X-Robots-Tag "noindex, nofollow" env=norobots

RewriteEngine On

# --------------------------------------------------------------------
# SQL Injection Protection 
# --------------------------------------------------------------------

#RewriteCond %{QUERY_STRING} [^a-z](funion|union|char|sleep)[^a-z] [NC]
#RewriteRule (.*) - [F,L]

# --------------------------------------------------------------------

RewriteCond %{HTTP_HOST} ^www.studio-atrium.com.pl [or]
RewriteCond %{HTTP_HOST} ^studio-atrium.com.pl
RewriteRule (.*) https://www.studioatrium.pl/$1 [R=301,L]

## wyłączenie subdomeny test 2025-11-14 - wniosek sempai
RewriteCond %{HTTP_HOST} ^www.test.studioatrium.pl [or]
RewriteCond %{HTTP_HOST} ^test.studioatrium.pl
RewriteRule (.*) https://www.studioatrium.pl/$1 [R=410,L]

## wyłączenie subdomeny static 2025-12-03 - wniosek sempai
RewriteCond %{HTTP_HOST} ^www.static.studioatrium.pl [or]
RewriteCond %{HTTP_HOST} ^static.studioatrium.pl
RewriteRule (.*) https://www.studioatrium.pl/$1 [R=410,L]

# LOCALHOST: www-redirect disabled
#RewriteCond %{HTTP_HOST} !^www.
#RewriteCond %{REQUEST_URI} !\.well-known/acme-challenge
#RewriteRule (.*) https://www.%{HTTP_HOST}/$1 [R=301,L]
#RewriteCond %{HTTP_HOST} !^www.
#RewriteCond %{REQUEST_URI} !\.well-known/acme-challenge
#RewriteRule ^$ https://www.%{HTTP_HOST}%{SCRIPT_URI} [R=301,L]

## wyłączenie mobilnej wersji na subdomenie 2016-01-19
RewriteCond %{HTTP_HOST} ^www.m.studioatrium.pl [or]
RewriteCond %{HTTP_HOST} ^m.studioatrium.pl
RewriteRule (.*) https://www.studioatrium.pl/$1 [R=301,L]

#2016-04-04 - https (LOCALHOST: disabled)
#RewriteCond %{HTTPS} !=on
#RewriteCond %{HTTP_HOST} ^www.studioatrium.pl
#RewriteCond %{REQUEST_URI} !\.well-known/acme-challenge
