############################################################# 301 - ze starej strony ################################################################################################

#baza wiedzy
RewriteRule ^/?baza-wiedzy,([0-9]+),p-([0-9]+)/?$ index.php?module=relocator301&relocate=baza-wiedzy&params[page]=$2&params[tag]=$1 [L,NS]
RewriteRule ^/?baza-wiedzy,p-([0-9]+)/?$ index.php?module=relocator301&relocate=baza-wiedzy&params[page]=$1 [L,NS,QSA]
RewriteRule ^/?archiwum/Forum,([^,]*),([0-9]+),([0-9]+),([0-1]).html$ index.php?module=relocator301&relocate=archiwum-forum&params[title]=$1&params[id]=$2&params[page]=$3 [L,NS]

#projekty garazy - lista i konkretny projekt
RewriteRule ^/?projekty-garazy/wszystkie-projekty/([^,]*),([0-9]+).html$ index.php?module=relocator301&relocate=projekt-garazu&params[symbol]=$1&params[id]=$2 [L,NS]
RewriteRule ^/?projekty-garazy/wszystkie-projekty/([^,]*),([0-9]+),lustro.html$ index.php?module=relocator301&relocate=projekt-garazu&params[symbol]=$1&params[id]=$2&params[lustro]=1 [L,NS]
RewriteRule ^/?projekty-garazy/wszystkie-projekty/? /projekty-garazy/ [L,R=301]

#projekt wiaty
RewriteRule ^/?projekty/wiaty/S-A-([^,]*),([0-9]+).html$ index.php?module=relocator301&relocate=projekt-wiaty&params[symbol]=$1&params[id]=$2 [L,NS]

#projekt altany
RewriteRule ^/?projekty/altany/S-A-([^,]*),([0-9]+).html$ index.php?module=relocator301&relocate=projekt-altany&params[symbol]=$1&params[id]=$2 [L,NS]

#projekt ogrodzenia
RewriteRule ^/?projekty/ogrodzenia/S-OG-([^,]*),([0-9]+).html$ index.php?module=relocator301&relocate=projekt-ogrodzenia&params[symbol]=$1&params[id]=$2 [L,NS]

#projekt domu
RewriteRule ^/?projekty-domow/S-GL([^,]*),([0-9]+).html$ index.php?module=relocator301&relocate=projekt-domu&params[symbol]=$1&params[id]=$2 [L,NS]
RewriteRule ^/?selfie/S-GL([^,]*),([0-9]+).html$ index.php?module=relocator301&relocate=selfie&params[id]=$2 [L,NS]
RewriteRule ^/?projekty-domow/([^/]*)/S-GL([^,]*),([0-9]+).html$ index.php?module=relocator301&relocate=projekt-domu&params[symbol]=$2&params[id]=$3 [L,NS]
RewriteRule ^/?O-budowie-projektu-S-GL([^,]*),([0-9]+).html$ index.php?module=relocator301&relocate=projekt-domu&params[symbol]=$1&params[id]=$2 [L,NS]
RewriteRule ^/?projekty-domow/([^/]*)/S-GL([^,]*),([0-9]+),lustro.html$ index.php?module=relocator301&relocate=projekt-domu&params[symbol]=$2&params[id]=$3&params[mirror]=1 [L,NS]

