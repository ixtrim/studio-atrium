<?xml version="1.0" encoding="UTF-8"?>
<application>

	<registry>
		<global>
			<!-- Application CommonLogger -->
			<object global="true" name="application::commonlogger" type="Object" class="Point7_Log_PEARWrapper" lazy="true">
				<param target="configure" name="file" value="{#LOG_PATH#}/%{year}-%{month}-messages.log" />
				<param target="configure" name="format" value="%{timestamp} - %{message}" />
			</object>

			<!-- Application Cache -->
			<object global="true" name="application::cache" type="Object" class="Point7_WebApp_Cache_File">
				<param target="configure" name="path" value="{#APP_PATH#}/Cache" />
			</object>
			
			<!-- Application User Cache -->
			<object global="true" name="application::userCache" type="Object" class="Point7_WebApp_Cache_File">
				<param target="configure" name="path" value="{#APP_PATH#}/Cache/Users" />
			</object>

			<!-- Application ErrorLogger -->
			<object global="true" name="application::errorlogger" type="Object" class="Point7_Log_PEARWrapper" lazy="true">
				<param target="configure" name="file" value="{#LOG_PATH#}/%{year}-%{month}-errors.log" />
				<param target="configure" name="format" value="%{timestamp} - %{message}" />
			</object>

			<!-- Application DebugLogger -->
			<object global="true" name="application::debuglogger" type="Object" class="Point7_Log_PEARWrapper" lazy="true">
				<param target="configure" name="file" value="{#LOG_PATH#}/%{year}-%{month}-debug.log" />
				<param target="configure" name="format" value="%{timestamp} - %{message}" />
			</object>
			
			<!-- Application ConsultantLogger -->
			<object global="true" name="application::consultantlogger" type="Object" class="Point7_Log_PEARWrapper" lazy="true">
				<param target="configure" name="file" value="{#LOG_PATH#}/%{year}-%{month}-consultant.log" />
				<param target="configure" name="format" value="%{timestamp} - %{message}" />
			</object>

			<!-- Application NotFoundLogger -->
			<object global="true" name="application::notfoundlogger" type="Object" class="Point7_Log_PEARWrapper" lazy="true">
			    <param target="configure" name="file" value="{#LOG_PATH#}/%{year}-%{month}-404.log" />
			    <param target="configure" name="format" value="%{timestamp} - %{message}" />
			</object>

			<!-- Global PDO -->
			<object global="true" name="dbconnection::pdo1" type="Object" class="PDO" lazy="true">
				<param name="dsn" value="mysql:host=localhost;dbname=studioatrium2016new" />
				<param name="username" value="root" />
				<param name="passwd" value="IxtrimDev1234!" />
			</object>

			<!-- Application session -->
			<object global="true" name="application::session" type="Object" class="Point7_WebApp_Session">
				<param target="configure" name="name" value="__StudioAtrium" />
				<param target="configure" name="lifetime" value="360000" />
				<param target="configure" name="domain" value="studioatrium.local" />
				<param target="configure" name="autostart" value="true" />
			</object>

			<!-- Application DAO Repository -->
			<object global="true" name="application::daoRepository" type="Object" class="\StudioAtrium\Application\DAORepository" lazy="false" />

			<!-- Request Resolver -->
			<object global="true" name="application::requestResolver" type="Object" class="\StudioAtrium\Application\WWW\RequestResolver" >
				<param name="request" value="{$application::request}" />
			</object>

			<!-- Smarty function registry-->
			<object global="true" name="view::smartyFunctionsRegistry" type="Object" class="\StudioAtrium\Application\WWW\SmartyFunctionsRegistry">
				<param target="configure" name="res_url" value="https://media.studioatrium.pl/document" />
			</object>
		</global>

		<dao>
			<include file="DaoRegistry.include.xml" />
		</dao>

		<!-- Listeners goes here -->
		<listener>
			<object name="listener::dao" type="Object" class="\StudioAtrium\Entity\DAOActivityListener">
				<param target="configure" name="file" value="{#LOG_PATH#}/%{year}-%{month}-dao-activity.log" />
				<param target="configure" name="format" value="%{timestamp} - %{message}" />
			</object>
		</listener>

	</registry>

	<!-- Connect listener to event -->
	<dispatcher>
		<connect event="dao_object_insert" listener="listener::dao" />
		<connect event="dao_object_update" listener="listener::dao" />
		<connect event="dao_object_delete" listener="listener::dao" />
	</dispatcher>

