<?xml version="1.0" encoding="UTF-8"?>
<module>
	<classname>\StudioAtrium\Application\WWW\Module\Favourite</classname>
	<classfile>Favourite</classfile>
	<default_action>List</default_action>
	<request>
		<action name="List">
			<allowed_methods get="yes" />
		</action>
		
		<action name="Compare">
			<allowed_methods get="yes" />
		</action>
		
		<action name="Send">
			<allowed_methods post="yes" />
			<param name="receiver_email" required="yes">
				<validator name="Email" />
			</param>
			<param name="sender_email" required="yes">
				<validator name="Email" />
			</param>
			<param name="message" required="yes">
				<filter name="Trim" />
				<validator name="String" />
			</param>
			<param name="signature" required="no">
				<filter name="Trim" />
				<validator name="String" />
			</param>
		</action>
	</request>

	<commands>
		<on_before_exec>
			<include file="../defaultBeforeCommands.xml" />
		</on_before_exec>
	</commands>

	<result_map>
		<action name="List">
			<on_exec_ok>
				<view classname="Point7_WebApp_View_Smarty3">
					<param name="layout" value="Layout.tpl" />
					<param name="template" value="Favourite/List.tpl" />
					<param name="smarty.css_includes">
						<value>["favourite.min.css?v=20190129"]</value>
					</param>
					<param name="smarty.js_includes">
						<value>["jquery.mCustomScrollbar.concat.min.js","favourite.js?v=20190129"]</value>
					</param>
				</view>
			</on_exec_ok>
			<on_exec_error>
				<forward module="Page" action="Display404" />
			</on_exec_error>
		</action>	
		<action name="Compare">
			<on_exec_ok>
				<view classname="Point7_WebApp_View_Smarty3">
					<param name="layout" value="Layout.tpl" />
					<param name="template" value="Favourite/Compare.tpl" />
					<param name="smarty.css_includes">
						<value>["favourite.min.css?v=20190129"]</value>
					</param>
					<param name="smarty.js_includes">
						<value>["jquery.fancybox.js","jquery.mCustomScrollbar.concat.min.js", "compare.js?v=20191009"]</value>
					</param>
				</view>
			</on_exec_ok>
			<on_exec_error>
				<forward module="Page" action="Display404" />
			</on_exec_error>
		</action>
		<action name="Send">
			<on_exec_ok>
				<view classname="Point7_WebApp_View_JSON" />
			</on_exec_ok>
			<on_exec_error>
				<view classname="Point7_WebApp_View_JSON" />
			</on_exec_error>
		</action>
	</result_map>
</module>