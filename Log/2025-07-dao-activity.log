2025-07-01 08:45:09 - StudioAtrium\Entity\User\Message:Insert {"timestamp":1751359509,"user_id":18510,"user_ip":"79.184.22.187","user_browser":"Mozilla\/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit\/537.36 (KHTML, like Gecko) Chrome\/138.0.0.0 Safari\/537.36 Edg\/138.0.0.0","dao_classname":"StudioAtrium\\Entity\\User\\Message\\DAO\\PDOMySQL","dao_event":"dao_object_insert","entity_classname":"StudioAtrium\\Entity\\User\\Message","entity_data":{"id":1400,"__foreign_props":[],"user_id":18510,"parent_id":0,"author":"Wojciech","title":"Ricky","message":"Dzie\u0144 dobry,\r\n\r\nJakie jest zapotrzebowanie domu Ricky na ciep\u0142o (kWh\/m\u00b2\/rok) ? \r\n\r\nCzy jest mo\u017cliwo\u015b\u0107 przeprojektowania i podniesienia poddasza o jeden\/dwa pustaki, jak rozmawiali\u015bmy wczoraj przy samej \u015bcianie jest do\u015b\u0107 nisko 70cm ?\r\n\r\nCzy jest mo\u017cliwo\u015b\u0107 likwidacji okna na strychu?\r\n\r\nPozdrawiam,\r\nWojciech Guzik","create_date":"2025-07-01 08:45:09","status":"new","attachments":[],"_uid":358436},"entity_changes":false}
