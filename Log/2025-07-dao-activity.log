2025-07-25 05:48:21 - StudioAtrium\Entity\Project\Files\Download:Insert {"timestamp":1753422501,"user_id":18578,"user_ip":"91.94.103.231","user_browser":"Mozilla\/5.0 (Linux; Android 10; K) AppleWebKit\/537.36 (KHTML, like Gecko) Chrome\/138.0.0.0 Mobile Safari\/537.36","dao_classname":"StudioAtrium\\Entity\\Project\\Files\\Download\\DAO\\PDOMySQL","dao_event":"dao_object_insert","entity_classname":"StudioAtrium\\Entity\\Project\\Files\\Download","entity_data":{"id":24946,"__foreign_props":[],"project_id":"1600","file_type":"estimate","user_id":18578,"name":"Andrzej","surname":"Warpas","email":"umbarharm@gmail.com","phone":"608224228","project_order_date":"2","create_date":"2025-07-25 05:48:21","status":"downloaded","props":{"uwagi":"Moje pytanie dotyczy projektu z ewentualnymi zmianami, tzn.\r\n- dodatkowym oknem (oknami) od strony z ktorej nie ma \u017cadnego.\r\n- ogrzewaniem pod\u0142ogowym na obu kondygnacjach (i dostosowaniem do pompy ciepla)\r\n- zmian\u0105 materia\u0142\u00f3w konstrukcyjnych (beton kom\u00f3rkowy i minimum 25cm materia\u0142\u00f3w izolacyjnych).\r\nCzy jest mozliwosc takich zmian i jezeli tak to jak Panstwo wyceniaj\u0105 takie zmiany w projekcie i jakie s\u0105 orientacyjne terminy?."},"attachments":[],"_uid":6386228},"entity_changes":false}
