2024-05-22 19:56:49 - StudioAtrium\Entity\Discuss\Post:Insert {"timestamp":1716407809,"user_id":null,"user_ip":"207.230.106.215","user_browser":"Mozilla\/5.0 (X11; Ubuntu; Linux x86_64; rv:114.0) Gecko\/20100101 Firefox\/114.0","dao_classname":"StudioAtrium\\Entity\\Discuss\\Post\\DAO\\PDOMySQL","dao_event":"dao_object_insert","entity_classname":"StudioAtrium\\Entity\\Discuss\\Post","entity_data":{"id":10022,"__foreign_props":[],"parent_id":"0","cat_id":"2","project_id":"1656","nick":"Caleb","topic":"The Relief Consultants Enquiry: Unlock Your COVID-19 Relief Funds","content":"Hey there, hope everything's going well with you~\r\n\r\nI was just going through your website, and would it be correct to assume that you are classified as self-employed?\r\n\r\nAs a self-employed American, I just wanted to let you know that you may be eligible for up to $32,220 through the IRS's Self-Employed Tax Credit program:\r\nirs.gov\/newsroom\/tax-credits-for-paid-leave-under-the-american-rescue-plan-act-of-2021-specific-provisions-related-to-self-employed-individuals\r\n\r\nIf you want, you can easily check your estimated refund amount for the SETC program: setcreliefconsultants.com\r\n\r\nBTW,if you do decide that this is for you, please know that our process is designed with your security in mind.\r\n\r\nWe get paid only if we've successfully secured your funds, ensuring an entirely risk-free experience for our clients.\r\n\r\nHoping to hear from you.\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\nBest regards,\r\n\r\nCaleb Davis\r\n\r\nSETC Relief Consultants\r\n+1 619 798 8260\r\n\r\n\r\n\r\n\r\n\r\n\r\nTo stop receiving marketing messages, reply \u201cStop\u201d in the subject line for your website: studioatrium.pl","create_date":"2024-05-22 19:56:49","modify_date":"2024-05-22 19:56:49","status":"published","is_moderated":0,"attachments":[],"_uid":2565679},"entity_changes":false}
