2024-11-13 14:40:33 - StudioAtrium\Entity\Adwords\Clicks:Update {"timestamp":1731508833,"user_id":null,"user_ip":"188.146.96.143","user_browser":"Mozilla\/5.0 (Linux; Android 10; K) AppleWebKit\/537.36 (KHTML, like Gecko) Chrome\/130.0.0.0 Mobile Safari\/537.36","dao_classname":"StudioAtrium\\Entity\\Adwords\\Clicks\\DAO\\PDOMySQL","dao_event":"dao_object_update","entity_classname":"StudioAtrium\\Entity\\Adwords\\Clicks","entity_data":{"id":23004,"__foreign_props":[],"click_date":"2024-11-13","campaign_no":"12","clicks_desktop":"4","clicks_tablet":0,"clicks_mobile":11,"attachments":[],"_uid":5889046},"entity_changes":{"clicks_mobile":11}}
2024-11-13 14:45:33 - StudioAtrium\Entity\User\Message:Insert {"timestamp":1731509133,"user_id":17451,"user_ip":"46.186.99.59","user_browser":"Mozilla\/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit\/537.36 (KHTML, like Gecko) Chrome\/130.0.0.0 Safari\/537.36","dao_classname":"StudioAtrium\\Entity\\User\\Message\\DAO\\PDOMySQL","dao_event":"dao_object_insert","entity_classname":"StudioAtrium\\Entity\\User\\Message","entity_data":{"id":1290,"__foreign_props":[],"user_id":17451,"parent_id":0,"author":"Andrzej","title":"Zapytanie o projekt Tango V SZ","message":"Dzie\u0144 dobry. \r\nNie ukrywaj\u0105c mojego zainteresowania projektem Tango V SZ, mam kilka pyta\u0144. \r\nPierwsze brzmi o mo\u017cliwo\u015b\u0107 usuni\u0119cia instalacji gazowej, a w zamian zaprojektowanie wstawienia bojlera elektrycznego wraz z pod\u0142\u0105czeniem, w miejsce pieca gazowego. \r\nDrugie pytanie, o mo\u017cliwo\u015b\u0107 zmiany \u015bciany dzia\u0142owej miedzy pokojem 3 i 4 na prost\u0105. \r\nNast\u0119pnie usuniecie z projektu kabiny prysznicowej i modernizacje miejsca pod pralk\u0119 z jednoczesnym usuni\u0119ciem jej z kot\u0142owni.\r\nJe\u015bli zmian s\u0105 akceptowalne, to poprosz\u0119 o zarys ceny wprowadzenia takich zmian.\r\n\r\nDodatkowe pytanie pytanie kieruje odno\u015bnie kominka. Jest on wbudowany z zaprojektowanym rozprowadzaniem powietrza czy wolnostoj\u0105cy typu koza?","create_date":"2024-11-13 14:45:33","status":"new","project_id":"1648","attachments":[],"_uid":330276},"entity_changes":false}
