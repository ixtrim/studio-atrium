2024-02-29 20:21:23 - StudioAtrium\Entity\User\Message:Insert {"timestamp":1709238083,"user_id":16466,"user_ip":"5.184.66.17","user_browser":"Mozilla\/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit\/537.36 (KHTML, like Gecko) Chrome\/122.0.0.0 Safari\/537.36 Edg\/122.0.0.0","dao_classname":"StudioAtrium\\Entity\\User\\Message\\DAO\\PDOMySQL","dao_event":"dao_object_insert","entity_classname":"StudioAtrium\\Entity\\User\\Message","entity_data":{"id":1230,"__foreign_props":[],"user_id":16466,"parent_id":0,"author":"Jaros\u0142aw","title":"Dotyczy projektu czapla GL 1476","message":"Witam.\r\nJeste\u015bmy zdecydowani zakupi\u0107 projekt domu Czapla GL 1476 wersj\u0119 lustrzan\u0105.\r\nJeste\u015bmy w trakcie za\u0142atwiana warunk\u00f3w \u015brodowiskowych do planu zagospodarowania\r\nCzy mog\u0119 prosi\u0107 o przes\u0142anie rysunk\u00f3w pogl\u0105dowych, kt\u00f3re mo\u017cecie Pa\u0144stwo udost\u0119pni\u0107 przed zakupem:\r\nprzekr\u00f3j budynku,\r\nrzut parteru i poddasza,\r\nrysunek wi\u0119\u017aby dachowej.\r\nZ powa\u017canie.\r\nJaros\u0142aw Beksi\u0144ski\r\nsiedlisko@dziwiszewo.pl\r\ntel.: +48 505 180 325","create_date":"2024-02-29 20:21:23","status":"new","attachments":[],"_uid":314916},"entity_changes":false}
