2024-02-02 14:27:15 - StudioAtrium\Entity\User\Message:Insert {"timestamp":1706884035,"user_id":16382,"user_ip":"86.158.227.222","user_browser":"Mozilla\/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit\/537.36 (KHTML, like Gecko) Chrome\/120.0.0.0 Safari\/537.36","dao_classname":"StudioAtrium\\Entity\\User\\Message\\DAO\\PDOMySQL","dao_event":"dao_object_insert","entity_classname":"StudioAtrium\\Entity\\User\\Message","entity_data":{"id":1222,"__foreign_props":[],"user_id":16382,"parent_id":0,"author":"Dariusz","title":"Zapytanie o projekt Pliszka IV","message":"Dzien dobry.\r\nIntresuje mnie budowa domu technologia murowana.\r\nCzy moge prosic o wyliczenie materialu: lawy fundamentowe, zbrojenie, beton, strop zelbetonowy, ilosc pustakow grubosc 25cm, drewno na dach itp?\r\nPozdrawiam\r\nDariusz Galica","create_date":"2024-02-02 14:27:15","status":"new","project_id":"1314","attachments":[],"_uid":312868},"entity_changes":false}
