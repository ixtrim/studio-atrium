2024-09-03 11:02:00 - StudioAtrium\Entity\User\Message:Insert {"timestamp":1725361320,"user_id":17189,"user_ip":"89.64.3.173","user_browser":"Mozilla\/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit\/537.36 (KHTML, like Gecko) Chrome\/126.0.0.0 Safari\/537.36 OPR\/112.0.0.0","dao_classname":"StudioAtrium\\Entity\\User\\Message\\DAO\\PDOMySQL","dao_event":"dao_object_insert","entity_classname":"StudioAtrium\\Entity\\User\\Message","entity_data":{"id":1265,"__foreign_props":[],"user_id":17189,"parent_id":0,"author":"monika","title":"plan domu Pliszka V Bis","message":"Dzie\u0144 dobry,\r\n\r\nPisz\u0119 z pro\u015bb\u0105 o przes\u0142anie obrysu domu wraz z rysunkami szczeg\u00f3\u0142owymi\r\nprojektu Pliszka V Bis 103,9 m2.\r\n\r\nKlientka zakupi\u0142a projekt ww domu i b\u0119dzie dla mnie wygodne otrzymanie plik\u00f3w do podj\u0119cia pracy nad projektem wn\u0119trza.\r\n\r\nDzi\u0119kuj\u0119\r\nPozdrawiam\r\n\r\nMonika Salewicz","create_date":"2024-09-03 11:02:00","status":"new","attachments":[],"_uid":323876},"entity_changes":false}
