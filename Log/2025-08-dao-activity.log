2025-08-12 19:13:21 - StudioAtrium\Entity\User\Message:Update {"timestamp":1755026001,"user_id":18658,"user_ip":"91.226.196.30","user_browser":"Mozilla\/5.0 (Linux; Android 10; K) AppleWebKit\/537.36 (KHTML, like Gecko) Chrome\/138.0.0.0 Mobile Safari\/537.36","dao_classname":"StudioAtrium\\Entity\\User\\Message\\DAO\\PDOMySQL","dao_event":"dao_object_update","entity_classname":"StudioAtrium\\Entity\\User\\Message","entity_data":{"id":1417,"__foreign_props":[],"user_id":"18658","parent_id":"1415","author":"Studio Atrium","title":"Re: Gustaw II dodatkowa \u0142azienka","message":"<p>Dzie\u0144 dobry Panie Dawidzie,<\/p>\r\n<p>Mo\u017cemy dorprojektowa\u0107 dla Pana tak\u0105 \u0142azienk\u0119. Projekt z tak\u0105 zmian\u0105 kosztowa\u0142by 4839z\u0142. Termin realizacji na ten moment to pierwsza po\u0142owa pa\u017adziernika. Je\u017celi b\u0119dzie Pan zainteresowany, pozostaj\u0119 w kontakcie.<\/p>\r\n<p>Pozdrawiam<br \/>\u0141ukasz Jakubiec<\/p>","create_date":"2025-08-12 13:47:57","status":"read","attachments":[],"_uid":362788},"entity_changes":{"status":"read"}}
2025-08-12 19:25:08 - StudioAtrium\Entity\User:Insert {"timestamp":1755026708,"user_id":null,"user_ip":"89.64.81.140","user_browser":"Mozilla\/5.0 (iPhone; CPU iPhone OS 18_6_0 like Mac OS X) AppleWebKit\/605.1.15 (KHTML, like Gecko) CriOS\/139.0.7258.76 Mobile\/15E148 Safari\/604.1","dao_classname":"StudioAtrium\\Entity\\User\\DAO\\PDOMySQL","dao_event":"dao_object_insert","entity_classname":"StudioAtrium\\Entity\\User","entity_data":{"id":18668,"__foreign_props":[],"type":"user","email":"agnieszka.kadziela87@gmail.com","password":"f1d6056995baa85ea57926f50bc3975dafcbd93db72567bcf6fb1f46f14bfc21","name":"Agnieszka","surname":"Boguszewska","status":"new","register_date":"2025-08-12 19:25:08","attachments":[],"_uid":4779009,"props":null,"impersonated":false},"entity_changes":false}
2025-08-12 19:34:30 - StudioAtrium\Entity\User\Message:Update {"timestamp":1755027270,"user_id":16934,"user_ip":"178.43.13.167","user_browser":"Mozilla\/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit\/537.36 (KHTML, like Gecko) Chrome\/138.0.0.0 Safari\/537.36","dao_classname":"StudioAtrium\\Entity\\User\\Message\\DAO\\PDOMySQL","dao_event":"dao_object_update","entity_classname":"StudioAtrium\\Entity\\User\\Message","entity_data":{"id":1416,"__foreign_props":[],"user_id":"16934","parent_id":"1414","author":"Studio Atrium","title":"Re: Ricardo XV Sz","message":"<p>Dzie\u0144 dobry Pani Lidio<\/p>\r\n<p>Rozumiem, \u017ce chodzi Pani o projekt <a href=\"https:\/\/www.studioatrium.pl\/projekty-domow\/Ricardo-plus-xv-sz,1736.html\">Ricardo Plus XV SZ<\/a>, z podpiwniczeniem? Nie mamy niestety p\u00f3ki co tego projektu w wersji murowanej. Mo\u017cemy taki przygotowa\u0107 w cenie 5589z\u0142. Termin realizacji na ten moment to dopiero po\u0142owa grudnia. <br \/>W przypadku zainteresowania lub dodatkowych pyta\u0144, pozostaj\u0119 do dyspozycji.<\/p>\r\n<p><br \/>Pozdrawiam<br \/>\u0141ukasz Jakubiec<\/p>","create_date":"2025-08-11 11:00:13","status":"read","attachments":[],"_uid":362532},"entity_changes":{"status":"read"}}
