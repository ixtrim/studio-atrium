2025-04-22 12:55:07 - StudioAtrium\Entity\User\Message:Update {"timestamp":1745326507,"user_id":18231,"user_ip":"37.248.200.116","user_browser":"Mozilla\/5.0 (Linux; Android 10; K) AppleWebKit\/537.36 (KHTML, like Gecko) Chrome\/135.0.0.0 Mobile Safari\/537.36","dao_classname":"StudioAtrium\\Entity\\User\\Message\\DAO\\PDOMySQL","dao_event":"dao_object_update","entity_classname":"StudioAtrium\\Entity\\User\\Message","entity_data":{"id":1367,"__foreign_props":[],"user_id":"18231","parent_id":"1363","author":"Studio Atrium","title":"Re: Pliszka v bis -dane szczeg\u00f3\u0142owe wymiar\u00f3w pomieszcze\u0144","message":"<p>Ok, teraz zauwa\u017cy\u0142em.<br \/>Materia\u0142y w za\u0142\u0105czniku do tej wiadomo\u015bci.<\/p>\r\n<p>W przypadku dodatkowych pyta\u0144, pozostaj\u0119 w kontakcie.<\/p>\r\n<p>Pozdrawiam<br \/>\u0141ukasz Jakubiec<\/p>","create_date":"2025-04-22 10:10:41","status":"read","attachments":{"UserMessageFile":[{"id":51686,"__foreign_props":[],"profile_name":"UserMessageFile","filename":"68074f118bac8-gl_1389-wt21-pb21-pliszka_v_bis-rzuty-przekroje.pdf","path":"36\/349988","title":"Rzuty-przekroje","description":"","owner_uid":"349988","props":{"original_filename":"GL 1389-WT21-PB21-Pliszka V Bis-rzuty-przekroje.pdf","file_size":1071348,"file_created":1745309457},"sorting":0,"parent_attachment_id":0,"parent_relationship":"","_uid":13231621,"childAttachments":[]}]},"_uid":349988},"entity_changes":{"status":"read"}}
