2025-06-20 17:33:00 - StudioAtrium\Entity\User\Message:Insert {"timestamp":1750440780,"user_id":18482,"user_ip":"178.159.173.104","user_browser":"Mozilla\/5.0 (Windows NT 10.0; Win64; x64; rv:139.0) Gecko\/20100101 Firefox\/139.0","dao_classname":"StudioAtrium\\Entity\\User\\Message\\DAO\\PDOMySQL","dao_event":"dao_object_insert","entity_classname":"StudioAtrium\\Entity\\User\\Message","entity_data":{"id":1396,"__foreign_props":[],"user_id":18482,"parent_id":0,"author":"Katarzyna","title":"Zapytanie o projekt Kos XII SZ","message":"Dzie\u0144 dobry, \r\nCzy istnieje mo\u017cliwo\u015b\u0107 wprowadzenia zmian w projekcie? \r\nChcia\u0142abym zmieni\u0107 t\u0105 wersj\u0119 na murowan\u0105, oraz wprowadzi\u0107 zmiany m. in. w dachu, stolarce okiennej. Jaki jest koszt takiej zmiany? Pozdrawiam.","create_date":"2025-06-20 17:33:00","status":"new","project_id":"1751","attachments":[],"_uid":357412},"entity_changes":false}
